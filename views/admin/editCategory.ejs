<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Edit Category · ShoeZone Admin</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    />
    <link rel="stylesheet" href="/css/admin-shared.css" />
  </head>
  <body>
    <!-- ── Top bar ── -->
    <header class="admin-topbar">
      <a href="/admin" class="topbar-brand">
        <div class="topbar-brand-logo"><img src="/test.jpg" alt="Logo" /></div>
        <span class="topbar-brand-name">ShoeZone <em>Admin</em></span>
      </a>
      <div class="topbar-breadcrumb">
        <a
          href="/admin/categoryList"
          style="color: rgba(255, 255, 255, 0.35); text-decoration: none"
          >Category List</a
        >
        <i class="fas fa-chevron-right"></i>
        <span>Edit Category</span>
      </div>
      <div class="topbar-right">
        <div class="topbar-admin-pill" id="adminPill">
          <div class="topbar-admin-avatar">A</div>
          <span class="topbar-admin-label">Admin</span>
          <i class="fas fa-chevron-down topbar-admin-chevron"></i>
          <div class="topbar-admin-dropdown">
            <a href="/admin/logout" class="topbar-dropdown-item"
              ><i class="fas fa-sign-out-alt"></i> Logout</a
            >
          </div>
        </div>
      </div>
    </header>

    <div class="admin-shell">
      <%- include('../includes/adminSidebar.ejs', { activePage: 'categories' }) %>

      <main class="admin-main">
        <div class="admin-page-header">
          <div class="admin-page-header-left">
            <div class="admin-page-title">Edit Category</div>
            <div class="admin-page-subtitle"><%= categoryList.categoryName %></div>
          </div>
          <a href="/admin/categoryList" class="btn-admin btn-admin-ghost">
            <i class="fas fa-arrow-left"></i> Back to Categories
          </a>
        </div>

        <div class="admin-card" style="max-width: 560px">
          <div class="admin-card-body">
            <form
              id="categoryForm"
              method="POST"
              action="/admin/categoryList/edit/<%= categoryList._id %>"
            >
              <div
                id="globalError"
                class="admin-error"
                style="font-weight: 700; margin-bottom: 0.75rem"
              ></div>

              <!-- Category Name -->
              <div class="admin-field">
                <label class="admin-label">Category Name <span class="req">*</span></label>
                <input
                  type="text"
                  class="admin-input"
                  id="categoryName"
                  name="categoryName"
                  value="<%= categoryList.categoryName %>"
                  maxlength="20"
                  required
                />
                <small id="categoryNameError" class="admin-error"></small>
              </div>

              <!-- Description -->
              <div class="admin-field">
                <label class="admin-label">Description <span class="req">*</span></label>
                <input
                  type="text"
                  class="admin-input"
                  id="description"
                  name="description"
                  value="<%= categoryList.description %>"
                  maxlength="100"
                  required
                />
                <small id="descriptionError" class="admin-error"></small>
              </div>

              <!-- Buttons -->
              <div
                style="
                  display: flex;
                  gap: 0.75rem;
                  margin-top: 2rem;
                  padding-top: 1.5rem;
                  border-top: 1px solid var(--grey-100);
                "
              >
                <button
                  type="submit"
                  class="btn-admin btn-admin-primary"
                  style="flex: 1; justify-content: center; padding: 0.85rem"
                >
                  UPDATE CATEGORY
                </button>
                <button
                  type="button"
                  class="btn-admin btn-admin-ghost"
                  onclick="clearFields()"
                  style="flex: 1; justify-content: center; padding: 0.85rem"
                >
                  CLEAR
                </button>
                <a
                  href="/admin/categoryList"
                  class="btn-admin btn-admin-ghost"
                  style="flex: 1; justify-content: center; padding: 0.85rem"
                >
                  BACK
                </a>
              </div>
            </form>
          </div>
        </div>
      </main>
    </div>

    <footer class="admin-footer">© 2024 ShoeZone Admin Panel. All rights reserved.</footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
      document.getElementById("adminPill")?.addEventListener("click", function (e) {
        e.stopPropagation();
        this.classList.toggle("open");
      });
      document.addEventListener("click", () =>
        document.getElementById("adminPill")?.classList.remove("open")
      );

      const inputs = {
        categoryName: document.getElementById("categoryName"),
        description: document.getElementById("description"),
      };

      const errors = {
        categoryName: document.getElementById("categoryNameError"),
        description: document.getElementById("descriptionError"),
      };

      inputs.categoryName.addEventListener("input", function () {
        this.value = this.value.toUpperCase();
        validateField(this);
      });

      inputs.categoryName.addEventListener("blur", function () {
        this.value = this.value.toUpperCase();
        validateField(this);
      });

      Object.values(inputs).forEach((input) => {
        if (input) {
          input.addEventListener("input", () => validateField(input));
          input.addEventListener("blur", () => validateField(input));
        }
      });

      const initialFormState = {
        categoryName: inputs.categoryName.value.trim(),
        description: inputs.description.value.trim(),
      };

      function hasFormChanged() {
        return (
          inputs.categoryName.value.trim() !== initialFormState.categoryName ||
          inputs.description.value.trim() !== initialFormState.description
        );
      }

      function validateField(input) {
        const value = input.value.trim();
        const id = input.id;
        let errorMsg = "";

        if (id === "categoryName") {
          if (!value) errorMsg = "Category name is required";
          else if (!/^[A-Za-z\s]+$/.test(value)) errorMsg = "Only letters and spaces allowed";
          else if (value.length < 3) errorMsg = "Name must be at least 3 characters";
          else if (value.length > 20) errorMsg = "Name must be at most 20 characters";
        } else if (id === "description") {
          if (!value) errorMsg = "Description is required";
          else if (value.length < 3) errorMsg = "Description must be at least 3 characters";
          else if (value.length > 100) errorMsg = "Description must be at most 100 characters";
        }

        errors[id].textContent = errorMsg;
        input.classList.toggle("is-invalid", !!errorMsg);
      }

      function isFormValid() {
        let valid = true;
        Object.values(inputs).forEach((input) => {
          if (input) {
            validateField(input);
            if (input.classList.contains("is-invalid")) valid = false;
          }
        });
        return valid;
      }

      // Submit with SweetAlert
      document.getElementById("categoryForm").addEventListener("submit", async function (e) {
        e.preventDefault();

        if (!hasFormChanged()) {
          Swal.fire({
            icon: "info",
            title: "No Changes",
            text: "No changes were made to update.",
            timer: 2000,
            showConfirmButton: false,
          });
          return;
        }

        if (!isFormValid()) {
          Swal.fire({
            icon: "warning",
            title: "Invalid Input",
            text: "Please fix the highlighted errors",
            timer: 2500,
            showConfirmButton: false,
          });
          return;
        }

        const formData = new FormData(this);
        const data = Object.fromEntries(formData);

        try {
          const res = await fetch(this.action, {
            method: "PUT",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(data),
          });

          const result = await res.json();

          if (result.success) {
            await Swal.fire({
              icon: "success",
              title: "Success",
              text: "Category updated successfully!",
              timer: 2000,
              showConfirmButton: false,
            });
            window.location.href = "/admin/categoryList";
          } else {
            Swal.fire({
              icon: "error",
              title: "Error",
              text: result.message || "Failed to update category",
            });
          }
        } catch (err) {
          Swal.fire({
            icon: "error",
            title: "Network Error",
            text: "Failed to connect. Please try again.",
          });
        }
      });

      function clearFields() {
        document.getElementById("categoryName").value = "";
        document.getElementById("description").value = "";
        document.querySelectorAll(".admin-error").forEach((el) => (el.textContent = ""));
        document
          .querySelectorAll(".admin-input")
          .forEach((el) => el.classList.remove("is-invalid"));
      }
    </script>
  </body>
</html>
