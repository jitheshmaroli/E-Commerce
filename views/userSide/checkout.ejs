<%- include('../includes/userHead.ejs') %>
<link rel="stylesheet" href="/css/checkout.css" />

<%- include('../includes/userHeader.ejs') %>

<div class="container">
  <h1 class="page-title">Checkout</h1>
  <div class="checkout-wrapper">
    <div class="checkout-form">
      <input type="hidden" id="selectedAddressId" name="selectedAddressId" value="" />

      <div class="default-address">
        <% if (addresses && addresses.address.length > 0) { %> <% const defaultAddress =
        addresses.address.find(a => a.isDefault) %>

        <% if (defaultAddress) { %>
        <div class="address-card" data-address-id="<%= defaultAddress._id %>">
          <span class="default-address-tag">Delivery Address</span>
          <h3><%= defaultAddress.name %></h3>
          <p>
            <%= defaultAddress.houseName.trim() %>, <%= defaultAddress.street.trim() %>, <%=
            defaultAddress.city.trim() %>, <%= defaultAddress.district.trim() %>, <%=
            defaultAddress.state.trim() %>, <%= defaultAddress.pinCode %>
          </p>
          <div class="address-card-buttons">
            <button type="button" class="btn product-btn edit-address-btn btn-sm">Edit</button>

            <% if (addresses.address.length > 1) { %>
            <button
              type="button"
              class="btn product-btn change-address-btn btn-sm"
              data-bs-toggle="collapse"
              data-bs-target="#addressListCollapse"
            >
              Change address
            </button>
            <% } %>
          </div>
        </div>

        <!-- Collapsible other addresses (only show if >1) -->
        <% if (addresses.address.length > 1) { %>
        <div class="collapse" id="addressListCollapse">
          <div class="address-list">
            <% addresses.address.forEach((address) => { %>
            <% if (!address.isDefault) { %>
            <div class="address-card" data-address-id="<%= address._id %>">
              <h3><%= address.name %></h3>
              <p>
                <%= address.houseName.trim() %>, <%= address.street.trim() %>, <%=
                address.city.trim() %>, <%= address.district.trim() %>, <%= address.state.trim() %>,
                <%= address.pinCode %>
              </p>
              <div class="address-card-buttons">
                <button type="button" class="btn product-btn edit-address-btn btn-sm">Edit</button>
                <button
                  type="button"
                  class="btn product-btn deliver-to-here-btn btn-sm"
                  data-address-id="<%= address._id %>"
                >
                  Deliver Here
                </button>
              </div>
            </div>
            <% } %>
            <% }) %>
          </div>
        </div>
        <% } %>

        <% } else { %>
        <!-- No default → show all -->
        <p class="text-warning mb-3">
          <strong>No default address set.</strong> Please select one below:
        </p>

        <div class="address-list" id="addressListNoDefault">
          <% addresses.address.forEach((address) => { %>
          <div class="address-card" data-address-id="<%= address._id %>">
            <h3><%= address.name %></h3>
            <p>
              <%= address.houseName.trim() %>, <%= address.street.trim() %>, <%= address.city.trim()
              %>, <%= address.district.trim() %>, <%= address.state.trim() %>, <%= address.pinCode
              %>
            </p>
            <div class="address-card-buttons">
              <button type="button" class="btn product-btn edit-address-btn btn-sm">Edit</button>
              <button
                type="button"
                class="btn product-btn deliver-to-here-btn btn-sm"
                data-address-id="<%= address._id %>"
              >
                Deliver Here
              </button>
            </div>
          </div>
          <% }) %>
        </div>
        <% } %>

        <% } else { %>
        <p class="text-danger">No addresses found. Please add a new address to continue.</p>
        <% } %>
      </div>
      <br />
      <div class="add-address-card">
        <button
          type="button"
          class="btn product-btn btn-add-address"
          data-bs-toggle="modal"
          data-bs-target="#addAddressModal"
        >
          Add New Address
        </button>
      </div>
      <br />
      <div class="payment-options">
        <h3>Payment Options</h3>
        <div class="payment-option">
          <input type="radio" id="online-payment" name="payment_method" />
          <label for="online-payment">Online Payment</label>
        </div>
        <div class="payment-option">
          <% if (user.wallet === 0) { %>
          <input type="radio" disabled id="wallet-payment" name="payment_method" />
          <label for="wallet-payment"
            >Wallet Payment (Balance: ₹<%= user.wallet.toFixed(2) %>)</label
          >
          <% } else { %>
          <input type="radio" id="wallet-payment" name="payment_method" />
          <label for="wallet-payment">Wallet Payment (₹<%= user.wallet.toFixed(2) %>)</label>
          <% } %>
          <span id="wallet-payment-error" class="text-danger"></span>
        </div>
        <div class="payment-option">
          <input type="radio" id="cod" name="payment_method" />
          <label for="cod" id="cod-label">Cash on Delivery</label>
        </div>
      </div>
    </div>

    <div class="order-summary">
      <% if (checkoutItems && checkoutItems.length > 0) { %>
      <div class="order-details">
        <h3>Order Summary</h3>
        <div class="products">
          <% checkoutItems.forEach(checkoutItem => { %>
          <div class="product-details" data-product-id="<%= checkoutItem.product._id %>">
            <img
              src="/uploads/<%= checkoutItem.product.photos[0].filename %>"
              width="100"
              height="100"
              alt="Product Image"
            />
            <div class="price-quantity">
              <h4><%= checkoutItem.product.name %></h4>
              <% if (checkoutItem.product.bestOffer) { %>
              <p
                data-product-price="<%= checkoutItem.product.currentPrice %>"
                data-original-price="<%= checkoutItem.product.price %>"
              >
                Price:
                <span class="original-price">₹<%= checkoutItem.product.price.toFixed(2) %></span>
                ₹<%= checkoutItem.product.currentPrice.toFixed(2) %>
                <i
                  class="fas fa-info-circle offer-icon"
                  data-bs-toggle="modal"
                  data-bs-target="#offerModal<%= checkoutItem.product._id %>"
                ></i>
              </p>
              <% } else { %>
              <p data-product-price="<%= checkoutItem.product.price %>">
                Price: ₹<%= checkoutItem.product.price.toFixed(2) %>
              </p>
              <% } %>
              <div class="quantity-control">
                <button class="quantity-btn" aria-label="Decrease">-</button>
                <input
                  type="number"
                  class="quantity-input"
                  value="<%= checkoutItem.quantity || 1 %>"
                  min="1"
                  data-stock="<%= checkoutItem.product.stock %>"
                />
                <button class="quantity-btn" aria-label="Increase">+</button>
              </div>
            </div>
          </div>
          <% if (checkoutItem.product.bestOffer) { %>
          <div class="modal fade" id="offerModal<%= checkoutItem.product._id %>" tabindex="-1">
            <div class="modal-dialog">
              <div class="modal-content">
                <div class="modal-header">
                  <h5 class="modal-title">Offer Details</h5>
                  <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                  <%= checkoutItem.product.bestOffer.name %>: <%=
                  checkoutItem.product.bestOffer.discountType === 'percentage' ?
                  checkoutItem.product.bestOffer.discountValue + '% off' : '₹' +
                  checkoutItem.product.bestOffer.discountValue + ' off' %>
                </div>
              </div>
            </div>
          </div>
          <% } %>
          <% }) %>
          <hr />
          <p id="product-total-price"></p>
          <div class="coupon-section">
            <h4>Apply Coupon</h4>
            <button
              type="button"
              class="btn product-btn btn-sm mb-3"
              data-bs-toggle="modal"
              data-bs-target="#couponsModal"
            >
              <i class="fas fa-tags me-1"></i> View Available Offers
            </button>
            <div class="coupon-form">
              <input type="text" id="couponCodeInput" placeholder="Enter coupon code" />
              <button id="applyCouponBtn" class="btn product-btn btn-sm">Apply</button>
            </div>
            <div id="appliedCouponContainer" style="display: none">
              <span id="appliedCouponCode"></span>
              <button id="removeCouponBtn" class="btn product-btn btn-sm">Remove</button>
            </div>
            <span id="couponMessage"></span>
          </div>
          <hr />
          <div class="total-amount">
            <p id="base-price"></p>
            <p id="total-quantity">Total Items: 0</p>
            <p id="coupon-discount"></p>
            <p id="sub-total"></p>
            <p id="sales-tax"></p>
            <p id="delivery-charge"></p>
            <p id="order-total-price">Total Cost: ₹0.00</p>
          </div>
        </div>
        <form action="/place-order" method="POST">
          <button type="submit" class="btn product-btn btn-place-order">Place Order</button>
        </form>
        <% } else { %>
        <div class="empty-state">
          <h1>NO ITEMS SELECTED FOR CHECKOUT</h1>
          <a href="/cart" class="btn product-btn">BACK TO CART</a>
        </div>
        <% } %>
      </div>
    </div>

    <div
      class="modal fade"
      id="addAddressModal"
      tabindex="-1"
      aria-labelledby="addAddressModalLabel"
      aria-hidden="true"
    >
      <div class="modal-dialog">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" id="addAddressModalLabel">Add New Address</h5>
            <button
              type="button"
              class="btn-close"
              data-bs-dismiss="modal"
              aria-label="Close"
            ></button>
          </div>
          <div class="modal-body">
            <form id="addAddressForm">
              <div class="mb-3">
                <label for="name" class="form-label">Name</label>
                <input type="text" class="form-control" id="name" name="name" required />
              </div>
              <div class="mb-3">
                <label for="houseName" class="form-label">House Name/Number</label>
                <input type="text" class="form-control" id="houseName" name="houseName" required />
              </div>
              <div class="mb-3">
                <label for="street" class="form-label">Street</label>
                <input type="text" class="form-control" id="street" name="street" required />
              </div>
              <div class="mb-3">
                <label for="city" class="form-label">City</label>
                <input type="text" class="form-control" id="city" name="city" required />
              </div>
              <div class="mb-3">
                <label for="district" class="form-label">District</label>
                <input type="text" class="form-control" id="district" name="district" required />
              </div>
              <div class="mb-3">
                <label for="state" class="form-label">State</label>
                <input type="text" class="form-control" id="state" name="state" required />
              </div>
              <div class="mb-3">
                <label for="pinCode" class="form-label">PIN Code</label>
                <input type="number" class="form-control" id="pinCode" name="pinCode" required />
              </div>
              <div class="mb-3 form-check d-flex align-items-center">
                <input type="checkbox" class="form-check-input" id="isDefault" name="isDefault" />
                <label class="form-check-label ms-2" for="isDefault">
                  Set as Default Address
                </label>
              </div>
            </form>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            <button type="button" class="btn btn-primary" id="saveNewAddress">Save Address</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Coupons Modal -->
    <div
      class="modal fade"
      id="couponsModal"
      tabindex="-1"
      aria-labelledby="couponsModalLabel"
      aria-hidden="true"
    >
      <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" id="couponsModalLabel">Available Coupons</h5>
            <button
              type="button"
              class="btn-close"
              data-bs-dismiss="modal"
              aria-label="Close"
            ></button>
          </div>
          <div class="modal-body">
            <% if (availableCoupons && availableCoupons.length > 0) { %>
            <div class="list-group">
              <% availableCoupons.forEach(coupon => { %>
              <div class="list-group-item d-flex justify-content-between align-items-center py-3">
                <div>
                  <h6 class="mb-1 fw-bold text-success"><%= coupon.code %></h6>
                  <p class="mb-1 text-muted">
                    <strong><%= coupon.discount %>% OFF</strong>
                    <small>on your order</small>
                  </p>
                  <small class="text-muted">
                    Valid until <%= new Date(coupon.expiryDate).toLocaleDateString('en-IN', { day:
                    'numeric', month: 'short', year: 'numeric' }) %>
                  </small>
                </div>
                <button
                  class="btn btn-sm btn-outline-success copy-coupon-btn"
                  data-code="<%= coupon.code %>"
                >
                  Copy Code
                </button>
              </div>
              <% }) %>
            </div>
            <% } else { %>
            <div class="text-center py-4">
              <i class="fas fa-tags fa-3x text-muted mb-3"></i>
              <p class="text-muted">No active coupons available right now.</p>
              <small>Check back later for exciting offers!</small>
            </div>
            <% } %>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
          </div>
        </div>
      </div>
    </div>
    <!-- edit address -->
    <div
      class="modal fade"
      id="editAddressModal"
      tabindex="-1"
      aria-labelledby="editAddressModalLabel"
      aria-hidden="true"
    >
      <div class="modal-dialog">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" id="editAddressModalLabel">Edit Address</h5>
            <button
              type="button"
              class="btn-close"
              data-bs-dismiss="modal"
              aria-label="Close"
            ></button>
          </div>
          <div class="modal-body">
            <form id="editAddressForm">
              <input type="hidden" id="addressId" name="addressId" />
              <div class="mb-3">
                <label for="name" class="form-label">Name</label>
                <input type="text" class="form-control" id="name" name="name" required />
              </div>
              <div class="mb-3">
                <label for="houseName" class="form-label">House Name/Number</label>
                <input type="text" class="form-control" id="houseName" name="houseName" required />
              </div>
              <div class="mb-3">
                <label for="street" class="form-label">Street</label>
                <input type="text" class="form-control" id="street" name="street" required />
              </div>
              <div class="mb-3">
                <label for="city" class="form-label">City</label>
                <input type="text" class="form-control" id="city" name="city" required />
              </div>
              <div class="mb-3">
                <label for="district" class="form-label">District</label>
                <input type="text" class="form-control" id="district" name="district" required />
              </div>
              <div class="mb-3">
                <label for="state" class="form-label">State</label>
                <input type="text" class="form-control" id="state" name="state" required />
              </div>
              <div class="mb-3">
                <label for="pinCode" class="form-label">PIN Code</label>
                <input type="number" class="form-control" id="pinCode" name="pinCode" required />
              </div>
              <div class="mb-3 form-check d-flex align-items-center">
                <input type="checkbox" class="form-check-input" id="isDefault" name="isDefault" />
                <label class="form-check-label ms-2" for="isDefault">
                  Set as Default Address
                </label>
              </div>
            </form>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            <button type="button" class="btn btn-primary" id="saveEditedAddress">
              Save Changes
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../includes/userFooter.ejs') %>
<%- include('../includes/userScripts.ejs') %>
<%- include('../includes/addressValidation.ejs') %>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    //  Elements & Variables
    const productCards = Array.from(document.querySelectorAll(".product-details"));
    const walletPaymentRadio = document.getElementById("wallet-payment");
    const walletBalanceSpan = document.querySelector('label[for="wallet-payment"]');
    const walletBalance = walletBalanceSpan
      ? parseFloat(walletBalanceSpan.textContent.match(/₹([\d.]+)/)?.[1] || 0)
      : 0;
    const walletPaymentErrorSpan = document.getElementById("wallet-payment-error");

    const placeOrderBtn = document.querySelector(".btn-place-order");
    const paymentRadios = document.querySelectorAll('input[name="payment_method"]');
    const couponInput = document.getElementById("couponCodeInput");
    const applyCouponBtn = document.getElementById("applyCouponBtn");
    const removeCouponBtn = document.getElementById("removeCouponBtn");
    const appliedCouponContainer = document.getElementById("appliedCouponContainer");
    const appliedCouponCodeSpan = document.getElementById("appliedCouponCode");
    const couponMessage = document.getElementById("couponMessage");

    let selectedAddressId = null;
    let selectedPaymentMode = null;
    let couponCode = null;
    let couponDiscount = 0;

    function selectAddress(addressId, cardElement) {
      document
        .querySelectorAll(".address-card")
        .forEach((c) => c.classList.remove("active-address"));
      if (cardElement) cardElement.classList.add("active-address");

      selectedAddressId = addressId;
      document.getElementById("selectedAddressId").value = addressId;

      checkIfOrderCanBePlaced();
    }

    const defaultCard = document.querySelector(".address-card[data-address-id]");
    if (defaultCard) {
      selectAddress(defaultCard.dataset.addressId, defaultCard);
    }

    document.querySelectorAll(".deliver-to-here-btn").forEach((btn) => {
      btn.addEventListener("click", async function () {
        const addressId = this.dataset.addressId;
        const card = this.closest(".address-card");

        try {
          const res = await fetch("/set-default", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ addressId }),
          });
          const data = await res.json();

          if (data.success) {
            selectAddress(addressId, card);
            Swal.fire({
              icon: "success",
              title: "Address Selected",
              text: "This address will be used for delivery.",
              timer: 1800,
              showConfirmButton: false,
            });
          } else {
            Swal.fire({
              icon: "error",
              title: "Error",
              text: data.message || "Could not set default address.",
            });
          }
        } catch (err) {
          console.error(err);
          Swal.fire({
            icon: "error",
            title: "Network Error",
            text: "Failed to update address.",
          });
        }
      });
    });

    //  Coupon Handling
    applyCouponBtn.addEventListener("click", () => {
      const code = couponInput.value.trim().toUpperCase();
      if (!code) return;

      fetch(`/coupon-discount/${code}`)
        .then((res) => res.json())
        .then((data) => {
          if (data.success) {
            couponDiscount = data.discount / 100;
            couponCode = code;
            couponMessage.textContent = `Coupon applied! −${data.discount}%`;
            couponMessage.className = "text-success fw-bold";
            showAppliedCoupon(code);
          } else {
            couponDiscount = 0;
            couponCode = null;
            couponMessage.textContent = data.error || "Invalid or expired coupon";
            couponMessage.className = "text-danger";
          }
          calculateTotals();
          checkIfOrderCanBePlaced();
        })
        .catch((err) => {
          console.error(err);
          couponMessage.textContent = "Error applying coupon";
          couponMessage.className = "text-danger";
        });

      couponInput.value = "";
    });

    removeCouponBtn.addEventListener("click", () => {
      couponCode = null;
      couponDiscount = 0;
      couponMessage.textContent = "Coupon removed";
      couponMessage.className = "text-primary";
      hideAppliedCoupon();
      calculateTotals();
      checkIfOrderCanBePlaced();
    });

    function showAppliedCoupon(code) {
      appliedCouponCodeSpan.textContent = `Applied: ${code}`;
      appliedCouponContainer.style.display = "block";
      couponInput.disabled = true;
      applyCouponBtn.disabled = true;
    }

    function hideAppliedCoupon() {
      appliedCouponContainer.style.display = "none";
      couponInput.disabled = false;
      applyCouponBtn.disabled = false;
    }

    document.querySelectorAll(".coupon-item").forEach((item) => {
      item.addEventListener("click", () => {
        couponInput.value = item.dataset.code;
        applyCouponBtn.click();
      });
    });

    // Copy coupon code to clipboard
    document.querySelectorAll(".copy-coupon-btn").forEach((btn) => {
      btn.addEventListener("click", function () {
        const code = this.dataset.code;

        navigator.clipboard
          .writeText(code)
          .then(() => {
            const originalText = this.textContent;
            this.textContent = "Copied!";
            this.classList.add("btn-success");
            this.classList.remove("btn-outline-success");

            setTimeout(() => {
              this.textContent = originalText;
              this.classList.remove("btn-success");
              this.classList.add("btn-outline-success");
            }, 2000);
          })
          .catch((err) => {
            console.error("Failed to copy: ", err);
            Swal.fire({
              icon: "error",
              title: "Copy Failed",
              text: "Please copy manually.",
              timer: 2000,
            });
          });
      });
    });
    //  Calculate Totals & Constraints
    function calculateTotals() {
      let basePrice = 0;
      let totalQuantity = 0;
      let totalSavings = 0;

      productCards.forEach((card) => {
        const qtyInput = card.querySelector(".quantity-input");
        const priceDiv = card.querySelector("p[data-product-price]");

        if (!qtyInput || !priceDiv) return;

        const qty = parseInt(qtyInput.value) || 0;
        const currentPrice = parseFloat(priceDiv.dataset.productPrice) || 0;
        const originalPrice = parseFloat(priceDiv.dataset.originalPrice) || currentPrice;

        totalQuantity += qty;
        basePrice += qty * currentPrice;
        totalSavings += qty * (originalPrice - currentPrice);
      });

      const salesTax = basePrice * 0.08;
      const deliveryCharge = 40;
      const subTotal = basePrice * (1 - couponDiscount);
      const discountAmount = basePrice * couponDiscount;
      const grandTotal = subTotal + salesTax + deliveryCharge;

      // Wallet constraint
      if (walletBalance < grandTotal) {
        walletPaymentRadio.disabled = true;
        walletPaymentErrorSpan.textContent = "Insufficient Balance";
      } else {
        walletPaymentRadio.disabled = false;
        walletPaymentErrorSpan.textContent = "";
      }

      // COD constraint
      const codInput = document.getElementById("cod");
      const codLabel = document.getElementById("cod-label");
      if (grandTotal > 1000) {
        codInput.disabled = true;
        codLabel.textContent = "Cash on Delivery (not available for orders > ₹1000)";
      } else {
        codInput.disabled = false;
        codLabel.textContent = "Cash on Delivery";
      }

      // Update DOM
      document.getElementById("base-price").textContent = `Base Price: ₹${basePrice.toFixed(2)}`;
      document.getElementById("sub-total").textContent = `Sub Total: ₹${subTotal.toFixed(2)}`;
      document.getElementById("sales-tax").textContent = `Sales Tax: ₹${salesTax.toFixed(2)}`;
      document.getElementById("delivery-charge").textContent =
        `Delivery Charge: ₹${deliveryCharge.toFixed(2)}`;
      document.getElementById("order-total-price").textContent =
        `Total Cost: ₹${grandTotal.toFixed(2)}`;
      document.getElementById("total-quantity").textContent = `Total Items: ${totalQuantity}`;

      document.getElementById("coupon-discount").textContent =
        discountAmount > 0
          ? `Coupon Discount: -₹${discountAmount.toFixed(2)}`
          : `Coupon Discount: ₹0.00`;

      return { discountAmount, salesTax, deliveryCharge, subTotal, totalSavings, grandTotal };
    }

    //  Quantity Controls
    const MAX_QTY_PER_USER = 5;

    productCards.forEach((card) => {
      const productId = card.dataset.productId;
      const qtyInput = card.querySelector(".quantity-input");
      const stock = parseInt(qtyInput?.dataset.stock || 9999);
      const storedQty = JSON.parse(localStorage.getItem(`cartQuantity_${productId}`));

      if (storedQty && storedQty >= 1 && storedQty <= stock) {
        qtyInput.value = storedQty;
      }

      // +/- buttons
      card.querySelectorAll(".quantity-btn").forEach((btn) => {
        btn.addEventListener("click", (e) => {
          e.preventDefault();
          let qty = parseInt(qtyInput.value) || 1;
          const isIncrease = btn.textContent === "+";

          if (isIncrease) {
            if (qty < MAX_QTY_PER_USER && qty < stock) {
              qty++;
            } else if (qty >= MAX_QTY_PER_USER) {
              Swal.fire("Limit Reached", "Maximum 5 units per customer.", "warning");
            } else {
              Swal.fire("Out of Stock", "Cannot add more than available stock.", "warning");
            }
          } else {
            if (qty > 1) qty--;
          }

          qtyInput.value = qty;
          localStorage.setItem(`cartQuantity_${productId}`, JSON.stringify(qty));
          calculateTotals();
          checkIfOrderCanBePlaced();
        });
      });

      // Manual input
      qtyInput.addEventListener("change", () => {
        let qty = parseInt(qtyInput.value) || 1;
        if (qty > MAX_QTY_PER_USER) {
          qty = MAX_QTY_PER_USER;
          Swal.fire("Limit Reached", "Maximum 5 units allowed.", "warning");
        } else if (qty > stock) {
          qty = stock;
          Swal.fire("Stock Limit", "Adjusted to available stock.", "warning");
        } else if (qty < 1) {
          qty = 1;
        }
        qtyInput.value = qty;
        localStorage.setItem(`cartQuantity_${productId}`, JSON.stringify(qty));
        calculateTotals();
        checkIfOrderCanBePlaced();
      });
    });

    //  Payment Method Tracking
    paymentRadios.forEach((radio) => {
      radio.addEventListener("change", () => {
        const modeMap = {
          "online-payment": "online",
          "wallet-payment": "wallet",
          cod: "cod",
        };
        selectedPaymentMode = modeMap[radio.id] || null;
        checkIfOrderCanBePlaced();
      });
    });

    //  Place Order Button State
    function checkIfOrderCanBePlaced() {
      const hasAddress = !!selectedAddressId;
      const hasPayment = !!selectedPaymentMode;
      const hasValidItems = productCards.some((card) => {
        const qty = parseInt(card.querySelector(".quantity-input")?.value || 0);
        return qty > 0;
      });

      const canPlace = hasAddress && hasPayment && hasValidItems;

      placeOrderBtn.disabled = !canPlace;
      placeOrderBtn.style.opacity = canPlace ? "1" : "0.6";

      if (!canPlace) {
        if (!hasAddress) {
          placeOrderBtn.title = "Select a delivery address";
        } else if (!hasPayment) {
          placeOrderBtn.title = "Choose a payment method";
        } else {
          placeOrderBtn.title = "No items in order";
        }
      } else {
        placeOrderBtn.title = "";
      }
    }

    // Initial checks
    calculateTotals();
    checkIfOrderCanBePlaced();

    //  Place Order – Final Validation & Submission
    placeOrderBtn.addEventListener("click", async (e) => {
      e.preventDefault();

      if (!selectedAddressId) {
        Swal.fire({
          icon: "warning",
          title: "Address Required",
          text: "Please select a delivery address.",
          confirmButtonText: "OK",
        });
        return;
      }

      if (!selectedPaymentMode) {
        Swal.fire({
          icon: "warning",
          title: "Payment Required",
          text: "Please select a payment method.",
          confirmButtonText: "OK",
        });
        return;
      }

      // Collect items
      const orderItems = [];
      productCards.forEach((card) => {
        const qty = parseInt(card.querySelector(".quantity-input")?.value || 0);
        if (qty > 0) {
          orderItems.push({
            productId: card.dataset.productId,
            quantity: qty,
          });
        }
      });

      if (orderItems.length === 0) {
        Swal.fire("No Items", "Your order is empty.", "error");
        return;
      }

      // Total cost
      const totalCostStr = document.getElementById("order-total-price").textContent;
      const totalCost = parseFloat(totalCostStr.match(/[\d.]+/)?.[0] || 0);

      // Address details
      let addressDetails;
      try {
        const res = await fetch(`/get-address/${selectedAddressId}`);
        if (!res.ok) throw new Error();
        addressDetails = await res.json();
      } catch {
        Swal.fire("Error", "Could not load selected address.", "error");
        return;
      }

      const priceDetails = calculateTotals();

      try {
        const response = await fetch("/place-order", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            orderItems,
            totalCost,
            paymentMode: selectedPaymentMode,
            couponCode,
            priceDetails,
            addressDetails,
          }),
        });

        const data = await response.json();

        if (data.cod || data.wallet) {
          Swal.fire({
            icon: "success",
            title: "Order Placed",
            text: "Your order has been successfully placed.",
            confirmButtonText: "OK",
          }).then(() => {
            window.location.href = "/order-history";
          });
        } else if (data.online) {
          const options = {
            key: "rzp_test_Tb5YYNqwWeIaYk",
            amount: data.razorpayOrder.amount,
            currency: data.razorpayOrder.currency,
            name: "ShoeZone",
            description: "Order Payment",
            order_id: data.razorpayOrder.id,
            handler: async function (response) {
              if (response.razorpay_payment_id) {
                response.orderId = data.orderId;
                const verifyRes = await fetch("/checkout/verify", {
                  method: "POST",
                  headers: { "Content-Type": "application/json" },
                  body: JSON.stringify(response),
                });
                const verifyData = await verifyRes.json();

                if (verifyData.message === "Payment verified") {
                  window.location.href = `/order-details/${data.orderId}`;
                } else {
                  window.location.href = `/order-details/${data.orderId}?payment=failed`;
                }
              }
            },
            prefill: {
              name: "User Name",
              email: "user@example.com",
              contact: "9876543210",
            },
            notes: { address: "Address Details" },
          };

          const rzp = new Razorpay(options);
          rzp.open();

          rzp.on("payment.failed", (response) => {
            window.location.href = `/payment-failed?orderId=${data.orderId}&reason=${encodeURIComponent(response.error.description)}`;
          });

          rzp.on("payment.dismissed", () => {
            window.location.href = `/payment-failed?orderId=${data.orderId}&reason=Payment%20dismissed%20by%20user`;
          });
        } else {
          Swal.fire({
            icon: "error",
            title: "Order Failed",
            text: data.error || "Something went wrong.",
            confirmButtonText: "OK",
          });
        }
      } catch (err) {
        console.error(err);
        Swal.fire({
          icon: "error",
          title: "Network Error",
          text: "Failed to place order. Please try again.",
          confirmButtonText: "OK",
        });
      }
    });
  });
</script>

<script>
  document.querySelectorAll(".edit-address-btn").forEach(function (btn) {
    btn.addEventListener("click", function () {
      const addressCard = this.closest(".address-card");
      const name = addressCard.querySelector("h3").textContent.trim();
      const addressText = addressCard.querySelector("p").textContent.trim();
      const parts = addressText.split(", ").map((part) => part.trim());

      const addressId = addressCard.dataset.addressId;
      const houseName = parts[0] || "";
      const street = parts[1] || "";
      const city = parts[2] || "";
      const district = parts[3] || "";
      const state = parts[4] || "";
      const pinCode = parts[5] || "";
      const isDefault = addressCard.querySelector(".default-address-tag") !== null;

      const modal = document.getElementById("editAddressModal");
      const nameInput = modal.querySelector("#name");
      const houseNameInput = modal.querySelector("#houseName");
      const streetInput = modal.querySelector("#street");
      const cityInput = modal.querySelector("#city");
      const districtInput = modal.querySelector("#district");
      const stateInput = modal.querySelector("#state");
      const pinCodeInput = modal.querySelector("#pinCode");
      const isDefaultCheckbox = modal.querySelector("#isDefault");

      // Set cleaned values
      nameInput.value = name;
      houseNameInput.value = houseName;
      streetInput.value = street;
      cityInput.value = city;
      districtInput.value = district;
      stateInput.value = state;
      pinCodeInput.value = pinCode;

      // Default checkbox logic
      if (isDefault) {
        isDefaultCheckbox.checked = true;
        isDefaultCheckbox.disabled = true; // Can't uncheck default
      } else {
        isDefaultCheckbox.checked = false;
        isDefaultCheckbox.disabled = false;
      }

      const saveButton = modal.querySelector("#saveEditedAddress");

      // Remove old listener to prevent duplicates
      const newSaveHandler = async function () {
        const formData = new FormData(modal.querySelector("#editAddressForm"));
        const addressData = Object.fromEntries(formData);
        addressData.addressId = addressId;
        addressData.isDefault = isDefaultCheckbox.checked;

        try {
          const response = await fetch(`/address/edit?addressId=${addressId}`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(addressData),
          });

          const data = await response.json();

          if (data.success) {
            Swal.fire({
              icon: "success",
              title: "Success",
              text: "Address updated successfully",
              timer: 1500,
              showConfirmButton: false,
            }).then(() => {
              location.reload();
            });
          } else {
            Swal.fire({
              icon: "error",
              title: "Error",
              text: data.message || "Failed to update address",
            });
          }
        } catch (error) {
          console.error("Update error:", error);
          Swal.fire({
            icon: "error",
            title: "Network Error",
            text: "Failed to update address. Please try again.",
          });
        }

        bootstrap.Modal.getInstance(modal).hide();
      };

      // Remove previous listeners and add new one
      saveButton.removeEventListener("click", saveButton._previousHandler);
      saveButton.addEventListener("click", newSaveHandler);
      saveButton._previousHandler = newSaveHandler;

      const bootstrapModal = new bootstrap.Modal(modal);
      bootstrapModal.show();
    });
  });
</script>
<script>
  document.querySelectorAll(".deliver-to-here-btn").forEach(function (btn) {
    btn.addEventListener("click", async function () {
      const addressId = this.dataset.addressId;
      const card = this.closest(".address-card");

      btn.disabled = true;
      btn.textContent = "Updating...";

      try {
        const res = await fetch("/set-default", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ addressId }),
        });

        const data = await res.json();

        if (data.success) {
          // Show SweetAlert FIRST, reload AFTER it finishes
          await Swal.fire({
            icon: "success",
            title: "Success",
            text: "Delivery address changed successfully!",
            timer: 1800, // Show for 1.8 seconds
            showConfirmButton: true,
            position: "top-end",
            toast: true,
          });
          location.reload();

          // Only reload after the alert is done
        } else {
          Swal.fire({
            icon: "error",
            title: "Error",
            text: data.message || "Could not change delivery address.",
          });
        }
      } catch (err) {
        console.error("Set default error:", err);
        Swal.fire({
          icon: "error",
          title: "Network Error",
          text: "Failed to update delivery address. Please try again.",
        });
      } finally {
        btn.disabled = false;
        btn.textContent = "Deliver Here";
      }
    });
  });
</script>
<script>
