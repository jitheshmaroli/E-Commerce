<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Offers · ShoeZone Admin</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdn.datatables.net/2.0.8/css/dataTables.bootstrap5.min.css"
    />
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/admin-shared.css" />
  </head>
  <body>
    <!-- ── Top bar ── -->
    <header class="admin-topbar">
      <a href="/admin" class="topbar-brand">
        <div class="topbar-brand-logo"><img src="/test.jpg" alt="Logo" /></div>
        <span class="topbar-brand-name">ShoeZone <em>Admin</em></span>
      </a>
      <div class="topbar-breadcrumb">
        <i class="fas fa-home"></i>
        <i class="fas fa-chevron-right"></i>
        <span>Offers</span>
      </div>
      <div class="topbar-right">
        <div class="topbar-admin-pill" id="adminPill">
          <div class="topbar-admin-avatar">A</div>
          <span class="topbar-admin-label">Admin</span>
          <i class="fas fa-chevron-down topbar-admin-chevron"></i>
          <div class="topbar-admin-dropdown">
            <a href="/admin/logout" class="topbar-dropdown-item"
              ><i class="fas fa-sign-out-alt"></i> Logout</a
            >
          </div>
        </div>
      </div>
    </header>

    <div class="admin-shell">
      <%- include('../../includes/adminSidebar.ejs', { activePage: 'offers' }) %>

      <main class="admin-main">
        <div class="admin-page-header">
          <div class="admin-page-header-left">
            <div class="admin-page-title">Offers</div>
            <div class="admin-page-subtitle">
              <%= offers ? offers.length : 0 %> offers configured
            </div>
          </div>
          <a href="/admin/offers/add-offer" class="btn-admin btn-admin-primary">
            <i class="fas fa-plus"></i> Add Offer
          </a>
        </div>

        <% if (offers && offers.length > 0) { %>
        <div class="admin-card">
          <div class="admin-card-body p-0">
            <div class="admin-table-wrap">
              <table id="offersTable" class="admin-table">
                <thead>
                  <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Discount</th>
                    <th>Apply To</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th class="text-center">Status</th>
                    <th class="text-center">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% offers.forEach(offer => { %>
                  <tr data-offer-id="<%= offer._id %>">
                    <td
                      style="
                        font-family: 'Bebas Neue', sans-serif;
                        font-size: 1rem;
                        letter-spacing: 0.04em;
                        font-weight: 400;
                      "
                    >
                      <%= offer.name %>
                    </td>
                    <td
                      style="
                        color: var(--grey-600);
                        max-width: 200px;
                        white-space: nowrap;
                        overflow: hidden;
                        text-overflow: ellipsis;
                      "
                    >
                      <%= offer.description %>
                    </td>
                    <td>
                      <span class="admin-badge badge-black">
                        <%= offer.discountType === 'percentage' ? offer.discountValue + '%' : '₹' +
                        offer.discountValue %>
                      </span>
                    </td>
                    <td>
                      <span class="admin-badge badge-grey">
                        <%= offer.offerType.charAt(0).toUpperCase() + offer.offerType.slice(1) %>
                      </span>
                    </td>
                    <td style="font-size: 0.8rem; color: var(--grey-600)">
                      <%= new Date(offer.startDate).toLocaleDateString('en-IN', { day: '2-digit',
                      month: 'short', year: 'numeric' }) %>
                    </td>
                    <td style="font-size: 0.8rem; color: var(--grey-600)">
                      <%= new Date(offer.endDate).toLocaleDateString('en-IN', { day: '2-digit',
                      month: 'short', year: 'numeric' }) %>
                    </td>
                    <td class="text-center">
                      <span class="admin-badge <%= offer.isActive ? 'badge-green' : 'badge-red' %>">
                        <%= offer.isActive ? 'Active' : 'Inactive' %>
                      </span>
                    </td>
                    <td class="text-center">
                      <div style="display: flex; gap: 0.4rem; justify-content: center">
                        <a
                          href="/admin/offers/edit/<%= offer._id %>"
                          class="btn-admin btn-admin-warning btn-admin-sm"
                          title="Edit"
                        >
                          <i class="fas fa-edit"></i>
                        </a>
                        <button
                          class="btn-admin btn-admin-danger btn-admin-sm delete-offer"
                          title="Delete"
                        >
                          <i class="fas fa-trash"></i>
                        </button>
                      </div>
                    </td>
                  </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <% } else { %>
        <div class="admin-card" style="text-align: center; padding: 4rem 2rem">
          <i
            class="fas fa-percentage"
            style="font-size: 3rem; color: var(--grey-200); margin-bottom: 1rem; display: block"
          ></i>
          <div
            style="
              font-family: 'Bebas Neue', sans-serif;
              font-size: 1.5rem;
              letter-spacing: 0.04em;
              margin-bottom: 0.5rem;
            "
          >
            No Offers Yet
          </div>
          <p style="color: var(--grey-400); font-size: 0.88rem; margin-bottom: 1.5rem">
            Click "Add Offer" to create your first offer.
          </p>
          <a href="/admin/offers/add-offer" class="btn-admin btn-admin-primary">
            <i class="fas fa-plus"></i> Add First Offer
          </a>
        </div>
        <% } %>
      </main>
    </div>

    <footer class="admin-footer">© 2024 ShoeZone Admin Panel. All rights reserved.</footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
      document.getElementById("adminPill")?.addEventListener("click", function (e) {
        e.stopPropagation();
        this.classList.toggle("open");
      });
      document.addEventListener("click", () =>
        document.getElementById("adminPill")?.classList.remove("open")
      );

      $(document).ready(function () {
        $("#offersTable").DataTable({
          responsive: true,
          pageLength: 10,
          lengthMenu: [5, 10, 25, 50],
          order: [[4, "desc"]],
          language: { search: "Search offers:", emptyTable: "No offers found" },
        });
      });

      document.querySelectorAll(".delete-offer").forEach((btn) => {
        btn.addEventListener("click", function () {
          const offerId = this.closest("tr").dataset.offerId;
          Swal.fire({
            title: "Delete Offer?",
            text: "This offer will be permanently deleted!",
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: "#dc2626",
            cancelButtonColor: "#9a9a96",
            confirmButtonText: "Yes, delete it!",
          }).then(async (result) => {
            if (result.isConfirmed) {
              try {
                const res = await fetch(`/admin/offers/delete/${offerId}`, { method: "POST" });
                const data = await res.json();
                if (data.success || res.ok) {
                  await Swal.fire({
                    icon: "success",
                    title: "Deleted!",
                    text: "Offer has been deleted.",
                    timer: 1200,
                    showConfirmButton: false,
                  });
                  location.reload();
                } else {
                  Swal.fire("Error!", data.message || "Failed to delete offer.", "error");
                }
              } catch {
                Swal.fire("Error!", "Network error occurred.", "error");
              }
            }
          });
        });
      });
    </script>
  </body>
</html>
