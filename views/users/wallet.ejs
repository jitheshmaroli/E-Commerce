<%- include('../includes/userHead.ejs') %>
<link rel="stylesheet" href="/css/profile-shared.css" />
<%- include('../includes/userHeader.ejs') %>

<% if (user) { %>
<div class="account-shell">
  <%- include('../includes/accountNav.ejs', { activePage: 'wallet' }) %>

  <div class="account-content">
    <!-- Balance Card -->
    <div class="wallet-balance-card">
      <i class="fas fa-wallet wallet-icon-bg"></i>
      <div class="wallet-balance-label">Available Balance</div>
      <div class="wallet-balance-amount">₹<%= user.wallet.toFixed(2) %></div>
      <div class="wallet-balance-sub">
        ShoeZone Wallet &middot; Credited on refunds &amp; returns
      </div>
    </div>

    <!-- Transactions -->
    <div class="transactions-card">
      <div class="transactions-card-header">
        <div class="account-card-icon"><i class="fas fa-list-alt"></i></div>
        <h3>Transaction History</h3>
      </div>

      <% if (user.walletTransactions && user.walletTransactions.length > 0) { %>
      <div style="overflow-x: auto">
        <table class="txn-table">
          <thead>
            <tr>
              <th>Date</th>
              <th>Description</th>
              <th>Amount</th>
              <th>Type</th>
            </tr>
          </thead>
          <tbody>
            <% user.walletTransactions.slice().reverse().forEach(function(txn) { %>
            <tr>
              <td style="white-space: nowrap; color: var(--grey-600); font-size: 0.8rem">
                <i class="far fa-calendar-alt me-1"></i>
                <%= txn.createdAt.toLocaleDateString('en-IN', {day:'numeric',month:'short',year:'numeric'}) %>
              </td>
              <td><%= txn.description %></td>
              <td class="<%= txn.type === 'credit' ? 'txn-amount-credit' : 'txn-amount-debit' %>">
                <%= txn.type === 'credit' ? '+' : '-' %><%- '&#8377;' %><%= txn.amount.toFixed(2) %>
              </td>
              <td>
                <span
                  class="txn-type-pill <%= txn.type === 'credit' ? 'txn-credit' : 'txn-debit' %>"
                >
                  <i class="fas <%= txn.type === 'credit' ? 'fa-arrow-down' : 'fa-arrow-up' %>"></i>
                  <%= txn.type.charAt(0).toUpperCase() + txn.type.slice(1) %>
                </span>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <!-- Pagination -->
      <% if (totalPages && totalPages > 1) { %>
      <style>
        .wallet-pagination {
          padding: 1.5rem 2rem;
          border-top: 1px solid var(--grey-100);
          display: flex;
          align-items: center;
          gap: 1rem;
          flex-wrap: wrap;
        }
        .wallet-pagination-nav {
          display: flex;
          gap: 0.4rem;
          flex-wrap: wrap;
          align-items: center;
          flex: 1;
          justify-content: center;
        }
        .wallet-page-link {
          width: 36px;
          height: 36px;
          display: inline-flex;
          align-items: center;
          justify-content: center;
          border-radius: 50%;
          border: 1.5px solid var(--grey-100);
          color: var(--black);
          background: var(--off-white);
          font-size: 0.82rem;
          font-weight: 600;
          transition: all var(--transition);
          text-decoration: none;
        }
        .wallet-page-link:hover {
          background: var(--black);
          color: var(--white);
          border-color: var(--black);
        }
        .wallet-page-link.active {
          background: var(--black) !important;
          color: var(--white) !important;
          border-color: var(--black) !important;
        }
        .wallet-page-prev,
        .wallet-page-next {
          display: inline-flex;
          align-items: center;
          gap: 0.4rem;
          padding: 0.6rem 1.1rem;
          background: var(--off-white);
          color: var(--black);
          border: 1.5px solid var(--grey-100);
          border-radius: var(--radius-sm);
          font-size: 0.78rem;
          font-weight: 700;
          text-decoration: none;
          transition: all var(--transition);
        }
        .wallet-page-prev:hover,
        .wallet-page-next:hover {
          background: var(--black);
          color: var(--white);
          border-color: var(--black);
        }
        .wallet-page-prev:disabled,
        .wallet-page-next:disabled {
          opacity: 0.4;
          cursor: not-allowed;
          pointer-events: none;
        }
        .pagination-ellipsis {
          color: var(--grey-400);
          padding: 0 0.4rem;
        }
        .pagination-info {
          font-size: 0.78rem;
          color: var(--grey-400);
          text-align: center;
          margin-top: 1rem;
          padding: 0 2rem;
        }
      </style>

      <div class="wallet-pagination">
        <!-- Previous button -->
        <% if (currentPage > 1) { %>
        <a href="/wallet?page=<%= currentPage - 1 %>" class="wallet-page-prev">
          <i class="fas fa-chevron-left"></i> Previous
        </a>
        <% } else { %>
        <button class="wallet-page-prev" disabled>
          <i class="fas fa-chevron-left"></i> Previous
        </button>
        <% } %>

        <div class="wallet-pagination-nav">
          <% let startPage = Math.max(1, currentPage - 2); let endPage = Math.min(totalPages,
          currentPage + 2); %>

          <% if (startPage > 1) { %>
          <a href="/wallet?page=1" class="wallet-page-link">1</a>
          <% if (startPage > 2) { %>
          <span class="pagination-ellipsis">...</span>
          <% } %>
          <% } %>

          <% for (let i = startPage; i <= endPage; i++) { %>
          <a
            href="/wallet?page=<%= i %>"
            class="wallet-page-link <%= i === currentPage ? 'active' : '' %>"
          >
            <%= i %>
          </a>
          <% } %>

          <% if (endPage < totalPages) { %>
          <% if (endPage < totalPages - 1) { %>
          <span class="pagination-ellipsis">...</span>
          <% } %>
          <a href="/wallet?page=<%= totalPages %>" class="wallet-page-link"><%= totalPages %></a>
          <% } %>
        </div>

        <% if (currentPage < totalPages) { %>
        <a href="/wallet?page=<%= currentPage + 1 %>" class="wallet-page-next">
          Next <i class="fas fa-chevron-right"></i>
        </a>
        <% } else { %>
        <button class="wallet-page-next" disabled>Next <i class="fas fa-chevron-right"></i></button>
        <% } %>
      </div>

      <div class="pagination-info">
        Showing page <strong><%= currentPage %></strong> of
        <strong><%= totalPages %></strong> (<%= totalTransactions %>
        total transactions)
      </div>
      <% } %>

      <% } else { %>
      <div class="wallet-empty">
        <i class="fas fa-receipt"></i>
        <p>No transactions yet. Your wallet activity will appear here.</p>
      </div>
      <% } %>
    </div>
  </div>
</div>
<% } %>

<%- include('../includes/userFooter.ejs') %>
<%- include('../includes/userScripts.ejs') %>

<script>
  function setCategory(c) {
    var el = document.getElementById("selectedCategory");
    if (el) el.value = c;
    var dt = document.querySelector(".dropdown-toggle-text");
    if (dt) dt.textContent = c.charAt(0).toUpperCase() + c.slice(1);
  }
</script>
