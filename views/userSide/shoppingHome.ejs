<%- include('../includes/userHead.ejs') %>
<link rel="stylesheet" href="/css/shoppingHome.css" />
<%- include('../includes/userHeader.ejs') %>
<!-- Hero section -->
<section class="hero-section text-dark py-5" style="background-color: var(--grey-050)">
  <div class="container py-5">
    <div class="row align-items-center">
      <div class="col-lg-6 mb-4 mb-lg-0">
        <p class="text-uppercase fw-bold text-primary mb-2">New Season | Unmatched Comfort</p>
        <h1 class="display-3 fw-bolder mb-3">
          **Step Into <span class="text-primary">Your Next Level</span>**
        </h1>
        <p class="lead mb-4 text-dark-50">
          Explore the latest collection of premium, performance-driven footwear. Style meets
          ultimate comfort.
        </p>
        <a
          href="/products?sortby=newArrivals"
          class="btn btn-dark btn-lg me-3 px-5 rounded-pill shadow-lg"
        >
          Shop New Arrivals
        </a>
      </div>
      <div class="col-lg-6 text-center">
        <img
          src="/banner-shoes.png"
          alt="A pair of stylish, modern athletic shoes for running and training"
          class="img-fluid rounded-4 shadow-xl hero-main-img"
        />
      </div>
    </div>
  </div>
</section>
<!-- Featured Sections -->
<div class="featured-sections py-5">
  <!-- Most Selling Products -->
  <section class="featured-section section-rail mb-5">
    <div class="container">
      <div class="section-header d-flex justify-content-between align-items-center mb-4">
        <h2 class="h3 fw-bold">Most Selling Products</h2>
        <a href="/products" class="text-decoration-none fw-medium text-dark">View All →</a>
      </div>
      <div class="products-slider-container position-relative">
        <button
          class="rail-prev-btn position-absolute top-50 start-0 translate-middle-y me-3 bg-white rounded-circle shadow-sm border-0 p-2"
          type="button"
          data-target="most-selling-rail"
        >
          <i class="fas fa-chevron-left text-dark"></i>
        </button>
        <div class="products-row d-flex gap-3 rail-scroll" id="most-selling-rail">
          <% const mostSelling = (products || []).slice().sort((a,b) => (b.totalSold||0) -
          (a.totalSold||0)).slice(0,6) %> <% mostSelling.forEach(product => { %>
          <div class="product-slide flex-shrink-0 h-100" style="width: 220px">
            <div
              class="product-card glass-card h-100 shadow-sm border-0 rounded-3 overflow-hidden modern-product-card <%= product.stock === 0 ? 'opacity-50' : '' %>"
              data-product="<%= product._id %>"
              data-stock="<%= product.stock %>"
            >
              <div
                class="product-image-container position-relative overflow-hidden"
                style="height: 180px"
              >
                <a href="/product-details/<%= product._id %>">
                  <img
                    src="/uploads/<%= product.photos[0].filename %>"
                    alt="<%= product.name %>"
                    class="product-image w-100 h-100 object-fit-cover"
                  />
                </a>
                <div
                  class="category-badge position-absolute top-2 start-2 bg-black text-white px-2 py-1 rounded-pill small fw-bold"
                >
                  Top
                </div>
                <button
                  class="wishlist-btn position-absolute top-2 end-2 p-0 border-0 bg-white rounded-circle d-flex align-items-center justify-content-center"
                  onclick="toggleWishlist(this)"
                  style="width: 32px; height: 32px; box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1)"
                >
                  <% const isInWishlist = wishlistProducts.find(item => item._id.toString() ===
                  product._id.toString()); %>
                  <i
                    class="fa fa-heart <%= isInWishlist ? 'text-danger fas' : 'text-muted far' %> fs-6"
                  ></i>
                </button>
                <div
                  class="out-of-stock-overlay position-absolute top-0 start-0 end-0 bottom-0 bg-dark bg-opacity-70 d-flex align-items-center justify-content-center <%= product.stock === 0 ? 'd-flex' : 'd-none' %>"
                >
                  <div
                    class="out-of-stock-text bg-white text-black px-3 py-2 rounded-pill fw-bold small"
                  >
                    Out of Stock
                  </div>
                </div>
              </div>
              <div class="product-details p-2 d-flex flex-column flex-grow-1">
                <div class="flex-grow-1">
                  <h3 class="product-name small fw-medium mb-1"><%= product.name %></h3>
                  <div class="rating-container d-flex align-items-center gap-1 mb-1">
                    <div class="stars small">
                      <% for (let i = 1; i <= 5; i++) { %>
                      <i
                        class="fa<%= i <= product.averageRating ? 's' : 'r' %> fa-star text-warning"
                      ></i>
                      <% } %>
                    </div>
                  </div>
                  <div class="price-container mb-2">
                    <% if (product.offer && product.price !== product.currentPrice) { %>
                    <div class="price-row d-flex align-items-center gap-1 mb-1">
                      <span class="original-price small text-muted text-decoration-line-through"
                        >₹<%= product.price.toFixed(2) %></span
                      >
                      <span class="offer-price fw-bold"
                        >₹<%= product.currentPrice.toFixed(2) %></span
                      >
                    </div>
                    <% if (product.offer) { %>
                    <div class="offer-info bg-black text-white px-2 py-1 rounded small">
                      🎉 <%= product.offer.name || 'Special Offer' %> - Save <%=
                      Math.round(((product.price - product.currentPrice) / product.price) * 100)
                      %>%!
                    </div>
                    <% } %>
                    <% } else { %>
                    <div class="price-row d-flex align-items-center gap-1 mb-1">
                      <span class="regular-price fw-bold">₹<%= product.price.toFixed(2) %></span>
                    </div>
                    <% } %>
                  </div>
                </div>
                <div class="button-group d-flex gap-1">
                  <button
                    class="btn-add-cart flex-fill btn btn-outline-dark btn-sm p-1 fw-bold text-uppercase small"
                    data-product-id="<%= product._id %>"
                  >
                    <i class="fas fa-shopping-cart me-1"></i>Add to Cart
                  </button>
                  <a
                    href="/checkout/<%= product._id %>/1"
                    class="btn-buy-now flex-fill btn btn-dark btn-sm p-1 fw-bold text-uppercase small"
                    >Buy Now
                  </a>
                </div>
              </div>
            </div>
          </div>
          <% }) %>
        </div>
        <button
          class="rail-next-btn position-absolute top-50 end-0 translate-middle-y ms-3 bg-white rounded-circle shadow-sm border-0 p-2"
          type="button"
          data-target="most-selling-rail"
        >
          <i class="fas fa-chevron-right text-dark"></i>
        </button>
      </div>
    </div>
  </section>
  <!-- Latest Arrivals -->
  <section class="featured-section section-rail">
    <div class="container">
      <div class="section-header d-flex justify-content-between align-items-center mb-4">
        <h2 class="h3 fw-bold">Latest Arrivals</h2>
        <a href="/products?sortby=newArrivals" class="text-decoration-none fw-medium text-dark"
          >View All →</a
        >
      </div>
      <div class="products-slider-container position-relative">
        <button
          class="rail-prev-btn position-absolute top-50 start-0 translate-middle-y me-3 bg-white rounded-circle shadow-sm border-0 p-2"
          type="button"
          data-target="latest-rail"
        >
          <i class="fas fa-chevron-left text-dark"></i>
        </button>
        <div class="products-row d-flex gap-3 rail-scroll" id="latest-rail">
          <% const latestProducts = (products || []).slice().sort((a,b) => new Date(b.createdAt||0)
          - new Date(a.createdAt||0)).slice(0,6) %> <% latestProducts.forEach(product => { %>
          <div class="product-slide flex-shrink-0 h-100" style="width: 220px">
            <div
              class="product-card glass-card h-100 shadow-sm border-0 rounded-3 overflow-hidden modern-product-card <%= product.stock === 0 ? 'opacity-50' : '' %>"
              data-product="<%= product._id %>"
            >
              <div
                class="product-image-container position-relative overflow-hidden"
                style="height: 180px"
              >
                <a href="/product-details/<%= product._id %>">
                  <img
                    src="/uploads/<%= product.photos[0].filename %>"
                    alt="<%= product.name %>"
                    class="product-image w-100 h-100 object-fit-cover"
                  />
                </a>
                <div
                  class="category-badge position-absolute top-2 start-2 bg-black text-white px-2 py-1 rounded-pill small fw-bold"
                >
                  <%= product.category.categoryName %>
                </div>
                <button
                  class="wishlist-btn position-absolute top-2 end-2 p-0 border-0 bg-white rounded-circle d-flex align-items-center justify-content-center"
                  onclick="toggleWishlist(this)"
                  style="width: 32px; height: 32px; box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1)"
                >
                  <% const isInWishlist = wishlistProducts.find(item => item._id.toString() ===
                  product._id.toString()); %>
                  <i
                    class="fa fa-heart <%= isInWishlist ? 'text-danger fas' : 'text-muted far' %> fs-6"
                  ></i>
                </button>
                <div
                  class="out-of-stock-overlay position-absolute top-0 start-0 end-0 bottom-0 bg-dark bg-opacity-70 d-flex align-items-center justify-content-center <%= product.stock === 0 ? 'd-flex' : 'd-none' %>"
                >
                  <div
                    class="out-of-stock-text bg-white text-black px-3 py-2 rounded-pill fw-bold small"
                  >
                    Out of Stock
                  </div>
                </div>
              </div>
              <div class="product-details p-2 d-flex flex-column flex-grow-1">
                <div class="flex-grow-1">
                  <h3 class="product-name small fw-medium mb-1"><%= product.name %></h3>
                  <div class="rating-container d-flex align-items-center gap-1 mb-1">
                    <div class="stars small">
                      <% for (let i = 1; i <= 5; i++) { %>
                      <i
                        class="fa<%= i <= product.averageRating ? 's' : 'r' %> fa-star text-warning"
                      ></i>
                      <% } %>
                    </div>
                  </div>
                  <div class="price-container mb-2">
                    <% if (product.offer && product.price !== product.currentPrice) { %>
                    <div class="price-row d-flex align-items-center gap-1 mb-1">
                      <span class="original-price small text-muted text-decoration-line-through"
                        >₹<%= product.price.toFixed(2) %>
                      </span>
                      <span class="offer-price fw-bold"
                        >₹<%= product.currentPrice.toFixed(2) %></span
                      >
                    </div>
                    <% if (product.offer) { %>
                    <div class="offer-info bg-black text-white px-2 py-1 rounded small">
                      🎉 <%= product.offer.name || 'Special Offer' %> - Save <%=
                      Math.round(((product.price - product.currentPrice) / product.price) * 100)
                      %>%!
                    </div>
                    <% } %>
                    <% } else { %>
                    <div class="price-row d-flex align-items-center gap-1 mb-1">
                      <span class="regular-price fw-bold">₹<%= product.price.toFixed(2) %></span>
                    </div>
                    <% } %>
                  </div>
                </div>
                <div class="button-group d-flex gap-1">
                  <button
                    class="btn-add-cart flex-fill btn btn-outline-dark btn-sm p-1 fw-bold text-uppercase small"
                    data-product-id="<%= product._id %>"
                  >
                    <i class="fas fa-shopping-cart me-1"></i>Add to Cart
                  </button>
                  <a
                    href="/checkout/<%= product._id %>/1"
                    class="btn-buy-now flex-fill btn btn-dark btn-sm p-1 fw-bold text-uppercase small"
                    >Buy Now
                  </a>
                </div>
              </div>
            </div>
          </div>
          <% }) %>
        </div>
        <button
          class="rail-next-btn position-absolute top-50 end-0 translate-middle-y ms-3 bg-white rounded-circle shadow-sm border-0 p-2"
          type="button"
          data-target="latest-rail"
        >
          <i class="fas fa-chevron-right text-dark"></i>
        </button>
      </div>
    </div>
  </section>
</div>
<section class="py-5">
  <div class="container">
    <div class="glass-card p-5 rounded-4 text-center glow-shadow">
      <h2 class="fw-bold mb-3">Start Shopping</h2>
      <p class="text-muted-600 mb-4">Browse all products and find your style.</p>
      <a href="/products" class="btn btn-dark btn-lg px-5 rounded-pill">View All Products</a>
    </div>
  </div>
</section>
<%- include('../includes/userFooter.ejs') %>
<%- include('../includes/userScripts.ejs') %>
<script>
  // Add to Cart
  document.querySelectorAll(".btn-add-cart").forEach((btn) => {
    btn.addEventListener("click", async (e) => {
      e.preventDefault();
      const productId = btn.dataset.productId;
      const productName = btn
        .closest(".product-card")
        .querySelector(".product-name")
        .textContent.trim();
      const card = btn.closest(".product-card");
      const stock = Number(card.dataset.stock);
      if (stock <= 0) {
        Swal.fire("Out of Stock!", "This product is unavailable.", "warning");
        return;
      }
      try {
        const res = await fetch("/add-to-cart", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ productId, quantity: 1 }),
        });

        if (res.status === 401) {
          window.location.href = `/login?redirect=/product-details/${productId}`;
          return;
        }
        const data = await res.json();
        if (!res.ok) {
          Swal.fire("Error", data.message || "Something went wrong", "error");
          return;
        }
        Swal.fire("Added!", `${productName} added to cart!`, "success");
      } catch (err) {
        console.error(err);
      }
    });
  });
  // Wishlist Toggle
  function toggleWishlist(btn) {
    const icon = btn.querySelector("i");
    const productId = btn.closest(".product-card").dataset.product;
    fetch("/toggle-wishlist", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ productId }),
    })
      .then((res) => res.json())
      .then((data) => {
        if (data.success) {
          if (data.isInWishlist) {
            icon.className = "fa fa-heart text-danger fas fs-6";
          } else {
            icon.className = "fa fa-heart text-muted far fs-6";
          }
        } else {
          Swal.fire("Error!", data.message, "error");
        }
      })
      .catch((err) => console.error(err));
  }
  // Rail Navigation with Arrows
  document.querySelectorAll(".rail-prev-btn, .rail-next-btn").forEach((btn) => {
    btn.addEventListener("click", (e) => {
      e.preventDefault();
      const targetId = btn.dataset.target;
      const row = document.getElementById(targetId);
      const slideWidth = row.children[0].offsetWidth + 12;
      if (btn.classList.contains("rail-prev-btn")) {
        row.scrollLeft -= slideWidth * 3;
      } else {
        row.scrollLeft += slideWidth * 3;
      }
    });
  });
  //  Drag-to-scroll rails (mouse/touch)
  document.querySelectorAll(".products-row.rail-scroll").forEach((row) => {
    let isDown = false;
    let startX = 0;
    let scrollLeft = 0;
    const onDown = (e) => {
      isDown = true;
      startX = (e.touches ? e.touches[0].pageX : e.pageX) - row.offsetLeft;
      scrollLeft = row.scrollLeft;
    };
    const onMove = (e) => {
      if (!isDown) return;
      e.preventDefault();
      const x = (e.touches ? e.touches[0].pageX : e.pageX) - row.offsetLeft;
      const walk = x - startX;
      row.scrollLeft = scrollLeft - walk;
    };
    const onUp = () => {
      isDown = false;
    };
    row.addEventListener("mousedown", onDown);
    row.addEventListener("mousemove", onMove);
    row.addEventListener("mouseleave", onUp);
    row.addEventListener("mouseup", onUp);
    row.addEventListener("touchstart", onDown, { passive: true });
    row.addEventListener("touchmove", onMove, { passive: false });
    row.addEventListener("touchend", onUp);
    // Shift+wheel for horizontal scroll
    row.addEventListener(
      "wheel",
      (e) => {
        if (Math.abs(e.deltaY) > Math.abs(e.deltaX)) {
          row.scrollBy({ left: e.deltaY, behavior: "auto" });
        }
      },
      { passive: true }
    );
  });
</script>
