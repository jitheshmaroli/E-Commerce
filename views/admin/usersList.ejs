<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Users List · ShoeZone Admin</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdn.datatables.net/2.0.8/css/dataTables.bootstrap5.min.css"
    />
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/admin-shared.css" />
  </head>
  <body>
    <!-- ── Top bar ── -->
    <header class="admin-topbar">
      <a href="/admin" class="topbar-brand">
        <div class="topbar-brand-logo"><img src="/test.jpg" alt="Logo" /></div>
        <span class="topbar-brand-name">ShoeZone <em>Admin</em></span>
      </a>
      <div class="topbar-breadcrumb">
        <i class="fas fa-home"></i>
        <i class="fas fa-chevron-right"></i>
        <span>Users</span>
      </div>
      <div class="topbar-right">
        <div class="topbar-admin-pill" id="adminPill">
          <div class="topbar-admin-avatar">A</div>
          <span class="topbar-admin-label">Admin</span>
          <i class="fas fa-chevron-down topbar-admin-chevron"></i>
          <div class="topbar-admin-dropdown">
            <a href="/admin/logout" class="topbar-dropdown-item"
              ><i class="fas fa-sign-out-alt"></i> Logout</a
            >
          </div>
        </div>
      </div>
    </header>

    <div class="admin-shell">
      <%- include('../includes/adminSidebar.ejs', { activePage: 'users' }) %>

      <main class="admin-main">
        <div class="admin-page-header">
          <div class="admin-page-header-left">
            <div class="admin-page-title">Users List</div>
            <div class="admin-page-subtitle"><%= users ? users.length : 0 %> registered users</div>
          </div>
        </div>

        <% if (users && users.length > 0) { %>
        <div class="admin-card">
          <div class="admin-card-body p-0">
            <div class="admin-table-wrap">
              <table id="usersTable" class="admin-table">
                <thead>
                  <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th class="text-center">Status</th>
                    <th class="text-center">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% users.forEach(user => { %>
                  <tr data-user-email="<%= user.email %>">
                    <td style="font-weight: 700"><%= user.name || '—' %></td>
                    <td style="color: var(--grey-600)"><%= user.email %></td>
                    <td class="text-center">
                      <span
                        id="status-<%= user.email %>"
                        class="admin-badge <%= user.isBlocked ? 'badge-red' : 'badge-green' %>"
                      >
                        <%= user.isBlocked ? 'BLOCKED' : 'ACTIVE' %>
                      </span>
                    </td>
                    <td class="text-center">
                      <button
                        class="btn-admin btn-admin-sm toggle-block-btn <%= user.isBlocked ? 'btn-admin-primary' : 'btn-admin-danger' %>"
                        data-email="<%= user.email %>"
                        data-blocked="<%= user.isBlocked %>"
                        title="<%= user.isBlocked ? 'Unblock' : 'Block' %>"
                      >
                        <%= user.isBlocked ? 'UNBLOCK' : 'BLOCK' %>
                      </button>
                    </td>
                  </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <% } else { %>
        <div class="admin-card" style="text-align: center; padding: 4rem 2rem">
          <i
            class="fas fa-users"
            style="font-size: 3rem; color: var(--grey-200); margin-bottom: 1rem; display: block"
          ></i>
          <div
            style="
              font-family: 'Bebas Neue', sans-serif;
              font-size: 1.5rem;
              letter-spacing: 0.04em;
              margin-bottom: 0.5rem;
            "
          >
            No Users Found
          </div>
          <p style="color: var(--grey-400); font-size: 0.88rem">No regular users registered yet.</p>
        </div>
        <% } %>
      </main>
    </div>

    <footer class="admin-footer">© 2024 ShoeZone Admin Panel. All rights reserved.</footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
      document.getElementById("adminPill")?.addEventListener("click", function (e) {
        e.stopPropagation();
        this.classList.toggle("open");
      });
      document.addEventListener("click", () =>
        document.getElementById("adminPill")?.classList.remove("open")
      );

      $(document).ready(function () {
        $("#usersTable").DataTable({
          responsive: true,
          pageLength: 10,
          lengthMenu: [5, 10, 25, 50],
          order: [[0, "asc"]],
          language: {
            search: "Search users:",
            emptyTable: "No users found",
          },
        });
      });

      // Toggle Block/Unblock with SweetAlert
      document.querySelectorAll(".toggle-block-btn").forEach((btn) => {
        btn.addEventListener("click", async function () {
          const userEmail = this.dataset.email;
          const isBlocked = this.dataset.blocked === "true";
          const action = isBlocked ? "unblock" : "block";

          const result = await Swal.fire({
            title: `Are you sure?`,
            text: `This will ${action} the user!`,
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: isBlocked ? "#28a745" : "#d33",
            cancelButtonColor: "#6c757d",
            confirmButtonText: `Yes, ${action.toUpperCase()}!`,
          });

          if (result.isConfirmed) {
            try {
              const res = await fetch(`/admin/usersList/${userEmail}`, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
              });

              const data = await res.json();

              if (data.message && data.user) {
                const statusBadge = document.getElementById(`status-${userEmail}`);
                const toggleBtn = this;

                if (data.user.isBlocked) {
                  statusBadge.textContent = "BLOCKED";
                  statusBadge.className = "admin-badge badge-red";
                  toggleBtn.textContent = "UNBLOCK";
                  toggleBtn.classList.remove("btn-admin-danger");
                  toggleBtn.classList.add("btn-admin-primary");
                  toggleBtn.dataset.blocked = "true";
                } else {
                  statusBadge.textContent = "ACTIVE";
                  statusBadge.className = "admin-badge badge-green";
                  toggleBtn.textContent = "BLOCK";
                  toggleBtn.classList.remove("btn-admin-primary");
                  toggleBtn.classList.add("btn-admin-danger");
                  toggleBtn.dataset.blocked = "false";
                }

                Swal.fire({
                  icon: "success",
                  title: "Updated!",
                  text: `User ${data.user.isBlocked ? "blocked" : "unblocked"} successfully.`,
                  timer: 1800,
                  showConfirmButton: false,
                });
              } else {
                Swal.fire("Error!", data.error || "Failed to update user status.", "error");
              }
            } catch (err) {
              console.error("Toggle error:", err);
              Swal.fire("Error!", "Network error occurred.", "error");
            }
          }
        });
      });
    </script>
  </body>
</html>
