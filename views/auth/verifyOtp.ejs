<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Verify OTP - ShoeZone</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
    />
    <link rel="stylesheet" href="/css/auth-shared.css" />
  </head>
  <body>
    <header class="header">
      <div class="brand">
        <a class="navbar-brand nav-link" style="color: aliceblue" href="/">
          <img src="/test.jpg" alt="Brand Logo" />
          <span class="brand-name">ShoeZone</span>
        </a>
      </div>
    </header>

    <div class="container d-flex align-items-center justify-content-center min-vh-100">
      <div class="form-container card shadow">
        <div class="card-body p-4">
          <h3 class="text-center mb-4">Verify Your Email</h3>

          <div id="otpInfoAlert" class="alert alert-info text-center mb-4" role="alert">
            OTP sent to <strong><%= maskedEmail %></strong>
          </div>

          <% if (message) { %>
          <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <%= message %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
          <% } %>

          <form
            action="/verify-otp"
            method="POST"
            id="otpForm"
            data-remaining-time="<%= remainingTime || 60 %>"
          >
            <div class="mb-4 position-relative">
              <label class="form-label text-center d-block fw-bold mb-3"> Enter 6-digit OTP </label>

              <div class="d-flex justify-content-center gap-3">
                <input
                  type="password"
                  class="otp-box"
                  maxlength="1"
                  data-index="0"
                  inputmode="numeric"
                  pattern="[0-9]*"
                  required
                  autofocus
                />
                <input
                  type="password"
                  class="otp-box"
                  maxlength="1"
                  data-index="1"
                  inputmode="numeric"
                  pattern="[0-9]*"
                  required
                />
                <input
                  type="password"
                  class="otp-box"
                  maxlength="1"
                  data-index="2"
                  inputmode="numeric"
                  pattern="[0-9]*"
                  required
                />
                <input
                  type="password"
                  class="otp-box"
                  maxlength="1"
                  data-index="3"
                  inputmode="numeric"
                  pattern="[0-9]*"
                  required
                />
                <input
                  type="password"
                  class="otp-box"
                  maxlength="1"
                  data-index="4"
                  inputmode="numeric"
                  pattern="[0-9]*"
                  required
                />
                <input
                  type="password"
                  class="otp-box"
                  maxlength="1"
                  data-index="5"
                  inputmode="numeric"
                  pattern="[0-9]*"
                  required
                />
              </div>

              <input type="hidden" name="otp" id="hiddenOtp" required />
              <div id="otpError" class="text-danger text-center mt-2 small"></div>
            </div>

            <button type="submit" id="submitBtn" class="btn btn-dark w-100 py-2" disabled>
              Verify OTP
            </button>
          </form>

          <div class="d-flex justify-content-between align-items-center mt-4">
            <p id="timer" class="text-muted mb-0"></p>
            <button type="button" id="resendBtn" class="btn btn-outline-dark btn-sm" disabled>
              Resend OTP
            </button>
          </div>
        </div>
      </div>
    </div>

    <footer class="footer">
      <p class="copyright">© 2026 ShoeZone</p>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      const form = document.getElementById("otpForm");
      const timeLeftInitial = parseInt(form.dataset.remainingTime) || 60;

      const otpBoxes = document.querySelectorAll(".otp-box");
      const hiddenOtp = document.getElementById("hiddenOtp");
      const submitBtn = document.getElementById("submitBtn");
      const otpError = document.getElementById("otpError");
      const resendBtn = document.getElementById("resendBtn");
      const timerEl = document.getElementById("timer");
      const otpInfoAlert = document.getElementById("otpInfoAlert");

      let timeLeft = timeLeftInitial;
      let timerId = null;

      function updateHidden() {
        hiddenOtp.value = Array.from(otpBoxes)
          .map((box) => box.value)
          .join("");
      }

      otpBoxes.forEach((box, i) => {
        box.addEventListener("input", (e) => {
          const val = e.target.value.replace(/\D/, "");
          box.value = val;
          if (val && i < 5) otpBoxes[i + 1].focus();
          updateHidden();
          validate();
        });

        box.addEventListener("keydown", (e) => {
          if (e.key === "Backspace" && !box.value && i > 0) {
            otpBoxes[i - 1].focus();
          }
        });

        box.addEventListener("paste", (e) => {
          e.preventDefault();
          const text = (e.clipboardData || window.clipboardData).getData("text").replace(/\D/g, "");
          if (text) {
            text
              .split("")
              .slice(0, 6 - i)
              .forEach((d, idx) => {
                if (otpBoxes[i + idx]) otpBoxes[i + idx].value = d;
              });
            const next = Math.min(i + text.length, 5);
            otpBoxes[next]?.focus();
            updateHidden();
            validate();
          }
        });
      });

      function validate() {
        const isComplete = hiddenOtp.value.length === 6;
        otpError.textContent = isComplete
          ? ""
          : hiddenOtp.value.length > 0
          ? "Enter complete 6-digit OTP"
          : "";
        submitBtn.disabled = !isComplete;
      }

      function startTimer() {
        if (timeLeft <= 0) {
          resendBtn.disabled = false;
          timerEl.textContent = "";
          return;
        }

        resendBtn.disabled = true;
        timerEl.textContent = `Resend available in ${timeLeft}s`;

        timerId = setInterval(() => {
          timeLeft--;
          timerEl.textContent = `Resend available in ${timeLeft}s`;
          if (timeLeft <= 0) {
            clearInterval(timerId);
            timerEl.textContent = "";
            resendBtn.disabled = false;
          }
        }, 1000);
      }

      resendBtn.addEventListener("click", async () => {
        resendBtn.disabled = true;
        timeLeft = 60;
        startTimer();

        try {
          const email = "<%= userData.email %>";
          const res = await fetch("/resend-otp", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ email }),
          });

          const data = await res.json();

          if (data.success) {
            const maskedEmail = "<%= maskedEmail %>";
            otpInfoAlert.textContent = `New OTP has been sent to ${maskedEmail}`;
            otpInfoAlert.classList.remove("alert-danger");
            otpInfoAlert.classList.add("alert-success");
          } else {
            otpInfoAlert.textContent = data.message || "Failed to resend OTP";
            otpInfoAlert.classList.remove("alert-success");
            otpInfoAlert.classList.add("alert-danger");
            timeLeft = 0; // stop timer
            clearInterval(timerId);
            startTimer();
          }
        } catch (err) {
          otpInfoAlert.textContent = "Network error. Please try again.";
          otpInfoAlert.classList.add("alert-danger");
          timeLeft = 0;
          clearInterval(timerId);
          startTimer();
        }
      });

      // Start on load
      startTimer();
      validate();

      // Optional: focus first box
      otpBoxes[0]?.focus();
    </script>
  </body>
</html>
