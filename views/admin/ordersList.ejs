<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Orders List · ShoeZone Admin</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdn.datatables.net/2.0.8/css/dataTables.bootstrap5.min.css"
    />
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/admin-shared.css" />
  </head>
  <body>
    <!-- ── Top bar ── -->
    <header class="admin-topbar">
      <a href="/admin" class="topbar-brand">
        <div class="topbar-brand-logo"><img src="/test.jpg" alt="Logo" /></div>
        <span class="topbar-brand-name">ShoeZone <em>Admin</em></span>
      </a>
      <div class="topbar-breadcrumb">
        <i class="fas fa-home"></i>
        <i class="fas fa-chevron-right"></i>
        <span>Orders</span>
      </div>
      <div class="topbar-right">
        <div class="topbar-admin-pill" id="adminPill">
          <div class="topbar-admin-avatar">A</div>
          <span class="topbar-admin-label">Admin</span>
          <i class="fas fa-chevron-down topbar-admin-chevron"></i>
          <div class="topbar-admin-dropdown">
            <a href="/admin/logout" class="topbar-dropdown-item"
              ><i class="fas fa-sign-out-alt"></i> Logout</a
            >
          </div>
        </div>
      </div>
    </header>

    <div class="admin-shell">
      <%- include('../includes/adminSidebar.ejs', { activePage: 'orders' }) %>

      <main class="admin-main">
        <div class="admin-page-header">
          <div class="admin-page-header-left">
            <div class="admin-page-title">Orders List</div>
            <div class="admin-page-subtitle"><%= orders ? orders.length : 0 %> total orders</div>
          </div>
        </div>

        <% if (orders && orders.length > 0) { %>
        <div class="admin-card">
          <div class="admin-card-body p-0">
            <div class="admin-table-wrap">
              <table id="ordersTable" class="admin-table">
                <thead>
                  <tr>
                    <th>Order ID</th>
                    <th>Order Date</th>
                    <th>Customer</th>
                    <th>Payment</th>
                    <th>Total</th>
                    <th class="text-center">Status</th>
                  </tr>
                </thead>
                <tbody>
                  <% orders.forEach(order => { %>
                  <tr>
                    <td>
                      <a
                        href="/admin/orders/<%= order._id %>"
                        style="
                          font-family: 'Bebas Neue', sans-serif;
                          font-size: 0.95rem;
                          letter-spacing: 0.04em;
                          color: var(--black);
                          text-decoration: none;
                          border-bottom: 1px dashed var(--grey-300);
                        "
                      >
                        <%= order.uniqueOrderId %>
                      </a>
                    </td>
                    <td style="font-size: 0.8rem; color: var(--grey-600)">
                      <%= new Date(order.createdAt).toLocaleDateString('en-IN', { day: '2-digit',
                      month: 'short', year: 'numeric' }) %>
                    </td>
                    <td style="font-weight: 600"><%= order.userId?.name || '—' %></td>
                    <td>
                      <span class="admin-badge badge-grey"
                        ><%= order.paymentMethod.toUpperCase() %></span
                      >
                    </td>
                    <td style="font-weight: 700">₹<%= order.totalCost.toFixed(2) %></td>
                    <td class="text-center">
                      <span
                        class="admin-badge <%= order.paymentStatus === 'confirmed' || order.paymentStatus === 'paid' ? 'badge-green' : 'badge-grey' %>"
                      >
                        <%= order.paymentStatus.toUpperCase() %>
                      </span>
                    </td>
                  </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <% } else { %>
        <div class="admin-card" style="text-align: center; padding: 4rem 2rem">
          <i
            class="fas fa-shopping-cart"
            style="font-size: 3rem; color: var(--grey-200); margin-bottom: 1rem; display: block"
          ></i>
          <div
            style="
              font-family: 'Bebas Neue', sans-serif;
              font-size: 1.5rem;
              letter-spacing: 0.04em;
              margin-bottom: 0.5rem;
            "
          >
            No Orders Yet
          </div>
          <p style="color: var(--grey-400); font-size: 0.88rem">No orders have been placed yet.</p>
        </div>
        <% } %>
      </main>
    </div>

    <footer class="admin-footer">© 2024 ShoeZone Admin Panel. All rights reserved.</footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.bootstrap5.min.js"></script>
    <script>
      document.getElementById("adminPill")?.addEventListener("click", function (e) {
        e.stopPropagation();
        this.classList.toggle("open");
      });
      document.addEventListener("click", () =>
        document.getElementById("adminPill")?.classList.remove("open")
      );

      $(document).ready(function () {
        $("#ordersTable").DataTable({
          responsive: true,
          pageLength: 10,
          lengthMenu: [5, 10, 25, 50],
          order: [[1, "desc"]],
          language: {
            search: "Search orders:",
            emptyTable: "No orders found",
          },
        });
      });
    </script>
  </body>
</html>
