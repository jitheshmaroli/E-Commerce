<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Log In - ShoeZone</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
    />
    <link rel="stylesheet" href="/css/auth-shared.css" />
  </head>
  <body>
    <header class="header">
      <div class="brand">
        <a class="navbar-brand nav-link" style="color: aliceblue" href="/">
          <img src="/test.jpg" alt="Brand Logo" />
          <span class="brand-name">ShoeZone</span>
        </a>
      </div>
    </header>

    <div class="container d-flex align-items-center justify-content-center min-vh-100">
      <div class="form-container card shadow">
        <div class="card-body p-4">
          <h3 class="text-center mb-4">Log In</h3>

          <% if (message) { %>
          <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <%= message %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
          <% } %>

          <form action="/login" method="POST" id="loginForm" novalidate>
            <div class="mb-4">
              <label for="email" class="form-label">Email</label>
              <input
                type="email"
                class="form-control"
                id="email"
                name="email"
                required
                autocomplete="email"
                autofocus
              />
              <div class="invalid-feedback">Please enter a valid email</div>
            </div>

            <div class="mb-4">
              <label for="password" class="form-label">Password</label>
              <div class="input-group">
                <input
                  type="password"
                  class="form-control"
                  id="password"
                  name="password"
                  required
                />
                <span class="input-group-text toggle-password" id="togglePassword">
                  <i class="bi bi-eye-slash"></i>
                </span>
              </div>
            </div>

            <button type="submit" class="btn btn-dark w-100 py-2 mb-3">Log In</button>

            <a href="/auth/google" class="btn btn-outline-dark w-100 mb-3">
              <i class="bi bi-google me-2"></i> Sign in with Google
            </a>

            <div class="text-center">
              <a href="/forgot-password" class="text-muted d-block mb-2">Forgot Password?</a>
              <a href="/signup" class="text-muted">Create an account</a>
            </div>
          </form>
        </div>
      </div>
    </div>

    <footer class="footer">
      <p class="copyright">© 2026 ShoeZone</p>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      const password = document.getElementById("password");
      const togglePassword = document.getElementById("togglePassword");

      togglePassword.addEventListener("click", () => {
        const type = password.type === "password" ? "text" : "password";
        password.type = type;
        togglePassword.innerHTML = `<i class="bi bi-eye${type === "password" ? "-slash" : ""}"></i>`;
      });
    </script>
    <script>
      // Login real-time email validation
      const loginEmail = document.getElementById("email");
      const loginForm = document.getElementById("loginForm");

      function validateLoginEmail() {
        const value = loginEmail.value.trim();
        const isValid = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value);

        loginEmail.classList.toggle("is-invalid", !isValid && value.length > 0);
        loginEmail.classList.toggle("is-valid", isValid);
      }

      loginEmail.addEventListener("input", validateLoginEmail);

      loginForm.addEventListener("submit", (e) => {
        if (!loginEmail.checkValidity()) {
          e.preventDefault();
          loginEmail.classList.add("is-invalid");
          loginEmail.focus();
        }
      });
    </script>
  </body>
</html>
