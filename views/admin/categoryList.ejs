<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Category List · ShoeZone Admin</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdn.datatables.net/2.0.8/css/dataTables.bootstrap5.min.css"
    />
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/admin-shared.css" />
  </head>
  <body>
    <!-- ── Top bar ── -->
    <header class="admin-topbar">
      <a href="/admin" class="topbar-brand">
        <div class="topbar-brand-logo"><img src="/test.jpg" alt="Logo" /></div>
        <span class="topbar-brand-name">ShoeZone <em>Admin</em></span>
      </a>
      <div class="topbar-breadcrumb">
        <i class="fas fa-home"></i>
        <i class="fas fa-chevron-right"></i>
        <span>Categories</span>
      </div>
      <div class="topbar-right">
        <div class="topbar-admin-pill" id="adminPill">
          <div class="topbar-admin-avatar">A</div>
          <span class="topbar-admin-label">Admin</span>
          <i class="fas fa-chevron-down topbar-admin-chevron"></i>
          <div class="topbar-admin-dropdown">
            <a href="/admin/logout" class="topbar-dropdown-item"
              ><i class="fas fa-sign-out-alt"></i> Logout</a
            >
          </div>
        </div>
      </div>
    </header>

    <div class="admin-shell">
      <%- include('../includes/adminSidebar.ejs', { activePage: 'categories' }) %>

      <main class="admin-main">
        <div class="admin-page-header">
          <div class="admin-page-header-left">
            <div class="admin-page-title">Category List</div>
            <div class="admin-page-subtitle">
              <%= categoryList ? categoryList.length : 0 %> categories configured
            </div>
          </div>
          <a href="/admin/addcategory" class="btn-admin btn-admin-primary">
            <i class="fas fa-plus"></i> Add New Category
          </a>
        </div>

        <% if (categoryList && categoryList.length > 0) { %>
        <div class="admin-card">
          <div class="admin-card-body p-0">
            <div class="admin-table-wrap">
              <table id="categoryTable" class="admin-table">
                <thead>
                  <tr>
                    <th>Category Name</th>
                    <th>Description</th>
                    <th class="text-center">Status</th>
                    <th class="text-center">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% categoryList.forEach(category => { %>
                  <tr data-category-id="<%= category._id %>">
                    <td
                      style="
                        font-family: 'Bebas Neue', sans-serif;
                        font-size: 1rem;
                        letter-spacing: 0.04em;
                      "
                    >
                      <%= category.categoryName %>
                    </td>
                    <td style="color: var(--grey-600)"><%= category.description || '—' %></td>
                    <td class="text-center">
                      <span
                        id="status-<%= category._id %>"
                        class="admin-badge <%= category.isBlocked ? 'badge-red' : 'badge-green' %>"
                      >
                        <%= category.isBlocked ? 'INACTIVE' : 'ACTIVE' %>
                      </span>
                    </td>
                    <td class="text-center">
                      <div style="display: flex; gap: 0.4rem; justify-content: center">
                        <a
                          href="/admin/categoryList/edit/<%= category._id %>"
                          class="btn-admin btn-admin-warning btn-admin-sm"
                          title="Edit"
                        >
                          <i class="fas fa-edit"></i>
                        </a>
                        <button
                          class="btn-admin btn-admin-sm toggle-status-btn <%= category.isBlocked ? 'btn-admin-primary' : 'btn-admin-danger' %>"
                          data-id="<%= category._id %>"
                          data-status="<%= category.isBlocked %>"
                          title="<%= category.isBlocked ? 'Activate' : 'Deactivate' %>"
                        >
                          <%= category.isBlocked ? 'ACTIVATE' : 'DEACTIVATE' %>
                        </button>
                      </div>
                    </td>
                  </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <% } else { %>
        <div class="admin-card" style="text-align: center; padding: 4rem 2rem">
          <i
            class="fas fa-tags"
            style="font-size: 3rem; color: var(--grey-200); margin-bottom: 1rem; display: block"
          ></i>
          <div
            style="
              font-family: 'Bebas Neue', sans-serif;
              font-size: 1.5rem;
              letter-spacing: 0.04em;
              margin-bottom: 0.5rem;
            "
          >
            No Categories Found
          </div>
          <p style="color: var(--grey-400); font-size: 0.88rem; margin-bottom: 1.5rem">
            Click "Add New Category" to create your first category.
          </p>
          <a href="/admin/addcategory" class="btn-admin btn-admin-primary">
            <i class="fas fa-plus"></i> Add New Category
          </a>
        </div>
        <% } %>
      </main>
    </div>

    <footer class="admin-footer">© 2024 ShoeZone Admin Panel. All rights reserved.</footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
      document.getElementById("adminPill")?.addEventListener("click", function (e) {
        e.stopPropagation();
        this.classList.toggle("open");
      });
      document.addEventListener("click", () =>
        document.getElementById("adminPill")?.classList.remove("open")
      );

      $(document).ready(function () {
        $("#categoryTable").DataTable({
          responsive: true,
          pageLength: 10,
          lengthMenu: [5, 10, 25, 50],
          order: [[0, "asc"]],
          language: {
            search: "Search categories:",
            emptyTable: "No categories found",
          },
        });
      });

      // Toggle Status with SweetAlert
      document.querySelectorAll(".toggle-status-btn").forEach((btn) => {
        btn.addEventListener("click", async function () {
          const categoryId = this.dataset.id;
          const currentStatus = this.dataset.status === "true";
          const action = currentStatus ? "activate" : "deactivate";

          const result = await Swal.fire({
            title: `Are you sure?`,
            text: `This will ${action} the category and ${action} all products in it!`,
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: currentStatus ? "#28a745" : "#d33",
            cancelButtonColor: "#6c757d",
            confirmButtonText: `Yes, ${action.toUpperCase()} it!`,
          });

          if (result.isConfirmed) {
            try {
              const res = await fetch(`/admin/categoryList/toggleStatus/${categoryId}`, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ isBlocked: !currentStatus }),
              });

              if (!res.ok) {
                const text = await res.text();
                console.error("Server responded with non-OK status:", res.status, text);
                throw new Error(`Server error: ${res.status} - ${text}`);
              }

              let data;
              try {
                data = await res.json();
              } catch (jsonErr) {
                console.warn("JSON parse failed, but status updated anyway:", jsonErr);
                data = { success: true, isBlocked: !currentStatus };
              }

              if (data.success) {
                const statusBadge = document.querySelector(`#status-${categoryId}`);
                const toggleBtn = this;

                if (data.isBlocked) {
                  statusBadge.textContent = "INACTIVE";
                  statusBadge.className = "admin-badge badge-red";
                  toggleBtn.textContent = "ACTIVATE";
                  toggleBtn.classList.remove("btn-admin-danger");
                  toggleBtn.classList.add("btn-admin-primary");
                  toggleBtn.dataset.status = "true";
                } else {
                  statusBadge.textContent = "ACTIVE";
                  statusBadge.className = "admin-badge badge-green";
                  toggleBtn.textContent = "DEACTIVATE";
                  toggleBtn.classList.remove("btn-admin-primary");
                  toggleBtn.classList.add("btn-admin-danger");
                  toggleBtn.dataset.status = "false";
                }

                Swal.fire({
                  icon: "success",
                  title: "Updated!",
                  text: `Category ${data.isBlocked ? "deactivated" : "activated"} successfully.`,
                  timer: 1800,
                  showConfirmButton: false,
                });
              } else {
                Swal.fire("Error!", data.message || "Failed to update status.", "error");
              }
            } catch (err) {
              console.error("Toggle error:", err);
              Swal.fire({
                icon: "error",
                title: "Error",
                text: "Something went wrong, but status may have changed. Please refresh.",
              });
            }
          }
        });
      });
    </script>
  </body>
</html>
