<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Edit Offer · ShoeZone Admin</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
  <link rel="stylesheet" href="/css/admin-shared.css" />
</head>
<body>

<header class="admin-topbar">
  <a href="/admin" class="topbar-brand">
    <div class="topbar-brand-logo"><img src="/test.jpg" alt="Logo" /></div>
    <span class="topbar-brand-name">ShoeZone <em>Admin</em></span>
  </a>
  <div class="topbar-breadcrumb">
    <a href="/admin/offers" style="color:rgba(255,255,255,.35);text-decoration:none">Offers</a>
    <i class="fas fa-chevron-right"></i>
    <span>Edit Offer</span>
  </div>
  <div class="topbar-right">
    <div class="topbar-admin-pill" id="adminPill">
      <div class="topbar-admin-avatar">A</div>
      <span class="topbar-admin-label">Admin</span>
      <i class="fas fa-chevron-down topbar-admin-chevron"></i>
      <div class="topbar-admin-dropdown">
        <a href="/admin/logout" class="topbar-dropdown-item"><i class="fas fa-sign-out-alt"></i> Logout</a>
      </div>
    </div>
  </div>
</header>

<div class="admin-shell">
  <%- include('../../includes/adminSidebar.ejs', { activePage: 'offers' }) %>
  <main class="admin-main">

    <div class="admin-page-header">
      <div class="admin-page-header-left">
        <div class="admin-page-title">Edit Offer</div>
        <div class="admin-page-subtitle"><%= offer.name %></div>
      </div>
      <a href="/admin/offers" class="btn-admin btn-admin-ghost">
        <i class="fas fa-arrow-left"></i> Back to Offers
      </a>
    </div>

    <div class="admin-card" style="max-width:820px">
      <div class="admin-card-body">
        <form id="offerForm" method="POST" action="/admin/offers/edit/<%= offer._id %>">
          <div id="globalError" class="admin-error" style="margin-bottom:.75rem"></div>

          <div class="admin-field">
            <label class="admin-label">Offer Name <span class="req">*</span></label>
            <input type="text" class="admin-input" id="name" name="name"
              value="<%= offer.name %>" maxlength="50" required style="text-transform:uppercase" />
            <small id="nameError" class="admin-error"></small>
          </div>

          <div class="row g-3 mb-0">
            <div class="col-md-6">
              <div class="admin-field">
                <label class="admin-label">Discount Type <span class="req">*</span></label>
                <select class="admin-select" id="discountType" name="discountType" required>
                  <option value="percentage" <%= offer.discountType === 'percentage' ? 'selected' : '' %>>Percentage (%)</option>
                  <option value="amount" <%= offer.discountType === 'amount' ? 'selected' : '' %>>Fixed Amount (INR)</option>
                </select>
                <small id="discountTypeError" class="admin-error"></small>
              </div>
            </div>
            <div class="col-md-6">
              <div class="admin-field">
                <label class="admin-label">Discount Value <span class="req">*</span></label>
                <input type="number" class="admin-input" id="discountValue" name="discountValue"
                  value="<%= offer.discountValue %>" step="0.01" min="0.01" required />
                <small id="discountValueError" class="admin-error"></small>
              </div>
            </div>
          </div>

          <div class="admin-field">
            <label class="admin-label">Description <span class="req">*</span></label>
            <textarea class="admin-textarea" id="description" name="description" rows="4" maxlength="200" required><%= offer.description %></textarea>
            <small id="descriptionError" class="admin-error"></small>
          </div>

          <div class="row g-3 mb-0">
            <div class="col-md-6">
              <div class="admin-field">
                <label class="admin-label">Start Date <span class="req">*</span></label>
                <input type="date" class="admin-input" id="startDate" name="startDate"
                  value="<%= offer.startDate.toISOString().split('T')[0] %>"
                  min="<%= new Date().toISOString().split('T')[0] %>" required />
                <small id="startDateError" class="admin-error"></small>
              </div>
            </div>
            <div class="col-md-6">
              <div class="admin-field">
                <label class="admin-label">End Date <span class="req">*</span></label>
                <input type="date" class="admin-input" id="endDate" name="endDate"
                  value="<%= offer.endDate.toISOString().split('T')[0] %>" required />
                <small id="endDateError" class="admin-error"></small>
              </div>
            </div>
          </div>

          <div class="admin-field">
            <label class="admin-label">Apply To <span class="req">*</span></label>
            <select class="admin-select" id="offerType" name="offerType" required>
              <option value="product"        <%= offer.offerType === 'product'        ? 'selected' : '' %>>Specific Product</option>
              <option value="category"       <%= offer.offerType === 'category'       ? 'selected' : '' %>>Specific Category</option>
              <option value="all-products"   <%= offer.offerType === 'all-products'   ? 'selected' : '' %>>All Products</option>
              <option value="all-categories" <%= offer.offerType === 'all-categories' ? 'selected' : '' %>>All Categories</option>
            </select>
            <small id="offerTypeError" class="admin-error"></small>
          </div>

          <div class="admin-field" id="productGroup">
            <label class="admin-label">Product</label>
            <select class="admin-select" id="product" name="product">
              <option value="">None</option>
              <option value="all" <%= offer.applyToAllProducts ? 'selected' : '' %>>All Products</option>
              <% products.forEach(p => { %>
              <option value="<%= p._id %>" <%= offer.product?.toString() === p._id.toString() ? 'selected' : '' %>><%= p.name %></option>
              <% }) %>
            </select>
            <small id="productError" class="admin-error"></small>
          </div>

          <div class="admin-field" id="categoryGroup">
            <label class="admin-label">Category</label>
            <select class="admin-select" id="category" name="category">
              <option value="">None</option>
              <option value="all" <%= offer.applyToAllCategories ? 'selected' : '' %>>All Categories</option>
              <% categories.forEach(c => { %>
              <option value="<%= c._id %>" <%= offer.category?.toString() === c._id.toString() ? 'selected' : '' %>><%= c.categoryName %></option>
              <% }) %>
            </select>
            <small id="categoryError" class="admin-error"></small>
          </div>

          <!-- Is Active Toggle -->
          <div class="admin-field" style="margin-top:1.25rem">
            <label class="admin-label">Offer Status</label>
            <label style="display:flex;align-items:center;gap:.85rem;cursor:pointer;padding:.85rem 1rem;border:1.5px solid var(--grey-100);border-radius:var(--radius-sm);background:var(--off-white);user-select:none">
              <div style="position:relative;width:44px;height:24px;flex-shrink:0">
                <input type="checkbox" id="isActive" name="isActive"
                  <%= offer.isActive ? 'checked' : '' %>
                  style="opacity:0;position:absolute;inset:0;margin:0;cursor:pointer;z-index:1;width:100%;height:100%"
                  onchange="syncToggle(this)" />
                <div id="toggleTrack" style="position:absolute;inset:0;border-radius:999px;transition:background .2s;background:var(--grey-200)"></div>
                <div id="toggleThumb" style="position:absolute;top:3px;width:18px;height:18px;border-radius:50%;background:var(--white);box-shadow:0 1px 3px rgba(0,0,0,.25);transition:left .2s;left:3px"></div>
              </div>
              <div>
                <div id="toggleLabel" style="font-weight:700;font-size:.88rem;color:var(--black)"><%= offer.isActive ? 'Active' : 'Inactive' %></div>
                <div id="toggleDesc" style="font-size:.75rem;color:var(--grey-400)"><%= offer.isActive ? 'Offer is live and applying to eligible products' : 'Offer is disabled and will not apply to any products' %></div>
              </div>
            </label>
          </div>

          <div style="display:flex;gap:.75rem;margin-top:2rem;padding-top:1.5rem;border-top:1px solid var(--grey-100)">
            <button type="submit" class="btn-admin btn-admin-primary" style="flex:1;justify-content:center;padding:.85rem">
              <i class="fas fa-check"></i> Update Offer
            </button>
            <button type="button" class="btn-admin btn-admin-ghost" onclick="clearFields()" style="flex:1;justify-content:center;padding:.85rem">
              <i class="fas fa-eraser"></i> Clear
            </button>
            <a href="/admin/offers" class="btn-admin btn-admin-ghost" style="flex:1;justify-content:center;padding:.85rem">
              <i class="fas fa-times"></i> Cancel
            </a>
          </div>
        </form>
      </div>
    </div>

  </main>
</div>

<footer class="admin-footer">© 2024 ShoeZone Admin Panel. All rights reserved.</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
  document.getElementById('adminPill')?.addEventListener('click', function(e) {
    e.stopPropagation(); this.classList.toggle('open');
  });
  document.addEventListener('click', () => document.getElementById('adminPill')?.classList.remove('open'));

  const inputs = {
    name:          document.getElementById("name"),
    discountType:  document.getElementById("discountType"),
    discountValue: document.getElementById("discountValue"),
    description:   document.getElementById("description"),
    startDate:     document.getElementById("startDate"),
    endDate:       document.getElementById("endDate"),
    offerType:     document.getElementById("offerType"),
    product:       document.getElementById("product"),
    category:      document.getElementById("category"),
    isActive:      document.getElementById("isActive"),
  };

  const errors = {
    name:          document.getElementById("nameError"),
    discountType:  document.getElementById("discountTypeError"),
    discountValue: document.getElementById("discountValueError"),
    description:   document.getElementById("descriptionError"),
    startDate:     document.getElementById("startDateError"),
    endDate:       document.getElementById("endDateError"),
    offerType:     document.getElementById("offerTypeError"),
    product:       document.getElementById("productError"),
    category:      document.getElementById("categoryError"),
  };

  Object.values(inputs).forEach(input => {
    if (input) {
      input.addEventListener("input", () => validateField(input));
      input.addEventListener("blur", () => validateField(input));
    }
  });

  const initialFormState = getFormState();

  function getFormState() {
    return {
      name:          inputs.name?.value.trim(),
      discountType:  inputs.discountType?.value,
      discountValue: inputs.discountValue?.value,
      description:   inputs.description?.value.trim(),
      startDate:     inputs.startDate?.value,
      endDate:       inputs.endDate?.value,
      offerType:     inputs.offerType?.value,
      product:       inputs.product?.value,
      category:      inputs.category?.value,
      isActive:      inputs.isActive?.checked,
    };
  }

  function hasFormChanged() {
    const current = getFormState();
    return Object.keys(initialFormState).some(key => initialFormState[key] !== current[key]);
  }

  inputs.name?.addEventListener("input", () => {
    inputs.name.value = inputs.name.value.toUpperCase();
  });

  function validateField(input) {
    const value = input.value.trim();
    const id = input.id;
    let errorMsg = "";

    if (id === "name") {
      if (!value) errorMsg = "Offer name is required";
      else if (value.length < 3 || value.length > 50) errorMsg = "Name must be 3-50 characters";
    } else if (id === "discountType") {
      if (!value) errorMsg = "Select discount type";
    } else if (id === "discountValue") {
      const num = parseFloat(value);
      const type = inputs.discountType.value;
      if (!value) errorMsg = "Discount value is required";
      else if (isNaN(num) || num <= 0) errorMsg = "Enter positive value";
      else if (type === "percentage" && (num < 1 || num > 100)) errorMsg = "Percentage: 1-100";
    } else if (id === "description") {
      if (!value) errorMsg = "Description is required";
      else if (value.length < 10 || value.length > 200) errorMsg = "Description: 10-200 characters";
    } else if (id === "startDate") {
      if (!value) errorMsg = "Start date is required";
      else {
        const selected = new Date(value);
        const today = new Date(); today.setHours(0,0,0,0);
        if (selected < today) errorMsg = "Start date cannot be in the past";
      }
    } else if (id === "endDate") {
      if (!value) errorMsg = "End date is required";
      else {
        const selected = new Date(value);
        if (selected <= new Date()) errorMsg = "End date must be in the future";
      }
    } else if (id === "offerType") {
      if (!value) errorMsg = "Select offer target";
    } else if (id === "product" && inputs.offerType?.value === "product" && !value) {
      errorMsg = "Select a product";
    } else if (id === "category" && inputs.offerType?.value === "category" && !value) {
      errorMsg = "Select a category";
    }

    if (errors[id]) {
      errors[id].textContent = errorMsg;
      input.classList.toggle("is-invalid", !!errorMsg);
    }

    if (inputs.startDate?.value && inputs.endDate?.value) {
      const start = new Date(inputs.startDate.value);
      const end   = new Date(inputs.endDate.value);
      if (start >= end) {
        errors.endDate.textContent = "End date must be after start date";
        inputs.endDate.classList.add("is-invalid");
      }
    }
  }

  function isFormValid() {
    let valid = true;
    Object.values(inputs).forEach(input => {
      if (input && input.type !== "checkbox") {
        validateField(input);
        if (input.classList.contains("is-invalid")) valid = false;
      }
    });
    return valid;
  }

  document.getElementById("offerForm").addEventListener("submit", async function(e) {
    e.preventDefault();

    if (!hasFormChanged()) {
      Swal.fire({ icon:"info", title:"No Changes", text:"No changes were made to update.", timer:2000, showConfirmButton:false });
      return;
    }

    if (!isFormValid()) {
      Swal.fire({ icon:"warning", title:"Invalid Input", text:"Please fix the highlighted errors", timer:2500, showConfirmButton:false });
      return;
    }

    const formData = new FormData(this);
    const data = Object.fromEntries(formData);

    // Checkbox omitted from FormData when unchecked — normalise explicitly so controller sees "on"/"off"
    data.isActive = inputs.isActive.checked ? "on" : "off";

    if (data.offerType !== "product")   delete data.product;
    if (data.offerType !== "category")  delete data.category;

    try {
      const res = await fetch(this.action, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data)
      });
      const result = await res.json();
      if (result.success) {
        await Swal.fire("Success", "Offer updated successfully!", "success");
        window.location.href = "/admin/offers";
      } else {
        Swal.fire("Error", result.message || "Failed to update offer.", "error");
      }
    } catch (err) {
      Swal.fire("Error", "Network error occurred.", "error");
    }
  });

  function clearFields() {
    document.querySelectorAll("input:not([type=checkbox]), textarea, select").forEach(el => {
      el.value = ""; el.classList.remove("is-invalid");
    });
    document.querySelectorAll(".admin-error").forEach(el => el.textContent = "");
  }

  function syncToggle(checkbox) {
    const track = document.getElementById("toggleTrack");
    const thumb = document.getElementById("toggleThumb");
    const label = document.getElementById("toggleLabel");
    const desc  = document.getElementById("toggleDesc");
    if (checkbox.checked) {
      track.style.background = "var(--black)";
      thumb.style.left = "23px";
      label.textContent = "Active";
      desc.textContent  = "Offer is live and applying to eligible products";
    } else {
      track.style.background = "var(--grey-200)";
      thumb.style.left = "3px";
      label.textContent = "Inactive";
      desc.textContent  = "Offer is disabled and will not apply to any products";
    }
  }

  function toggleGroups() {
    const val = document.getElementById("offerType")?.value;
    document.getElementById("productGroup").style.display  = (val === "product")  ? "block" : "none";
    document.getElementById("categoryGroup").style.display = (val === "category") ? "block" : "none";
  }

  document.addEventListener("DOMContentLoaded", toggleGroups);
  document.addEventListener("DOMContentLoaded", () => syncToggle(inputs.isActive));
  document.getElementById("offerType")?.addEventListener("change", toggleGroups);

  document.getElementById("discountType")?.addEventListener("change", function() {
    const input = document.getElementById("discountValue");
    if (this.value === "percentage") {
      input.min = "1"; input.max = "100"; input.step = "1";
    } else {
      input.removeAttribute("max"); input.min = "0.01"; input.step = "0.01";
    }
  });

  document.getElementById("discountType")?.dispatchEvent(new Event("change"));
</script>
</body>
</html>
