<%- include('../includes/userHead.ejs') %>
<link rel="stylesheet" href="/css/profile-shared.css" />
<%- include('../includes/userHeader.ejs') %>

<% if (user) { %>
<div class="account-shell">
  <%- include('../includes/accountNav.ejs', { activePage: 'orders' }) %>

  <div class="account-content">
    <div style="max-width: 760px">
      <% if (product) { %>

      <!-- Page title -->
      <div style="margin-bottom: 1.5rem">
        <a
          href="/order-history"
          class="btn-acc-ghost"
          style="
            font-size: 0.74rem;
            padding: 0.45rem 0.95rem;
            margin-bottom: 1rem;
            display: inline-flex;
          "
        >
          <i class="fas fa-arrow-left"></i> Back to Orders
        </a>
        <h2
          style="
            font-family: 'Bebas Neue', sans-serif;
            font-size: 2rem;
            letter-spacing: 0.03em;
            color: var(--black);
            margin: 0;
          "
        >
          Write a Review
        </h2>
      </div>

      <div class="review-page-grid">
        <!-- Product preview -->
        <div class="review-product-preview">
          <img
            src="/uploads/<%= product.photos[0].filename %>"
            alt="<%= product.name %>"
            class="review-product-img"
          />
          <div class="review-product-meta">
            <div class="review-product-name"><%= product.name %></div>
            <div class="review-product-desc"><%= product.description %></div>
            <div class="review-product-price">₹<%= product.price %></div>
          </div>
        </div>

        <!-- Review form -->
        <div class="account-card review-form-card">
          <div class="account-card-header">
            <div class="account-card-icon"><i class="fas fa-star"></i></div>
            <h2>Your Rating</h2>
          </div>
          <div class="account-card-body">
            <form action="/review/<%= orderId %>/<%= productId %>" method="POST">
              <div class="acc-field">
                <label>Star Rating</label>
                <div class="star-rating-group">
                  <input type="radio" id="star5" name="rating" value="5" required /><label
                    for="star5"
                    title="5 stars"
                    ><i class="fas fa-star"></i
                  ></label>
                  <input type="radio" id="star4" name="rating" value="4" /><label
                    for="star4"
                    title="4 stars"
                    ><i class="fas fa-star"></i
                  ></label>
                  <input type="radio" id="star3" name="rating" value="3" /><label
                    for="star3"
                    title="3 stars"
                    ><i class="fas fa-star"></i
                  ></label>
                  <input type="radio" id="star2" name="rating" value="2" /><label
                    for="star2"
                    title="2 stars"
                    ><i class="fas fa-star"></i
                  ></label>
                  <input type="radio" id="star1" name="rating" value="1" /><label
                    for="star1"
                    title="1 star"
                    ><i class="fas fa-star"></i
                  ></label>
                </div>
              </div>

              <div class="acc-field">
                <label for="comment">Your Review</label>
                <textarea
                  id="comment"
                  name="comment"
                  class="review-textarea"
                  rows="5"
                  placeholder="Share your experience with this product..."
                  required
                ></textarea>
              </div>

              <button type="submit" class="btn-acc-submit">
                <i class="fas fa-paper-plane"></i> Submit Review
              </button>
            </form>
          </div>
        </div>
      </div>

      <% } else { %>
      <div class="orders-empty">
        <i class="fas fa-box-open"></i>
        <h3>Product Not Found</h3>
        <a href="/order-history" class="btn-shop-now"
          ><i class="fas fa-arrow-left"></i> Back to Orders</a
        >
      </div>
      <% } %>
    </div>
  </div>
</div>
<% } %>

<%- include('../includes/userFooter.ejs') %>
<%- include('../includes/userScripts.ejs') %>

<script>
  function setCategory(c) {
    var el = document.getElementById("selectedCategory");
    if (el) el.value = c;
    var dt = document.querySelector(".dropdown-toggle-text");
    if (dt) dt.textContent = c.charAt(0).toUpperCase() + c.slice(1);
  }
</script>
