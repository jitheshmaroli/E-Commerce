<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Update Product - Admin</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
  <link rel="stylesheet" href="/css/theme.css" />
  <link rel="stylesheet" href="/css/updateProduct.css" />
</head>
<body class="bg-light">

  <!-- Navbar -->
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
    <div class="container-fluid">
      <a class="navbar-brand fw-bold" href="/admin">
        <img src="/test.jpg" alt="Logo" width="35" class="d-inline-block align-text-top me-2" />
        SportZilon Admin
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle text-white" href="#" id="adminDropdown" role="button" data-bs-toggle="dropdown">
              ADMIN
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
              <li><a class="dropdown-item" href="/admin/logout">Logout</a></li>
            </ul>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="d-flex">
    <!-- Sidebar -->
    <aside class="sidebar bg-dark text-white p-3" style="width: 250px; min-height: 100vh;">
      <div class="list-group list-group-flush">
        <a href="/admin" class="list-group-item list-group-item-action bg-dark text-white border-0 py-3">
          <i class="fas fa-home me-2"></i> HOME
        </a>
        <a href="/admin/allproducts" class="list-group-item list-group-item-action bg-dark text-white border-0 py-3 active">
          <i class="fas fa-box me-2"></i> ALL PRODUCTS
        </a>
        <a href="/admin/ordersList" class="list-group-item list-group-item-action bg-dark text-white border-0 py-3">
          <i class="fas fa-shopping-cart me-2"></i> ORDERS LIST
        </a>
        <a href="/admin/usersList" class="list-group-item list-group-item-action bg-dark text-white border-0 py-3">
          <i class="fas fa-users me-2"></i> USERS LIST
        </a>
        <a href="/admin/categoryList" class="list-group-item list-group-item-action bg-dark text-white border-0 py-3">
          <i class="fas fa-tags me-2"></i> CATEGORY LIST
        </a>
        <a href="/admin/couponList" class="list-group-item list-group-item-action bg-dark text-white border-0 py-3">
          <i class="fas fa-gift me-2"></i> COUPON LIST
        </a>
        <a href="/admin/offers" class="list-group-item list-group-item-action bg-dark text-white border-0 py-3">
          <i class="fas fa-percentage me-2"></i> OFFERS
        </a>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="content flex-grow-1 p-4">
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb bg-transparent p-0 mb-4">
          <li class="breadcrumb-item"><a href="/admin/allproducts" class="text-dark">All Products</a></li>
          <li class="breadcrumb-item active" aria-current="page">Update Product</li>
        </ol>
      </nav>

      <div class="card shadow-lg border-0" style="max-width: 900px; margin: 0 auto;">
        <div class="card-header bg-dark text-white text-center py-3">
          <h4 class="mb-0">Update Product: <%= productData.name %></h4>
        </div>
        <div class="card-body p-4">
          <form id="productForm" method="POST" action="/admin/allProducts/edit/<%= productData._id %>" enctype="multipart/form-data">
            <div class="row">
              <!-- Left Column: Form Fields -->
              <div class="col-lg-7">
                <div class="mb-4">
                  <label for="name" class="form-label fw-bold">Product Name <span class="text-danger">*</span></label>
                  <input type="text" class="form-control" id="name" name="name" value="<%= productData.name %>" maxlength="50" required />
                  <small id="nameError" class="text-danger"></small>
                </div>

                <div class="mb-4">
                  <label for="description" class="form-label fw-bold">Description <span class="text-danger">*</span></label>
                  <textarea class="form-control" id="description" name="description" rows="4" maxlength="500" required><%= productData.description %></textarea>
                  <small id="descriptionError" class="text-danger"></small>
                </div>

                <div class="mb-4">
                  <label for="category" class="form-label fw-bold">Category <span class="text-danger">*</span></label>
                  <select class="form-control" id="category" name="category" required>
                    <option value="">Select Category</option>
                    <% categoryList.forEach(cat => { %>
                      <option value="<%= cat.categoryName %>" 
                              <%= productData.category?.categoryName === cat.categoryName ? 'selected' : '' %>>
                        <%= cat.categoryName %>
                      </option>
                    <% }) %>
                  </select>
                  <small id="categoryError" class="text-danger"></small>
                </div>

                <div class="row mb-4">
                  <div class="col-md-4">
                    <label for="brandName" class="form-label fw-bold">Brand Name</label>
                    <input type="text" class="form-control" id="brandName" name="brandName" value="<%= productData.brandName %>" />
                    <small id="brandNameError" class="text-danger"></small>
                  </div>
                  <div class="col-md-4">
                    <label for="stock" class="form-label fw-bold">Stock Quantity <span class="text-danger">*</span></label>
                    <input type="number" inputmode="numeric" pattern="[0-9]*" class="form-control" id="stock" name="stock" value="<%= productData.stock %>" min="0" required />
                    <small id="stockError" class="text-danger"></small>
                  </div>
                  <div class="col-md-4">
                    <label for="price" class="form-label fw-bold">Price (₹) <span class="text-danger">*</span></label>
                    <input type="number" inputmode="decimal" step="0.01" pattern="[0-9]+([.,][0-9]{1,2})?" class="form-control" id="price" name="price" min="0" required value="<%= productData.price %>" />
                    <small id="priceError" class="text-danger"></small>
                  </div>
                </div>

                <!-- <div class="mb-4">
                  <label for="tags" class="form-label fw-bold">Tags (comma separated)</label>
                  <input type="text" class="form-control" id="tags" name="tags" 
                         value="<%= Array.isArray(productData.tags) ? productData.tags.join(', ') : productData.tags %>" />
                  <small id="tagsError" class="text-danger"></small>
                </div> -->
              </div>

              <!-- Right Column: Image Management -->
              <div class="col-lg-5">
                <div class="border p-4 rounded bg-light">
                  <h5 class="text-center mb-4">Product Images (Current: <%= productData.photos.length %>)</h5>

                  <input type="file" class="form-control mb-3" name="photos" id="photos" accept="image/*" multiple />
                  <small class="form-text text-muted">Add new images (existing ones can be removed below).</small>
                  <small id="photosError" class="text-danger d-block mt-2"></small>

                  <div class="image-preview-container d-flex flex-wrap justify-content-center mt-4">
                    <% productData.photos.forEach((photo, index) => { %>
                      <div class="image-wrapper m-2 text-center" data-filename="<%= photo.filename %>">
                        <img src="/uploads/<%= photo.filename %>" class="img-thumbnail" width="120" height="120" alt="Product Image">
                        <button type="button" class="btn btn-sm btn-danger mt-2 remove-image-btn">
                          Remove
                        </button>
                        <input type="hidden" name="existingPhotos[]" value="<%= photo.filename %>">
                      </div>
                    <% }) %>
                  </div>
                </div>
              </div>
            </div>

            <!-- Buttons -->
            <div class="d-flex gap-3 mt-5">
              <button type="submit" class="btn btn-dark flex-grow-1 py-3 fw-bold">UPDATE PRODUCT</button>
              <button type="button" class="btn btn-outline-dark flex-grow-1 py-3" onclick="clearFields()">CLEAR</button>
              <a href="/admin/allproducts" class="btn btn-outline-secondary flex-grow-1 py-3 text-center">BACK</a>
            </div>
          </form>
        </div>
      </div>
    </main>
  </div>

  <!-- Scripts -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
  // DOM Elements
  const form = document.getElementById("productForm");
  const photoInput = document.getElementById("photos");
  const previewArea = document.querySelector(".image-preview-container");

  // Error elements
  const nameError = document.getElementById("nameError");
  const descError = document.getElementById("descriptionError");
  const categoryError = document.getElementById("categoryError");
  const brandError = document.getElementById("brandNameError");
  const stockError = document.getElementById("stockError");
  const priceError = document.getElementById("priceError");
  const photosError = document.getElementById("photosError");

  // Helper: show error + red border
  function setFieldError(errorEl, message, inputEl = null) {
    if (!errorEl) return;
    const targetInput = inputEl || errorEl.previousElementSibling;
    if (message) {
      errorEl.textContent = message;
      if (targetInput && targetInput.classList) {
        targetInput.classList.add("is-invalid");
      }
    } else {
      errorEl.textContent = "";
      if (targetInput && targetInput.classList) {
        targetInput.classList.remove("is-invalid");
      }
    }
  }

  // Clear all errors
  function clearAllErrors() {
    document.querySelectorAll(".text-danger").forEach(el => el.textContent = "");
    document.querySelectorAll(".is-invalid").forEach(el => el.classList.remove("is-invalid"));
  }

  // Validation functions
  function validateName(v) {
    v = v.trim();
    if (!v) return "Product name is required.";
    if (v.length < 3) return "Name must be at least 3 characters.";
    if (v.length > 50) return "Name cannot exceed 50 characters.";
    return "";
  }
  function validateDescription(v) {
    v = v.trim();
    if (!v) return "Description is required.";
    if (v.length < 20) return "Description should be at least 20 characters.";
    if (v.length > 500) return "Description cannot exceed 500 characters.";
    return "";
  }
  function validateCategory(v) { return v ? "" : "Please select a category."; }
  function validateStock(v) {
    if (!v || isNaN(v)) return "Stock quantity is required.";
    const n = Number(v);
    if (!Number.isInteger(n)) return "Stock must be a whole number.";
    if (n < 0) return "Stock cannot be negative.";
    if (n > 99999) return "Stock seems too large (max 99999).";
    return "";
  }
  function validatePrice(v) {
    if (!v || isNaN(v)) return "Price is required.";
    const n = Number(v);
    if (n <= 0) return "Price must be greater than 0.";
    if (n < 10) return "Price should be at least ₹10.";
    if (n > 1000000) return "Price seems unusually high.";
    return "";
  }

  // Count total images (existing + new)
  function getImageCount() {
    return previewArea.querySelectorAll(".image-wrapper").length;
  }
  function validateImages() {
    const count = getImageCount();
    if (count < 4) return `At least 4 images required (currently ${count}).`;
    if (count > 4) return `Only 4 images allowed (currently ${count}).`;
    return "";
  }

  // Attach real‑time validation
  function attachValidation(field, validator, errorEl) {
    if (!field) return;
    ["input", "blur"].forEach(ev => {
      field.addEventListener(ev, () => {
        const msg = validator(field.value);
        setFieldError(errorEl, msg, field);
      });
    });
  }
  attachValidation(document.getElementById("name"),        validateName,        nameError);
  attachValidation(document.getElementById("description"), validateDescription, descError);
  attachValidation(document.getElementById("category"),    validateCategory,    categoryError);
  attachValidation(document.getElementById("brandName"),   () => "",            brandError);
  attachValidation(document.getElementById("stock"),       validateStock,       stockError);
  attachValidation(document.getElementById("price"),       validatePrice,       priceError);

  // Image handling

  // Remove image (works for both existing and new)
  previewArea.addEventListener("click", e => {
    if (!e.target.classList.contains("remove-image-btn")) return;
    const wrapper = e.target.closest(".image-wrapper");
    if (!wrapper) return;

    // If it's a new image (has class 'new-image'), also clear the file input
    if (wrapper.classList.contains("new-image")) {
      photoInput.value = "";
    } else {
      wrapper.querySelector('input[name="existingPhotos[]"]')?.remove();
    }

    wrapper.remove();

    // Re‑validate image count and show error if needed
    const err = validateImages();
    setFieldError(photosError, err, photoInput);
  });

  // Add new images
  photoInput.addEventListener("change", function () {
    const files = Array.from(this.files);
    let hasInvalid = false;

    // Remove all previously added new‑image wrappers (they will be replaced)
    previewArea.querySelectorAll(".image-wrapper.new-image").forEach(w => w.remove());

    files.forEach(file => {
      if (!["image/jpeg", "image/png", "image/webp"].includes(file.type)) {
        hasInvalid = true;
        return;
      }
      if (file.size > 5 * 1024 * 1024) {
        hasInvalid = true;
        return;
      }

      // Create object URL synchronously
      const imgUrl = URL.createObjectURL(file);
      const wrapper = document.createElement("div");
      wrapper.className = "image-wrapper m-2 text-center new-image";
      wrapper.innerHTML = `
        <img src="${imgUrl}" class="img-thumbnail" width="120" height="120" alt="New image">
        <button type="button" class="btn btn-sm btn-danger mt-2 remove-image-btn">Remove</button>
        <br><small class="text-success">New</small>
      `;
      previewArea.appendChild(wrapper);
    });

    if (hasInvalid) {
      photosError.textContent = "Some files were skipped (invalid type or >5MB).";
    }

    const err = validateImages();
    setFieldError(photosError, err, photoInput);
  });

  // --- Form submit ---
  form.addEventListener("submit", async function (e) {
    e.preventDefault();

    // Clear previous errors
    clearAllErrors();

    // Run validations
    const nameField = document.getElementById("name");
    const descField = document.getElementById("description");
    const catField  = document.getElementById("category");
    const stockField = document.getElementById("stock");
    const priceField = document.getElementById("price");

    const nameErr   = validateName(nameField.value);
    const descErr   = validateDescription(descField.value);
    const catErr    = validateCategory(catField.value);
    const stockErr  = validateStock(stockField.value);
    const priceErr  = validatePrice(priceField.value);
    const imagesErr = validateImages();

    // Show errors
    setFieldError(nameError,     nameErr,   nameField);
    setFieldError(descError,     descErr,   descField);
    setFieldError(categoryError, catErr,    catField);
    setFieldError(stockError,    stockErr,  stockField);
    setFieldError(priceError,    priceErr,  priceField);
    setFieldError(photosError,   imagesErr, photoInput);

    // Stop if any error
    if (nameErr || descErr || catErr || stockErr || priceErr || imagesErr) {
      Swal.fire({
        icon: "error",
        title: "Validation Error",
        text: "Please correct the fields marked in red.",
        confirmButtonColor: "#dc3545"
      });
      return;
    }

    // Submit
    try {
      const formData = new FormData(form);
      const res = await fetch(form.action, {
        method: "POST",
        body: formData
      });

      let result;
      try {
        result = await res.json();
      } catch (jsonErr) {
        if (res.ok || res.redirected) {
          await Swal.fire("Success", "Product updated successfully!", "success");
          window.location.href = "/admin/allproducts";
          return;
        }
        throw jsonErr;
      }

      if (result?.success || res.ok) {
        await Swal.fire("Success", "Product updated successfully!", "success");
        window.location.href = "/admin/allproducts";
      } else {
        Swal.fire("Error", result?.message || "Failed to update product.", "error");
      }
    } catch (err) {
      console.error("Submit error:", err);
      Swal.fire("Error", "Network error or server is unreachable.", "error");
    }
  });

  // Clear form (reset)
  function clearFields() {
    form.reset();
    previewArea.querySelectorAll(".image-wrapper.new-image").forEach(w => w.remove());
    clearAllErrors();
    const err = validateImages();
    setFieldError(photosError, err, photoInput);
  }
</script>
</body>
</html>