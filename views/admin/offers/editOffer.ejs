<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Edit Offer - Admin</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
  <link rel="stylesheet" href="/css/theme.css" />
  <link rel="stylesheet" href="/css/addProduct.css" />
</head>
<body class="bg-light">

  <!-- Navbar -->
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
    <div class="container-fluid">
      <a class="navbar-brand fw-bold" href="/admin">
        <img src="/test.jpg" alt="Logo" width="35" class="d-inline-block align-text-top me-2" />
        SportZilon Admin
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle text-white" href="#" id="adminDropdown" role="button" data-bs-toggle="dropdown">
              ADMIN
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
              <li><a class="dropdown-item" href="/admin/logout">Logout</a></li>
            </ul>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="d-flex">
    <!-- Sidebar -->
    <aside class="sidebar bg-dark text-white p-3" style="width: 250px; min-height: 100vh;">
      <div class="list-group list-group-flush">
        <a href="/admin" class="list-group-item list-group-item-action bg-dark text-white border-0 py-3">
          <i class="fas fa-home me-2"></i> HOME
        </a>
        <a href="/admin/allproducts" class="list-group-item list-group-item-action bg-dark text-white border-0 py-3">
          <i class="fas fa-box me-2"></i> ALL PRODUCTS
        </a>
        <a href="/admin/ordersList" class="list-group-item list-group-item-action bg-dark text-white border-0 py-3">
          <i class="fas fa-shopping-cart me-2"></i> ORDERS LIST
        </a>
        <a href="/admin/usersList" class="list-group-item list-group-item-action bg-dark text-white border-0 py-3">
          <i class="fas fa-users me-2"></i> USERS LIST
        </a>
        <a href="/admin/categoryList" class="list-group-item list-group-item-action bg-dark text-white border-0 py-3">
          <i class="fas fa-tags me-2"></i> CATEGORY LIST
        </a>
        <a href="/admin/couponList" class="list-group-item list-group-item-action bg-dark text-white border-0 py-3">
          <i class="fas fa-gift me-2"></i> COUPON LIST
        </a>
        <a href="/admin/offers" class="list-group-item list-group-item-action bg-dark text-white border-0 py-3 active">
          <i class="fas fa-percentage me-2"></i> OFFERS
        </a>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="content flex-grow-1 p-4">
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb bg-transparent p-0 mb-4">
          <li class="breadcrumb-item"><a href="/admin/offers" class="text-dark">Offers</a></li>
          <li class="breadcrumb-item active" aria-current="page">Edit Offer</li>
        </ol>
      </nav>

      <div class="card shadow-lg border-0" style="max-width: 800px; margin: 0 auto;">
        <div class="card-header bg-dark text-white text-center py-3">
          <h4 class="mb-0">Edit Offer: <%= offer.name %></h4>
        </div>
        <div class="card-body p-4">
          <form id="offerForm" method="POST" action="/admin/offers/edit/<%= offer._id %>">
            <div id="globalError" class="text-danger mb-3 fw-bold"></div>

            <!-- Offer Name -->
            <div class="mb-4">
              <label for="name" class="form-label fw-bold">Offer Name <span class="text-danger">*</span></label>
              <input type="text" class="form-control" id="name" name="name" value="<%= offer.name %>" maxlength="50" required />
              <small id="nameError" class="text-danger"></small>
            </div>

            <!-- Discount Type & Value -->
            <div class="row mb-4">
              <div class="col-md-6">
                <label for="discountType" class="form-label fw-bold">Discount Type <span class="text-danger">*</span></label>
                <select class="form-control" id="discountType" name="discountType" required>
                  <option value="percentage" <%= offer.discountType === 'percentage' ? 'selected' : '' %>>Percentage (%)</option>
                  <option value="amount" <%= offer.discountType === 'amount' ? 'selected' : '' %>>Fixed Amount (₹)</option>
                </select>
                <small id="discountTypeError" class="text-danger"></small>
              </div>
              <div class="col-md-6">
                <label for="discountValue" class="form-label fw-bold">Discount Value <span class="text-danger">*</span></label>
                <input type="text" class="form-control" id="discountValue" name="discountValue" value="<%= offer.discountValue %>"  inputmode="numeric" required />
                <small id="discountValueError" class="text-danger"></small>
              </div>
            </div>

            <!-- Description -->
            <div class="mb-4">
              <label for="description" class="form-label fw-bold">Description <span class="text-danger">*</span></label>
              <textarea class="form-control" id="description" name="description" rows="4" maxlength="200" required><%= offer.description %></textarea>
              <small id="descriptionError" class="text-danger"></small>
            </div>

            <!-- Dates -->
            <div class="row mb-4">
              <div class="col-md-6">
                <label for="startDate" class="form-label fw-bold">Start Date <span class="text-danger">*</span></label>
                <input type="date" class="form-control" id="startDate" name="startDate" value="<%= offer.startDate.toISOString().split('T')[0] %>" required />
                <small id="startDateError" class="text-danger"></small>
              </div>
              <div class="col-md-6">
                <label for="endDate" class="form-label fw-bold">End Date <span class="text-danger">*</span></label>
                <input type="date" class="form-control" id="endDate" name="endDate" value="<%= offer.endDate.toISOString().split('T')[0] %>" required />
                <small id="endDateError" class="text-danger"></small>
              </div>
            </div>

            <!-- Offer Type -->
            <div class="mb-4">
              <label for="offerType" class="form-label fw-bold">Apply To <span class="text-danger">*</span></label>
              <select class="form-control" id="offerType" name="offerType" required>
                <option value="product"   <%= offer.offerType === 'product'   ? 'selected' : '' %>>Specific Product</option>
                <option value="category"  <%= offer.offerType === 'category'  ? 'selected' : '' %>>Specific Category</option>
                <option value="all"       <%= offer.offerType === 'all'       ? 'selected' : '' %>>All Products</option>
                <option value="referral"  <%= offer.offerType === 'referral'  ? 'selected' : '' %>>Referral Bonus</option>
              </select>
              <small id="offerTypeError" class="text-danger"></small>
            </div>

            <!-- Product Group -->
            <div class="mb-4" id="productGroup">
              <label for="product" class="form-label fw-bold">Product</label>
              <select class="form-control" id="product" name="product">
                <option value="">None</option>
                <option value="all" <%= (offer.product === 'all' || offer.applyToAllProducts) ? 'selected' : '' %>>All Products</option>
                <% products.forEach(p => { %>
                  <option value="<%= p._id %>" <%= (offer.product && offer.product.toString() === p._id.toString()) ? 'selected' : '' %>>
                    <%= p.name %>
                  </option>
                <% }) %>
              </select>
              <small id="productError" class="text-danger"></small>
            </div>

            <!-- Category Group -->
            <div class="mb-4" id="categoryGroup">
              <label for="category" class="form-label fw-bold">Category</label>
              <select class="form-control" id="category" name="category">
                <option value="">None</option>
                <option value="all" <%= (offer.category === 'all' || offer.applyToAllCategories) ? 'selected' : '' %>>All Categories</option>
                <% categories.forEach(c => { %>
                  <option value="<%= c._id %>" <%= (offer.category && offer.category.toString() === c._id.toString()) ? 'selected' : '' %>>
                    <%= c.categoryName %>
                  </option>
                <% }) %>
              </select>
              <small id="categoryError" class="text-danger"></small>
            </div>

            <!-- Active Checkbox -->
            <div class="form-check mb-4">
              <input type="checkbox" class="form-check-input" id="isActive" name="isActive" <%= offer.isActive ? 'checked' : '' %> />
              <label class="form-check-label" for="isActive">Offer is Active</label>
            </div>

            <!-- Buttons -->
            <div class="d-flex gap-3 mt-4">
              <button type="submit" class="btn product-btn flex-grow-1 py-2 fw-bold">Update Offer</button>
              <button type="button" class="btn btn-outline-dark flex-grow-1 py-2" onclick="clearFields()">Clear</button>
              <a href="/admin/offers" class="btn btn-outline-secondary flex-grow-1 py-2 text-center">Cancel</a>
            </div>
          </form>
        </div>
      </div>
    </main>
  </div>

  <!-- Scripts -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <script>
    // Real-time Validation + Submit
    const inputs = {
      name: document.getElementById("name"),
      discountType: document.getElementById("discountType"),
      discountValue: document.getElementById("discountValue"),
      description: document.getElementById("description"),
      startDate: document.getElementById("startDate"),
      endDate: document.getElementById("endDate"),
      offerType: document.getElementById("offerType"),
      product: document.getElementById("product"),
      category: document.getElementById("category")
    };

    const errors = {
      name: document.getElementById("nameError"),
      discountType: document.getElementById("discountTypeError"),
      discountValue: document.getElementById("discountValueError"),
      description: document.getElementById("descriptionError"),
      startDate: document.getElementById("startDateError"),
      endDate: document.getElementById("endDateError"),
      offerType: document.getElementById("offerTypeError"),
      product: document.getElementById("productError"),
      category: document.getElementById("categoryError")
    };

    // Real-time validation
    Object.values(inputs).forEach(input => {
      if (input) {
        input.addEventListener("input", () => validateField(input));
        input.addEventListener("blur", () => validateField(input));
      }
    });

    function validateField(input) {
      const value = input.value.trim();
      const id = input.id;
      let errorMsg = "";

      if (id === "name") {
        if (!value) errorMsg = "Offer name is required";
        else if (value.length < 3 || value.length > 50) errorMsg = "Name must be 3–50 characters";
      }
      else if (id === "discountType") {
        if (!value) errorMsg = "Select discount type";
      }
      else if (id === "discountValue") {
        const num = parseFloat(value);
        const type = inputs.discountType?.value;
        if (!value) errorMsg = "Discount value is required";
        else if (isNaN(num) || num <= 0) errorMsg = "Enter positive value";
        else if (type === "percentage" && (num < 1 || num > 100)) errorMsg = "Percentage: 1–100";
      }
      else if (id === "description") {
        if (!value) errorMsg = "Description is required";
        else if (value.length < 10 || value.length > 200) errorMsg = "Description: 10–200 characters";
      }
      else if (id === "startDate" || id === "endDate") {
        const start = new Date(inputs.startDate?.value || "");
        const end = new Date(inputs.endDate?.value || "");
        if (!value) errorMsg = "Date is required";
        else if (id === "endDate" && end <= start && start) errorMsg = "End date must be after start";
      }
      else if (id === "offerType") {
        if (!value) errorMsg = "Select offer target";
      }
      else if (id === "product" && inputs.offerType?.value === "product" && !value) {
        errorMsg = "Select a product";
      }
      else if (id === "category" && inputs.offerType?.value === "category" && !value) {
        errorMsg = "Select a category";
      }

      errors[id].textContent = errorMsg;
      input.classList.toggle("is-invalid", !!errorMsg);
    }

    // Full form validation
    function isFormValid() {
      let valid = true;
      Object.values(inputs).forEach(input => {
        if (input) {
          validateField(input);
          if (input.classList.contains("is-invalid")) valid = false;
        }
      });
      return valid;
    }

// Submit handler
document.getElementById("offerForm")?.addEventListener("submit", async function(e) {
  e.preventDefault();

  if (!isFormValid()) {
    Swal.fire({
      icon: "warning",
      title: "Invalid Input",
      text: "Please fix the highlighted errors",
      timer: 2500,
      showConfirmButton: false
    });
    return;
  }

  const formData = new FormData(this);
  let data = Object.fromEntries(formData);


  if (data.offerType !== "category" && data.offerType !== "all") {
    delete data.category;
  }

  if (data.category === "" || data.category === "None") {
    delete data.category;
  }

  if (data.offerType !== "product" && data.offerType !== "all") {
    delete data.product;
  }
  if (data.product === "" || data.product === "None") {
    delete data.product;
  }


  try {
    const res = await fetch(this.action, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(data)
    });

    const result = await res.json();

    if (result.success) {
      await Swal.fire({
        icon: "success",
        title: "Success",
        text: "Offer updated successfully!",
        timer: 2000,
        showConfirmButton: false
      });
      window.location.href = "/admin/offers";
    } else {
      Swal.fire({
        icon: "error",
        title: "Error",
        text: result.message || "Failed to update offer"
      });
    }
  } catch (err) {
    Swal.fire({
      icon: "error",
      title: "Network Error",
      text: "Failed to connect. Please try again."
    });
  }
});

    // Clear form
    function clearFields() {
      document.querySelectorAll("input, textarea, select").forEach(el => {
        if (el.type === "checkbox") el.checked = false;
        else el.value = "";
        el.classList.remove("is-invalid");
      });
      document.querySelectorAll(".text-danger").forEach(el => el.textContent = "");
    }

    // Conditional visibility for product/category groups
    function toggleOfferGroups() {
      const val = document.getElementById("offerType")?.value;
      if (!val) return;

      document.getElementById("productGroup").style.display = 
        (val === "product" || val === "all") ? "block" : "none";

      document.getElementById("categoryGroup").style.display = 
        (val === "category" || val === "all") ? "block" : "none";
    }

    // Initialize on load + listen for changes
    document.addEventListener("DOMContentLoaded", toggleOfferGroups);
    document.getElementById("offerType")?.addEventListener("change", toggleOfferGroups);

    // Discount type change handler
    document.getElementById("discountType")?.addEventListener("change", function() {
      const val = this.value;
      const input = document.getElementById("discountValue");
      if (val === "percentage") {
        input.min = 1;
        input.max = 100;
        input.step = 1;
      } else {
        input.removeAttribute("max");
        input.min = 0.01;
        input.step = 0.01;
      }
    });

    // Initialize everything
    document.getElementById("discountType")?.dispatchEvent(new Event("change"));
  </script>
</body>
</html>