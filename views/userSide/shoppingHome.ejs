            class="h3 fw-bold mb-0"
            style="font-family: 'Bebas Neue', sans-serif; font-size: 1.9rem; letter-spacing: 0.02em"
          >
            Most Selling Products
          </h2>
        </div>
        <a href="/products" class="section-view-all">View All →</a>
      </div>
      <div class="products-slider-container position-relative">
        <button
          class="rail-prev-btn position-absolute top-50 start-0 translate-middle-y bg-white rounded-circle shadow-sm border-0 p-2"
          type="button"
          data-target="most-selling-rail"
        >
          <i class="fas fa-chevron-left text-dark"></i>
        </button>
        <div class="products-row d-flex gap-3 rail-scroll" id="most-selling-rail">
          <% const mostSelling = (products || []).slice().sort((a,b) => (b.totalSold||0) -
          (a.totalSold||0)).slice(0,6) %> <% mostSelling.forEach(product => { %>
          <div class="product-slide flex-shrink-0" style="width: 200px">
            <div
              class="product-card glass-card shadow-sm border-0 rounded-3 overflow-hidden modern-product-card <%= product.stock === 0 ? 'opacity-50' : '' %>"
              data-product="<%= product._id %>"
              data-stock="<%= product.stock %>"
            >
              <div
                class="product-image-container position-relative overflow-hidden"
                style="height: 165px"
              >
                <a href="/product-details/<%= product._id %>">
                  <img
                    src="/uploads/<%= product.photos[0].filename %>"
                    alt="<%= product.name %>"
                    class="product-image w-100 h-100 object-fit-cover"
                  />
                </a>
                <div
                  class="category-badge position-absolute top-2 start-2 bg-black text-white px-2 py-1 rounded-pill small fw-bold"
                >
                  🔥 Top
                </div>
                <button
                  class="wishlist-btn position-absolute top-2 end-2 p-0 border-0 bg-white rounded-circle d-flex align-items-center justify-content-center"
                  onclick="toggleWishlist(this)"
                  style="width: 28px; height: 28px"
                >
                  <% const isInWishlist = wishlistProducts.find(item => item._id.toString() ===
                  product._id.toString()); %>
                  <i
                    class="fa fa-heart <%= isInWishlist ? 'text-danger fas' : 'text-muted far' %> fs-6"
                  ></i>
                </button>
                <div
                  class="out-of-stock-overlay position-absolute top-0 start-0 end-0 bottom-0 bg-dark bg-opacity-70 d-flex align-items-center justify-content-center <%= product.stock === 0 ? 'd-flex' : 'd-none' %>"
                >
                  <div
                    class="out-of-stock-text bg-white text-black px-3 py-2 rounded-pill fw-bold small"
                  >
                    Out of Stock
                  </div>
                </div>
              </div>
              <div class="product-details p-2 d-flex flex-column flex-grow-1">
                <div class="flex-grow-1">
                  <h3 class="product-name small fw-semibold mb-1"><%= product.name %></h3>
                  <div class="stars small mb-1">
                    <% for (let i = 1; i <= 5; i++) { %>
                    <i
                      class="fa<%= i <= product.averageRating ? 's' : 'r' %> fa-star text-warning"
                    ></i>
                    <% } %>
                  </div>
                  <div class="price-container mb-2">
                    <% if (product.offer && product.price !== product.currentPrice) { %>
                    <div class="d-flex align-items-center gap-1 mb-1">
                      <span class="small text-muted text-decoration-line-through"
                        >₹<%= product.price.toFixed(2) %></span
                      >
                      <span class="fw-bold">₹<%= product.currentPrice.toFixed(2) %></span>
                    </div>
                    <div class="offer-info bg-black text-white px-2 py-1 rounded small">
                      🎉 <%= product.offer.name || 'Special Offer' %> — Save <%=
                      Math.round(((product.price - product.currentPrice) / product.price) * 100)
                      %>%!
                    </div>
                    <% } else { %>
                    <span class="fw-bold">₹<%= product.price.toFixed(2) %></span>
                    <% } %>
                  </div>
                </div>
                <div class="button-group d-flex gap-1">
                  <button
                    class="btn-add-cart flex-fill btn btn-outline-dark btn-sm p-1 fw-bold text-uppercase small"
                    data-product-id="<%= product._id %>"
                  >
                    <i class="fas fa-cart-plus me-1"></i>Cart
                  </button>
                  <button
                    class="btn-buy-now flex-fill btn btn-dark btn-sm p-1 fw-bold text-uppercase small"
                    data-product-id="<%= product._id %>"
                  >
                    Buy
                  </button>
                </div>
              </div>
            </div>
          </div>
          <% }) %>
        </div>
        <button
          class="rail-next-btn position-absolute top-50 end-0 translate-middle-y bg-white rounded-circle shadow-sm border-0 p-2"
          type="button"
          data-target="most-selling-rail"
        >
          <i class="fas fa-chevron-right text-dark"></i>
        </button>
      </div>
    </div>
  </section>

