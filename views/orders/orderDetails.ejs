<%- include('../includes/userHead.ejs') %>
<link rel="stylesheet" href="/css/orderHistory.css" />

<%- include('../includes/userHeader.ejs') %>

<main class="main">
  <% if (user) { %>
  <aside class="sidebar">
    <div class="profile-section">
      <div class="avatar">
        <img
          src="<%= user.photo && user.photo.length > 0 ? '/uploads/' + user.photo[0].filename : '/images/avatar.jpg' %>"
          alt="Profile Avatar"
        />
      </div>
      <ul class="profile-links">
        <li><a href="/profile">User Profile</a></li>
        <li><a href="/address">Address</a></li>
        <li><a href="/order-history">Order History</a></li>
        <li><a href="/change-password">Change Password</a></li>
        <li><a href="/wallet">Wallet</a></li>
      </ul>
    </div>
  </aside>
  <div class="content">
    <% if (order) { %>
    <div class="container">
      <div class="d-flex justify-content-between align-items-center py-3">
        <h2 class="page-title">Order #<%= order.uniqueOrderId %></h2>
      </div>
      <div class="row">
        <div class="col-lg-8">
          <div class="card mb-4">
            <div class="card-body">
              <div class="mb-3 d-flex justify-content-between">
                <div>
                  <span class="me-3"><%= new Date(order.createdAt).toDateString() %></span>
                  <span class="me-3">#<%= order.uniqueOrderId %></span>
                </div>
                <div class="invoice">
                  <!-- Invoice Button – only show if at least one item is delivered -->
                  <% const hasDeliveredItem = order.items.some(item => item.status === 'Delivered');
                  %>
                  <% if (hasDeliveredItem) { %>
                  <button
                    class="btn btn-dark w-100 mb-3"
                    data-bs-toggle="modal"
                    data-bs-target="#invoiceModal"
                  >
                    <i class="fas fa-file-invoice me-2"></i> View/Download Invoice
                  </button>
                  <% } %>
                </div>
              </div>
              <div class="table-responsive">
                <table class="table table-borderless">
                  <thead>
                    <tr>
                      <th>Product</th>
                      <th>Qty</th>
                      <th>Price</th>
                      <th>Ordered</th>
                      <th>Shipped</th>
                      <th>Delivered</th>
                      <th>Cancelled</th>
                      <th>Status</th>
                      <th>Action</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% order.items.forEach(item => { %>
                    <tr>
                      <td>
                        <div class="d-flex mb-2">
                          <div class="flex-shrink-0">
                            <img
                              src="/uploads/<%= item.productId.photos[0].filename %>"
                              alt="<%= item.productId.name %>"
                              class="img-fluid rounded"
                              width="60"
                            />
                          </div>
                          <div class="flex-grow-1 ms-3">
                            <h6 class="mb-1">
                              <a
                                href="/product-details/<%= item.productId._id %>"
                                class="text-reset"
                                ><%= item.productId.name %></a
                              >
                            </h6>
                          </div>
                        </div>
                      </td>
                      <td><%= item.quantity %></td>
                      <td class="text-end">
                        ₹<%= item.productId.currentPrice || item.productId.price %>
                      </td>
                      <td>
                        <%= new Date(order.createdAt).toLocaleString('en-IN', {dateStyle: 'short', timeStyle: 'short'}) %>
                      </td>
                      <td>
                        <%= item.shippedAt ? new Date(item.shippedAt).toLocaleString('en-IN', {dateStyle: 'short', timeStyle: 'short'}) : '-' %>
                      </td>
                      <td>
                        <%= item.deliveredAt ? new Date(item.deliveredAt).toLocaleString('en-IN', {dateStyle: 'short', timeStyle: 'short'}) : '-' %>
                      </td>
                      <td>
                        <%= item.cancelledAt ? new Date(item.cancelledAt).toLocaleString('en-IN', {dateStyle: 'short', timeStyle: 'short'}) : '-' %>
                      </td>
                      <td>
                        <span class="badge bg-info rounded-pill"><%= item.status %></span>
                        <% if (item.status === 'Delivered') { %>
                        <a
                          href="/review/<%= order._id %>/<%= item.productId._id %>"
                          class="btn btn-sm review-btn ms-1"
                          >Review</a
                        >
                        <% } %>
                      </td>
                      <td>
                        <% if (item.status === 'Pending') { %>
                        <form
                          action="/cancel-item/<%= order._id %>/<%= item.productId._id %>"
                          method="POST"
                          class="cancel-item-form"
                          style="display: inline"
                        >
                          <button type="button" class="btn btn-danger btn-sm cancel-item-btn">
                            Cancel Item
                          </button>
                        </form>
                        <% } else { %>
                        <span class="text-muted"><%= item.status %></span>
                        <% } %>
                      </td>
                    </tr>
                    <% }) %>
                  </tbody>
                  <tfoot class="table-light">
                    <tr>
                      <td colspan="6" class="text-end">
                        <strong>Discount (<%= order.couponCode || 'N/A' %>)</strong>
                      </td>
                      <td class="text-end text-danger">
                        -₹<%= order.priceDetails.discountAmount %>
                      </td>
                    </tr>
                    <tr>
                      <td colspan="6" class="text-end">
                        <strong>Subtotal</strong>
                      </td>
                      <td class="text-end">₹<%= order.priceDetails.subTotal %></td>
                    </tr>
                    <tr>
                      <td colspan="6" class="text-end">
                        <strong>Delivery Charge</strong>
                      </td>
                      <td class="text-end">₹<%= order.priceDetails.deliveryCharge %></td>
                    </tr>
                    <tr>
                      <td colspan="6" class="text-end">
                        <strong>Sales Tax</strong>
                      </td>
                      <td class="text-end">₹<%= order.priceDetails.salesTax %></td>
                    </tr>
                    <tr class="fw-bold">
                      <td colspan="6" class="text-end">
                        <strong>Total</strong>
                      </td>
                      <td class="text-end">₹<%= order.totalCost %></td>
                    </tr>
                  </tfoot>
                </table>
              </div>
            </div>
          </div>
          <div class="row">
            <div class="col-md-6">
              <div class="card">
                <div class="card-body">
                  <h6 class="card-title">Payment Method</h6>
                  <p class="card-text">
                    <%= order.paymentMethod %><br />Total: ₹<%= order.totalCost
                    %>
                  </p>
                  <span
                    class="badge <%= order.paymentStatus === 'confirmed' ? 'bg-success' : 'bg-warning' %> rounded-pill"
                  >
                    <%= order.paymentStatus === 'confirmed' ? 'PAID' : 'PENDING' %>
                  </span>
                  <% if (order.paymentMethod === 'online' && order.paymentStatus
                  === 'pending') { %>
                  <button
                    class="btn btn-secondary btn-sm mt-2"
                    id="retry-payment"
                    data-order-id="<%= order._id %>"
                  >
                    Retry Payment
                  </button>
                  <% } %>
                </div>
              </div>
            </div>
            <div class="col-md-6">
              <div class="card">
                <div class="card-body">
                  <h6 class="card-title">Billing Address</h6>
                  <address>
                    <strong><%= order.deliveryAddress.address.name %></strong><br />
                    <%= order.deliveryAddress.address.houseName %><br />
                    <%= order.deliveryAddress.address.street %>,
                    <%=
                    order.deliveryAddress.address.city %><br />
                    <%= order.deliveryAddress.address.district %>,
                    <%=
                    order.deliveryAddress.address.state %>
                    <%=
                    order.deliveryAddress.address.pinCode %>
                  </address>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="col-lg-4">
          <div class="card">
            <div class="card-body">
              <h6 class="card-title">Shipping Address</h6>
              <address>
                <strong><%= order.deliveryAddress.address.name %></strong><br />
                <%= order.deliveryAddress.address.houseName %><br />
                <%= order.deliveryAddress.address.street %>,
                <%=
                order.deliveryAddress.address.city %><br />
                <%= order.deliveryAddress.address.district %>,
                <%=
                order.deliveryAddress.address.state %>
                <%=
                order.deliveryAddress.address.pinCode %>
              </address>
            </div>
          </div>
        </div>
      </div>
    </div>
    <% } else { %>
    <div class="empty-state">
      <h2 class="page-title">No Order Found</h2>
      <a href="/order-history" class="btn product-btn">View Order History</a>
    </div>
    <% } %>
  </div>
  <% } %>
</main>

<!-- Invoice Modal -->
<div
  class="modal fade"
  id="invoiceModal"
  tabindex="-1"
  aria-labelledby="invoiceModalLabel"
  aria-hidden="true"
>
  <div class="modal-dialog modal-xl">
    <div class="modal-content">
      <div class="modal-header bg-dark text-white">
        <h5 class="modal-title" id="invoiceModalLabel">
          Invoice – Order #<%= order.uniqueOrderId %> <% if (order.items.some(i => i.status !==
          'Delivered')) { %>
          <small class="text-warning ms-2">(Partial – Delivered Items Only)</small>
          <% } %>
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-4">
        <!-- Header -->
        <div class="row mb-4 align-items-center">
          <div class="col-6">
            <img src="/test.jpg" alt="Logo" height="50" />
            <h4 class="mt-2">Tax Invoice</h4>
          </div>
          <div class="col-6 text-end">
            <p class="mb-0">
              <strong>Order ID:</strong>
              <%= order.uniqueOrderId %>
            </p>
            <p>
              <strong>Date:</strong>
              <%= new Date(order.createdAt).toLocaleDateString('en-IN') %>
            </p>
          </div>
        </div>

        <!-- Addresses -->
        <div class="row mb-4">
          <div class="col-md-6">
            <strong>Billed To:</strong><br />
            <%= order.deliveryAddress.address.name %><br />
            <%= order.deliveryAddress.address.houseName %>,
            <%= order.deliveryAddress.address.street %><br />
            <%= order.deliveryAddress.address.city %>,
            <%= order.deliveryAddress.address.district %><br />
            <%= order.deliveryAddress.address.state %>
            -
            <%= order.deliveryAddress.address.pinCode %>
          </div>
          <div class="col-md-6 text-md-end">
            <strong>Shipped To:</strong><br />
            Same as billing address
          </div>
        </div>

        <!-- Items Table – only delivered -->
        <div class="table-responsive">
          <table class="table table-bordered">
            <thead class="table-dark">
              <tr>
                <th>#</th>
                <th>Item</th>
                <th>Qty</th>
                <th>Rate</th>
                <th>Amount</th>
              </tr>
            </thead>
            <tbody>
              <% let invoiceSubtotal = 0; let index = 1; order.items.forEach(item => { if
              (item.status === 'Delivered') { const price = item.productId.currentPrice ||
              item.productId.price; const amount = price * item.quantity; invoiceSubtotal += amount;
              %>
              <tr>
                <td><%= index++ %></td>
                <td><%= item.productId.name %></td>
                <td><%= item.quantity %></td>
                <td>₹<%= price.toFixed(2) %></td>
                <td>₹<%= amount.toFixed(2) %></td>
              </tr>
              <% }
                }); %>
            </tbody>
            <tfoot>
              <tr>
                <td colspan="4" class="text-end fw-bold">Subtotal (Delivered Items)</td>
                <td class="fw-bold">₹<%= invoiceSubtotal.toFixed(2) %></td>
              </tr>
              <% if (order.couponCode && order.priceDetails.discountAmount > 0) { %>
              <tr>
                <td colspan="4" class="text-end text-danger fw-bold">
                  Coupon Discount (<%= order.couponCode %>)
                </td>
                <td class="text-danger">-₹<%= order.priceDetails.discountAmount.toFixed(2) %></td>
              </tr>
              <% } %>
              <tr>
                <td colspan="4" class="text-end fw-bold">Delivery Charge</td>
                <td>₹<%= order.priceDetails.deliveryCharge.toFixed(2) %></td>
              </tr>
              <tr>
                <td colspan="4" class="text-end fw-bold">Sales Tax</td>
                <td>₹<%= order.priceDetails.salesTax.toFixed(2) %></td>
              </tr>
              <tr class="table-active">
                <td colspan="4" class="text-end fw-bold fs-5">Grand Total (Paid at Checkout)</td>
                <td class="fw-bold fs-5">₹<%= order.totalCost.toFixed(2) %></td>
              </tr>
            </tfoot>
          </table>
        </div>

        <!-- Footer Note -->
        <div class="mt-4 text-muted small">
          <p>
            <strong>Note:</strong> This invoice shows only delivered items. Full order amount was
            charged at checkout.
          </p>
          <p>
            Payment Method: <%= order.paymentMethod.toUpperCase() %> | Status: <%=
            order.paymentStatus.toUpperCase() %>
          </p>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
        <button type="button" class="btn btn-dark" onclick="window.print()">
          <i class="fas fa-print me-2"></i> Print / Download
        </button>
      </div>
    </div>
  </div>
</div>

<%- include('../includes/userFooter.ejs') %>
<%-
include('../includes/userScripts.ejs') %>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script>
  document.addEventListener("DOMContentLoaded", function () {
    const retryButton = document.getElementById("retry-payment");
    if (retryButton) {
      retryButton.addEventListener("click", async () => {
        const orderId = retryButton.dataset.orderId;
        try {
          const response = await fetch("/retry-payment", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ orderId }),
          });
          const data = await response.json();
          if (data.success) {
            const options = {
              key: "rzp_test_Tb5YYNqwWeIaYk",
              amount: data.razorpayOrder.amount,
              currency: data.razorpayOrder.currency,
              name: "ShoeZone",
              description: "Order Description",
              order_id: data.razorpayOrder.id,
              handler: async function (response) {
                if (response.razorpay_payment_id) {
                  response.orderId = data.orderId;
                  const verifyResponse = await fetch("/checkout/verify", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(response),
                  });
                  const verifyData = await verifyResponse.json();
                  if (verifyData.message === "Payment verified") {
                    window.location.href = `/order-details/${verifyData.orderId}`;
                  } else {
                    Swal.fire("Error", "Payment verification failed!", "error");
                  }
                } else {
                  window.location.href = `/order-details/${data.orderId}?payment=pending`;
                }
              },
              prefill: {
                name: "User Name",
                email: "user@example.com",
                contact: "9876543210",
              },
              notes: { address: "Address Details" },
            };
            const razorpay = new window.Razorpay(options);
            razorpay.open();
            razorpay.on("payment.failed", (response) => {
              window.location.href = `/order-details/${data.orderId}?payment=failed`;
            });
            razorpay.on("payment.dismissed", () => {
              window.location.href = `/order-details/${data.orderId}?payment=failed`;
            });
          } else {
            Swal.fire("Error", data.error || "Retry failed.", "error");
          }
        } catch (error) {
          Swal.fire("Error", "Network error during retry.", "error");
        }
      });
    }

    function setCategory(category) {
      const selectedCategory = document.getElementById("selectedCategory");
      if (selectedCategory) selectedCategory.value = category;
      const dropdownText = document.querySelector(".dropdown-toggle-text");
      if (dropdownText)
        dropdownText.textContent = category.charAt(0).toUpperCase() + category.slice(1);
    }
  });
</script>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    document.querySelectorAll(".cancel-item-btn").forEach((button) => {
      button.addEventListener("click", function () {
        const form = this.closest("form");

        Swal.fire({
          title: "Are you sure?",
          text: "Do you want to cancel this item? Refund will be processed if applicable.",
          icon: "warning",
          showCancelButton: true,
          confirmButtonColor: "#d33",
          cancelButtonColor: "#6c757d",
          confirmButtonText: "Yes, cancel it!",
          cancelButtonText: "No, keep it",
        }).then((result) => {
          if (result.isConfirmed) {
            form.submit();
          }
        });
      });
    });
  });
</script>
