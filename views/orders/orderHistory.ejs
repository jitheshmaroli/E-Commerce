<%- include('../includes/userHead.ejs') %>
<link rel="stylesheet" href="/css/orderHistory.css" />

<%- include('../includes/userHeader.ejs') %>

<main class="main">
  <% if (user) { %>
  <aside class="sidebar">
    <div class="profile-section">
      <div class="avatar">
        <img
          src="<%= user.photo && user.photo.length > 0 ? '/uploads/' + user.photo[0].filename : '/images/avatar.jpg' %>"
          alt="Profile Avatar" />
      </div>
      <ul class="profile-links">
        <li><a href="/profile">User Profile</a></li>
        <li><a href="/address">Address</a></li>
        <li><a href="/order-history">Order History</a></li>
        <li><a href="/change-password">Change Password</a></li>
        <li><a href="/wallet">Wallet</a></li>
      </ul>
    </div>
  </aside>
  <section class="content">
    <div class="container py-5">
      <% if (orders.length > 0) { %>
      <div class="row">
        <% orders.forEach(order => { %>
        <div class="col-12 mb-4">
          <div class="card shadow-sm">
            <div class="card-body">
              <div class="row align-items-center">
                <div class="col-md-3">
                  <p class="mb-1">
                    <strong>Date:</strong> <%= new
                    Date(order.createdAt).toDateString() %>
                  </p>
                  <p class="mb-1">
                    <strong>ID:</strong> #<%= order.uniqueOrderId %>
                  </p>
                  <p class="mb-0">
                    <strong>Total:</strong> ₹<%= order.totalCost %>
                  </p>
                </div>
                <div class="col-md-6">
                  <div class="row">
                    <% order.items.slice(0, 3).forEach(item => { %>
                    <div class="col-4 mb-2">
                      <div class="card h-100 border-0">
                        <img
                          src="/uploads/<%= item.productId.photos[0].filename %>"
                          class="card-img-top"
                          alt="<%= item.productId.name %>"
                          style="height: 100px; object-fit: cover" />
                        <div class="card-body p-2">
                          <p class="card-text small mb-1">
                            <%= item.productId.name %>
                          </p>
                          <p class="card-text small mb-0">
                            Qty: <%= item.quantity %>
                          </p>
                          <p class="card-text small mb-0">
                            ₹<%= item.productId.price %>
                          </p>
                          <span
                            class="badge bg-<%= item.status === 'Delivered' ? 'success' : item.status === 'Pending' ? 'warning' : 'danger' %> rounded-pill"
                            ><%= item.status %></span
                          >
                        </div>
                      </div>
                    </div>
                    <% }) %> <% if (order.items.length > 3) { %>
                    <div class="col-12">
                      <p class="text-muted small">
                        ... and <%= order.items.length - 3 %> more items
                      </p>
                    </div>
                    <% } %>
                  </div>
                </div>
                <div class="col-md-3 text-md-end">
                  <a
                    href="/order-details/<%= order._id %>"
                    class="btn btn-primary btn-sm mb-2 w-100"
                    >View Details</a
                  >
                  <% if (order.items.some(item => item.status === 'Pending')) {
                  %>
                  <form
                    action="/cancel-order/<%= order._id %>"
                    method="POST"
                    style="display: inline">
                    <button
                      type="submit"
                      class="btn btn-danger btn-sm w-100"
                      onclick="return confirm('Cancel entire order?')">
                      Cancel Order
                    </button>
                  </form>
                  <% } %>
                </div>
              </div>
              <hr />
              <div class="row">
                <div class="col-md-12">
                  <div class="progress mb-2" style="height: 6px">
                    style="width: <%= order.items[0]?.status === 'Delivered' ?
                    '100%' : order.items[0]?.status === 'Shipped' ? '50%' :
                    '25%' %>"
                  </div>
                  <div class="d-flex justify-content-between small text-muted">
                    <span>Pending</span>
                    <span>Shipped</span>
                    <span>Delivered</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
      <nav class="pagination" aria-label="Order History Pagination">
        <ul class="pagination justify-content-end">
          <% for (let i = 1; i <= totalPages; i++) { %>
          <li class="page-item <%= i === currentPage ? 'active' : '' %>">
            <a class="page-link" href="/order-history?page=<%= i %>"
              ><%= i %></a
            >
          </li>
          <% } %>
        </ul>
      </nav>
      <% } else { %>
      <div class="empty-state text-center py-5">
        <h2 class="page-title">No Orders Found</h2>
        <p>Your order history is empty. Start shopping!</p>
        <a href="/products" class="btn product-btn">Shop Now</a>
      </div>
      <% } %>
    </div>
  </section>
  <% } %>
</main>

<%- include('../includes/userFooter.ejs') %> <%-
include('../includes/userScripts.ejs') %>

<script>
  function setCategory(category) {
    const selectedCategory = document.getElementById("selectedCategory");
    if (selectedCategory) selectedCategory.value = category;
    const dropdownText = document.querySelector(".dropdown-toggle-text");
    if (dropdownText)
      dropdownText.textContent =
        category.charAt(0).toUpperCase() + category.slice(1);
  }
</script>
