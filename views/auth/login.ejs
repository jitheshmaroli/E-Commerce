<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Log In – ShoeZone</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <link rel="stylesheet" href="/css/auth-shared.css" />
</head>
<body>

<div class="auth-page">

  <!-- ── Brand Panel ── -->
  <div class="auth-panel-brand">
    <div class="auth-brand-top">
      <a href="/" class="auth-logo-wrap">
        <img src="/test.jpg" alt="ShoeZone" class="auth-logo-img" />
        <span class="auth-logo-text">Shoe<em>Zone</em></span>
      </a>
    </div>
    <div class="auth-panel-mid">
      <div class="auth-panel-tagline">
        Every Step<br><span>Starts</span><br>Here.
      </div>
      <p class="auth-panel-sub">Premium footwear for every occasion. Sign in and find your next favourite pair.</p>
    </div>
    <div class="auth-panel-bottom">
      <div class="auth-stat"><div class="auth-stat-num">10K+</div><div class="auth-stat-label">Styles</div></div>
      <div class="auth-stat"><div class="auth-stat-num">4.9★</div><div class="auth-stat-label">Rating</div></div>
      <div class="auth-stat"><div class="auth-stat-num">Free</div><div class="auth-stat-label">Delivery</div></div>
    </div>
  </div>

  <!-- ── Form Panel ── -->
  <div class="auth-panel-form">
    <div class="auth-form-scroll">
      <div class="auth-form-inner">

        <div class="auth-form-title">Welcome Back</div>
        <div class="auth-form-sub">Sign in to your ShoeZone account</div>

        <% if (message) { %>
        <div class="auth-alert auth-alert-error" id="authAlert">
          <i class="fas fa-circle-exclamation"></i>
          <span><%= message %></span>
          <button class="auth-alert-close" onclick="this.closest('.auth-alert').remove()">&times;</button>
        </div>
        <% } %>

        <form action="/login" method="POST" id="loginForm" novalidate>

          <div class="auth-field">
            <label for="email">Email Address</label>
            <input type="email" id="email" name="email" required autocomplete="email" autofocus />
            <span class="auth-field-error" id="emailError">Please enter a valid email address.</span>
          </div>

          <div class="auth-field">
            <label for="password">Password</label>
            <div class="auth-pw-wrap">
              <input type="password" id="password" name="password" required />
              <button type="button" class="auth-pw-toggle" id="togglePw" aria-label="Toggle password">
                <i class="fas fa-eye-slash"></i>
              </button>
            </div>
          </div>

          <button type="submit" class="btn-auth-submit">Log In</button>

          <div class="auth-divider">or</div>

          <a href="/auth/google" class="btn-auth-google">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
            Continue with Google
          </a>

          <div class="auth-links">
            <a href="/forgot-password">Forgot your password?</a>
            <a href="/signup">Don't have an account? <strong>Sign up</strong></a>
          </div>

        </form>
      </div>
    </div>
    <div class="auth-form-footer">© 2026 ShoeZone. All rights reserved.</div>
  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  // Password toggle
  const pw = document.getElementById('password');
  const togglePw = document.getElementById('togglePw');
  togglePw.addEventListener('click', () => {
    const show = pw.type === 'password';
    pw.type = show ? 'text' : 'password';
    togglePw.innerHTML = `<i class="fas fa-eye${show ? '' : '-slash'}"></i>`;
  });

  // Email validation
  const emailInput = document.getElementById('email');
  const emailError = document.getElementById('emailError');
  const emailRe = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  emailInput.addEventListener('input', () => {
    const valid = emailRe.test(emailInput.value.trim());
    emailInput.classList.toggle('is-invalid', !valid && emailInput.value.length > 0);
    emailInput.classList.toggle('is-valid', valid);
    emailError.classList.toggle('visible', !valid && emailInput.value.length > 0);
  });

  document.getElementById('loginForm').addEventListener('submit', e => {
    if (!emailRe.test(emailInput.value.trim())) {
      e.preventDefault();
      emailInput.classList.add('is-invalid');
      emailError.classList.add('visible');
      emailInput.focus();
    }
  });
</script>
</body>
</html>
