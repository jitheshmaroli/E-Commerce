<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Edit Offer</title>

    <link
      rel="stylesheet"
      href="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css"
    />
    <link rel="stylesheet" href="/css/addProduct.css" />
    <style>
      .text-danger {
        display: block;
        margin-top: 5px;
        font-size: 0.875em;
      }
    </style>
  </head>
  <body>
    <nav class="navbar navbar-expand-lg navbar-light bg-light">
      <div class="container-fluid">
        <a class="navbar-brand" href="/admin">
          <img
            src="/test.jpg"
            alt="Logo"
            width="30"
            height="24"
            class="d-inline-block align-text-top"
          />
          SportZilon
        </a>
        <div class="collapse navbar-collapse">
          <ul class="navbar-nav ml-auto">
            <li class="nav-item dropdown">
              <a
                class="nav-link dropdown-toggle"
                href="#"
                id="navbarDropdown"
                role="button"
                data-toggle="dropdown"
                aria-expanded="false"
              >
                ADMIN
              </a>
              <ul class="dropdown-menu dropdown-menu-right">
                <li><a class="dropdown-item" href="#">Action</a></li>
                <li><hr class="dropdown-divider" /></li>
                <li><a class="dropdown-item" href="/admin/logout">Logout</a></li>
              </ul>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <main class="main">
      <aside class="sidebar">
        <div class="p-3">
          <div class="list-group sidebar-list">
            <a href="/admin"
              ><button type="button" class="list-group-item list-group-item-action">HOME</button></a
            >
            <a href="/admin/allproducts"
              ><button type="button" class="list-group-item list-group-item-action">
                ALL PRODUCTS
              </button></a
            >
            <a href="/admin/ordersList"
              ><button type="button" class="list-group-item list-group-item-action">
                ORDERS LIST
              </button></a
            >
            <a href="/admin/usersList"
              ><button type="button" class="list-group-item list-group-item-action">
                USERS LIST
              </button></a
            >
            <a href="/admin/categoryList"
              ><button type="button" class="list-group-item list-group-item-action">
                CATEGORY LIST
              </button></a
            >
            <a href="/admin/couponList"
              ><button type="button" class="list-group-item list-group-item-action">
                COUPON LIST
              </button></a
            >
            <a href="/admin/offers"
              ><button type="button" class="list-group-item list-group-item-action active">
                OFFERS
              </button></a
            >
          </div>
        </div>
      </aside>

      <section class="content">
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/admin/offers">OFFERS LIST</a></li>
            <li class="breadcrumb-item active" aria-current="page">EDIT OFFER</li>
          </ol>
        </nav>

        <div class="container">
          <div class="row justify-content-center">
            <div class="col-lg-8 col-md-10">
              <div class="card shadow-sm">
                <div class="card-header bg-warning text-dark">
                  <h4 class="mb-0">Edit Offer: <%= offer.name %></h4>
                </div>
                <div class="card-body">
                  <form id="offerForm" action="/admin/offers/edit/<%= offer._id %>" method="POST">
                    <div class="form-row">
                      <div class="form-group col-md-6">
                        <label for="name">Offer Name <span class="text-danger">*</span></label>
                        <input
                          type="text"
                          class="form-control"
                          id="name"
                          name="name"
                          value="<%= offer.name %>"
                          required
                          maxlength="50"
                        />
                        <small class="text-danger" id="nameError"></small>
                      </div>

                      <div class="form-group col-md-6">
                        <label for="discountType"
                          >Discount Type <span class="text-danger">*</span></label
                        >
                        <select class="form-control" id="discountType" name="discountType" required>
                          <option value="">Select Type</option>
                          <option value="percentage">
                            <% if (offer.discountType === 'percentage') { %> selected="selected" <%
                            } %> >Percentage (%)
                          </option>
                          <option value="amount">
                            <% if (offer.discountType === 'amount') { %> selected="selected" <% } %>
                            >Fixed Amount (₹)
                          </option>
                        </select>
                        <small class="text-danger" id="discountTypeError"></small>
                      </div>
                    </div>

                    <div class="form-group">
                      <label for="discountValue"
                        >Discount Value <span class="text-danger">*</span></label
                      >
                      <input
                        type="number"
                        class="form-control"
                        id="discountValue"
                        name="discountValue"
                        value="<%= offer.discountValue %>"
                        required
                        step="0.01"
                        min="0"
                      />
                      <small class="form-text text-muted"
                        >Percentage: 1–100 | Amount: any positive value</small
                      >
                      <small class="text-danger" id="discountValueError"></small>
                    </div>

                    <div class="form-group">
                      <label for="description"
                        >Description <span class="text-danger">*</span></label
                      >
                      <textarea
                        class="form-control"
                        id="description"
                        name="description"
                        rows="4"
                        required
                        maxlength="200"
                      >
<%= offer.description %>
</textarea
                      >
                      <small class="text-danger" id="descriptionError"></small>
                    </div>

                    <div class="form-row">
                      <div class="form-group col-md-6">
                        <label for="startDate">Start Date <span class="text-danger">*</span></label>
                        <input
                          type="date"
                          class="form-control"
                          id="startDate"
                          name="startDate"
                          value="<%= offer.startDate.toISOString().split('T')[0] %>"
                          required
                        />
                        <small class="text-danger" id="startDateError"></small>
                      </div>
                      <div class="form-group col-md-6">
                        <label for="endDate">End Date <span class="text-danger">*</span></label>
                        <input
                          type="date"
                          class="form-control"
                          id="endDate"
                          name="endDate"
                          value="<%= offer.endDate.toISOString().split('T')[0] %>"
                          required
                        />
                        <small class="text-danger" id="endDateError"></small>
                      </div>
                    </div>

                    <div class="form-group">
                      <label for="offerType">Apply To <span class="text-danger">*</span></label>
                      <select class="form-control" id="offerType" name="offerType" required>
                        <option value="">Select Target</option>
                        <option value="product">
                          <% if (offer.offerType === 'product') { %> selected="selected" <% } %>
                          >Specific Product
                        </option>
                        <option value="category">
                          <% if (offer.offerType === 'category') { %> selected="selected" <% } %>
                          >Specific Category
                        </option>
                        <option value="all">
                          <% if (offer.offerType === 'all') { %> selected="selected" <% } %> >All
                          Products
                        </option>
                        <option value="referral">
                          <% if (offer.offerType === 'referral') { %> selected="selected" <% } %>
                          >Referral Bonus
                        </option>
                      </select>
                      <small class="text-danger" id="offerTypeError"></small>
                    </div>

                    <div class="form-group" id="productGroup">
                      <label for="product">Product</label>
                      <select class="form-control" id="product" name="product">
                        <option value="">None</option>
                        <option value="all">
                          <% if (offer.product === 'all' || offer.applyToAllProducts) { %>
                          selected="selected" <% } %> >All Products
                        </option>
                        <% if (products && products.length > 0) { %> <% products.forEach(p => { %>
                        <option value="<%= p._id %>">
                          <% if (offer.product && offer.product.toString() === p._id.toString()) {
                          %> selected="selected" <% } %> ><%= p.name %>
                        </option>
                        <% }) %>
                        <% } %>
                      </select>
                      <small class="text-danger" id="productError"></small>
                    </div>

                    <div class="form-group" id="categoryGroup">
                      <label for="category">Category</label>
                      <select class="form-control" id="category" name="category">
                        <option value="">None</option>
                        <option value="all">
                          <% if (offer.category === 'all' || offer.applyToAllCategories) { %>
                          selected="selected" <% } %> >All Categories
                        </option>
                        <% if (categories && categories.length > 0) { %> <% categories.forEach(c =>
                        { %>
                        <option value="<%= c._id %>">
                          <% if (offer.category && offer.category.toString() === c._id.toString()) {
                          %> selected="selected" <% } %> ><%= c.categoryName %>
                        </option>
                        <% }) %>
                        <% } %>
                      </select>
                      <small class="text-danger" id="categoryError"></small>
                    </div>

                    <div class="form-group form-check">
                      <input
                        type="checkbox"
                        class="form-check-input"
                        id="isActive"
                        name="isActive"
                      />
                      <% if (offer.isActive) { %>
                      checked="checked"
                      <% } %>
                      <label class="form-check-label" for="isActive">Offer is Active</label>
                    </div>

                    <div class="form-group mt-4">
                      <button type="submit" class="btn btn-warning btn-lg mr-3">
                        Update Offer
                      </button>
                      <a href="/admin/offers" class="btn btn-outline-secondary btn-lg">Cancel</a>
                    </div>
                  </form>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="footer mt-auto py-3 bg-light border-top">
      <div class="container text-center">
        <p class="mb-0 text-muted">© 2024 ShoesZone. All rights reserved.</p>
      </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/popper.js@1.16.1/dist/umd/popper.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>

    <script>
      const offerTypeSelect = document.getElementById("offerType");
      const productGroup = document.getElementById("productGroup");
      const categoryGroup = document.getElementById("categoryGroup");
      const productSelect = document.getElementById("product");
      const categorySelect = document.getElementById("category");
      const discountTypeSelect = document.getElementById("discountType");
      const discountValueInput = document.getElementById("discountValue");

      offerTypeSelect.addEventListener("change", function () {
        const value = this.value;
        const showProduct = value === "product" || value === "all";
        const showCategory = value === "category" || value === "all";

        productGroup.style.display = showProduct ? "block" : "none";
        categoryGroup.style.display = showCategory ? "block" : "none";

        if (!showProduct) productSelect.value = "";
        if (!showCategory) categorySelect.value = "";
      });

      discountTypeSelect.addEventListener("change", function () {
        if (this.value === "percentage") {
          discountValueInput.min = 1;
          discountValueInput.max = 100;
          discountValueInput.step = 1;
        } else {
          discountValueInput.removeAttribute("min");
          discountValueInput.removeAttribute("max");
          discountValueInput.step = 0.01;
        }
      });

      document.getElementById("offerForm").addEventListener("submit", function (e) {
        e.preventDefault();
        document.querySelectorAll(".text-danger").forEach((el) => (el.textContent = ""));

        let isValid = true;

        if (document.getElementById("name").value.trim().length < 3) {
          document.getElementById("nameError").textContent = "Name must be at least 3 characters";
          isValid = false;
        }

        if (document.getElementById("description").value.trim().length < 10) {
          document.getElementById("descriptionError").textContent =
            "Description must be at least 10 characters";
          isValid = false;
        }

        const dt = discountTypeSelect.value;
        const dv = parseFloat(discountValueInput.value);

        if (!dt) {
          document.getElementById("discountTypeError").textContent = "Select discount type";
          isValid = false;
        }
        if (isNaN(dv) || dv <= 0) {
          document.getElementById("discountValueError").textContent = "Enter valid positive value";
          isValid = false;
        } else if (dt === "percentage" && (dv < 1 || dv > 100)) {
          document.getElementById("discountValueError").textContent = "Percentage must be 1–100";
          isValid = false;
        }

        const start = new Date(document.getElementById("startDate").value);
        const end = new Date(document.getElementById("endDate").value);
        if (end <= start) {
          document.getElementById("endDateError").textContent = "End date must be after start date";
          isValid = false;
        }

        const ot = offerTypeSelect.value;
        if (!ot) {
          document.getElementById("offerTypeError").textContent = "Select where to apply offer";
          isValid = false;
        } else if (ot === "product" && !productSelect.value) {
          document.getElementById("productError").textContent = "Select a product";
          isValid = false;
        } else if (ot === "category" && !categorySelect.value) {
          document.getElementById("categoryError").textContent = "Select a category";
          isValid = false;
        }

        if (isValid) this.submit();
      });

      offerTypeSelect.dispatchEvent(new Event("change"));
      discountTypeSelect.dispatchEvent(new Event("change"));
    </script>
  </body>
</html>
