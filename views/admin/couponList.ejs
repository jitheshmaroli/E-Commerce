<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Coupon List · ShoeZone Admin</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdn.datatables.net/2.0.8/css/dataTables.bootstrap5.min.css"
    />
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/admin-shared.css" />
  </head>
  <body>
    <!-- ── Top bar ── -->
    <header class="admin-topbar">
      <a href="/admin" class="topbar-brand">
        <div class="topbar-brand-logo"><img src="/test.jpg" alt="Logo" /></div>
        <span class="topbar-brand-name">ShoeZone <em>Admin</em></span>
      </a>
      <div class="topbar-breadcrumb">
        <i class="fas fa-home"></i>
        <i class="fas fa-chevron-right"></i>
        <span>Coupons</span>
      </div>
      <div class="topbar-right">
        <div class="topbar-admin-pill" id="adminPill">
          <div class="topbar-admin-avatar">A</div>
          <span class="topbar-admin-label">Admin</span>
          <i class="fas fa-chevron-down topbar-admin-chevron"></i>
          <div class="topbar-admin-dropdown">
            <a href="/admin/logout" class="topbar-dropdown-item"
              ><i class="fas fa-sign-out-alt"></i> Logout</a
            >
          </div>
        </div>
      </div>
    </header>

    <div class="admin-shell">
      <%- include('../includes/adminSidebar.ejs', { activePage: 'coupons' }) %>

      <main class="admin-main">
        <div class="admin-page-header">
          <div class="admin-page-header-left">
            <div class="admin-page-title">Coupon List</div>
            <div class="admin-page-subtitle">
              <%= coupons ? coupons.length : 0 %> coupons configured
            </div>
          </div>
          <a href="/admin/addcoupon" class="btn-admin btn-admin-primary">
            <i class="fas fa-plus"></i> Add New Coupon
          </a>
        </div>

        <% if (coupons && coupons.length > 0) { %>
        <div class="admin-card">
          <div class="admin-card-body p-0">
            <div class="admin-table-wrap">
              <table id="couponTable" class="admin-table">
                <thead>
                  <tr>
                    <th>CODE</th>
                    <th>DISCOUNT</th>
                    <th>VALID FROM</th>
                    <th>VALID UNTIL</th>
                    <th class="text-center">STATUS</th>
                    <th class="text-center">ACTIONS</th>
                  </tr>
                </thead>
                <tbody>
                  <% coupons.forEach(coupon => { %>
                  <tr data-coupon-id="<%= coupon._id %>">
                    <td
                      style="
                        font-family: 'Bebas Neue', sans-serif;
                        font-size: 1.05rem;
                        letter-spacing: 0.08em;
                      "
                    >
                      <%= coupon.code %>
                    </td>
                    <td>
                      <span class="admin-badge badge-black"><%= coupon.discount %>%</span>
                    </td>
                    <td style="font-size: 0.8rem; color: var(--grey-600)">
                      <%= new Date(coupon.startDate).toLocaleDateString('en-IN', { day: '2-digit',
                      month: 'short', year: 'numeric' }) %>
                    </td>
                    <td style="font-size: 0.8rem; color: var(--grey-600)">
                      <%= new Date(coupon.expiryDate).toLocaleDateString('en-IN', { day: '2-digit',
                      month: 'short', year: 'numeric' }) %>
                    </td>
                    <td class="text-center">
                      <% const now = new Date(); let status = "Upcoming"; let badgeCls =
                      "badge-grey"; if (now >= coupon.startDate && now <= coupon.expiryDate) {
                      status = "ACTIVE"; badgeCls = "badge-green"; } else if (now >
                      coupon.expiryDate) { status = "EXPIRED"; badgeCls = "badge-red"; } %>
                      <span class="admin-badge <%= badgeCls %>"><%= status %></span>
                    </td>
                    <td class="text-center">
                      <div style="display: flex; gap: 0.4rem; justify-content: center">
                        <button
                          class="btn-admin btn-admin-warning btn-admin-sm edit-coupon"
                          data-id="<%= coupon._id %>"
                          data-code="<%= coupon.code %>"
                          data-discount="<%= coupon.discount %>"
                          data-start="<%= new Date(coupon.startDate).toISOString().split('T')[0] %>"
                          data-expiry="<%= new Date(coupon.expiryDate).toISOString().split('T')[0] %>"
                          title="Edit"
                        >
                          <i class="fas fa-edit"></i>
                        </button>
                        <button
                          class="btn-admin btn-admin-danger btn-admin-sm delete-coupon"
                          data-id="<%= coupon._id %>"
                          title="Delete"
                        >
                          <i class="fas fa-trash"></i>
                        </button>
                      </div>
                    </td>
                  </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <% } else { %>
        <div class="admin-card" style="text-align: center; padding: 4rem 2rem">
          <i
            class="fas fa-gift"
            style="font-size: 3rem; color: var(--grey-200); margin-bottom: 1rem; display: block"
          ></i>
          <div
            style="
              font-family: 'Bebas Neue', sans-serif;
              font-size: 1.5rem;
              letter-spacing: 0.04em;
              margin-bottom: 0.5rem;
            "
          >
            No Coupons Yet
          </div>
          <p style="color: var(--grey-400); font-size: 0.88rem; margin-bottom: 1.5rem">
            Click "Add New Coupon" to create your first coupon.
          </p>
          <a href="/admin/addcoupon" class="btn-admin btn-admin-primary">
            <i class="fas fa-plus"></i> Add New Coupon
          </a>
        </div>
        <% } %>
      </main>
    </div>

    <footer class="admin-footer">© 2024 ShoeZone Admin Panel. All rights reserved.</footer>

    <!-- ── Edit Coupon Modal ── -->
    <div
      class="modal fade"
      id="editCouponModal"
      tabindex="-1"
      aria-labelledby="editCouponModalLabel"
      aria-hidden="true"
    >
      <div class="modal-dialog modal-dialog-centered">
        <div
          class="modal-content"
          style="border-radius: 14px; border: 1px solid var(--grey-100); overflow: hidden"
        >
          <div
            class="modal-header"
            style="background: var(--black); border: none; padding: 1.25rem 1.5rem"
          >
            <h5
              class="modal-title"
              id="editCouponModalLabel"
              style="
                font-family: 'Bebas Neue', sans-serif;
                font-size: 1.3rem;
                letter-spacing: 0.05em;
                color: var(--white);
              "
            >
              Edit Coupon
            </h5>
            <button
              type="button"
              class="btn-close btn-close-white"
              data-bs-dismiss="modal"
              aria-label="Close"
            ></button>
          </div>
          <div class="modal-body" style="padding: 1.5rem; background: var(--white)">
            <form id="editCouponForm">
              <input type="hidden" id="couponId" name="couponId" />

              <div class="admin-field">
                <label class="admin-label">Coupon Code</label>
                <input
                  type="text"
                  class="admin-input"
                  id="couponCode"
                  name="code"
                  maxlength="5"
                  required
                  style="
                    text-transform: uppercase;
                    font-family: 'Bebas Neue', sans-serif;
                    font-size: 1.1rem;
                    letter-spacing: 0.08em;
                  "
                />
                <small id="couponCodeError" class="admin-error"></small>
              </div>

              <div class="admin-field">
                <label class="admin-label">Discount (%)</label>
                <input
                  type="number"
                  class="admin-input"
                  id="discount"
                  name="discount"
                  min="1"
                  max="100"
                  required
                />
                <small id="discountError" class="admin-error"></small>
              </div>

              <div class="admin-field">
                <label class="admin-label">Valid From</label>
                <input type="date" class="admin-input" id="startDate" name="startDate" required />
                <small id="startDateError" class="admin-error"></small>
              </div>

              <div class="admin-field">
                <label class="admin-label">Valid Until</label>
                <input type="date" class="admin-input" id="expiryDate" name="expiryDate" required />
                <small id="expiryDateError" class="admin-error"></small>
              </div>

              <button
                type="submit"
                class="btn-admin btn-admin-primary"
                style="width: 100%; justify-content: center; padding: 0.85rem; margin-top: 0.5rem"
              >
                Save Changes
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
      document.getElementById("adminPill")?.addEventListener("click", function (e) {
        e.stopPropagation();
        this.classList.toggle("open");
      });
      document.addEventListener("click", () =>
        document.getElementById("adminPill")?.classList.remove("open")
      );

      $(document).ready(function () {
        $("#couponTable").DataTable({
          responsive: true,
          pageLength: 10,
          lengthMenu: [5, 10, 25, 50],
          order: [[2, "desc"]],
          language: {
            search: "Search coupons:",
            emptyTable: "No coupons found",
          },
        });
      });

      // Track original dates so we only validate what the admin actually changes
      let originalStart = "";
      let originalExpiry = "";

      // Edit Coupon - Populate Modal
      document.querySelectorAll(".edit-coupon").forEach((btn) => {
        btn.addEventListener("click", function () {
          document.getElementById("couponId").value = this.dataset.id;
          document.getElementById("couponCode").value = this.dataset.code;
          document.getElementById("discount").value = this.dataset.discount;
          document.getElementById("startDate").value = this.dataset.start;
          document.getElementById("expiryDate").value = this.dataset.expiry;

          // Store originals for change-detection in validation
          originalStart = this.dataset.start;
          originalExpiry = this.dataset.expiry;

          // Reset validation
          document.querySelectorAll(".admin-error").forEach((el) => (el.textContent = ""));
          document
            .querySelectorAll(".admin-input")
            .forEach((el) => el.classList.remove("is-invalid"));

          const modal = new bootstrap.Modal(document.getElementById("editCouponModal"));
          modal.show();
        });
      });

      // Real-time validation in edit modal
      const editFields = {
        couponCode: document.getElementById("couponCode"),
        discount: document.getElementById("discount"),
        startDate: document.getElementById("startDate"),
        expiryDate: document.getElementById("expiryDate"),
      };

      Object.values(editFields).forEach((input) => {
        if (input) {
          input.addEventListener("input", validateEditField);
          input.addEventListener("blur", validateEditField);
        }
      });

      // Auto uppercase for code in edit modal
      editFields.couponCode.addEventListener("input", () => {
        editFields.couponCode.value = editFields.couponCode.value.toUpperCase();
      });

      function validateEditField(e) {
        const input = e.target;
        const value = input.value.trim();
        let msg = "";

        if (input.id === "couponCode") {
          if (!value) msg = "Coupon code is required";
          else if (value.length < 3 || value.length > 5) msg = "Code must be 3–5 characters";
          else if (!/[A-Z]/.test(value)) msg = "Code must contain uppercase letters";
        } else if (input.id === "discount") {
          const num = parseFloat(value);
          if (!value) msg = "Discount is required";
          else if (isNaN(num) || num < 1 || num > 100) msg = "Discount must be 1–100";
        } else if (input.id === "startDate") {
          if (!value) {
            msg = "Start date is required";
          } else if (value !== originalStart) {
            // Admin changed the start date — must not be set to the past
            const selected = new Date(value);
            const today = new Date();
            today.setHours(0, 0, 0, 0);
            if (selected < today) msg = "Start date cannot be set to a past date";
          }
          // If unchanged, skip — existing past start dates are valid
        } else if (input.id === "expiryDate") {
          if (!value) {
            msg = "Expiry date is required";
          } else if (value !== originalExpiry) {
            // Admin changed the expiry — must be a future date
            const selected = new Date(value);
            const today = new Date();
            today.setHours(0, 0, 0, 0);
            if (selected <= today) msg = "New expiry date must be in the future";
          }
          // If unchanged, skip — no re-validation needed
        }

        const errorEl = document.getElementById(`${input.id}Error`);
        if (errorEl) {
          errorEl.textContent = msg;
          input.classList.toggle("is-invalid", !!msg);
        }

        // Cross validation: start < expiry
        if (editFields.startDate.value && editFields.expiryDate.value) {
          const s = new Date(editFields.startDate.value);
          const e = new Date(editFields.expiryDate.value);
          const errEl = document.getElementById("expiryDateError");
          if (s >= e) {
            errEl.textContent = "Expiry must be after start date";
            editFields.expiryDate.classList.add("is-invalid");
          } else if (errEl.textContent === "Expiry must be after start date") {
            errEl.textContent = "";
            editFields.expiryDate.classList.remove("is-invalid");
          }
        }
      }

      // Submit edit form
      document.getElementById("editCouponForm")?.addEventListener("submit", async function (e) {
        e.preventDefault();

        let valid = true;
        Object.values(editFields).forEach((input) => {
          validateEditField({ target: input });
          if (input.classList.contains("is-invalid")) valid = false;
        });

        if (!valid) {
          Swal.fire({
            icon: "warning",
            title: "Invalid Input",
            text: "Please fix the highlighted errors",
            timer: 2500,
            showConfirmButton: false,
          });
          return;
        }

        const formData = new FormData(this);
        const data = Object.fromEntries(formData);

        try {
          const res = await fetch(`/admin/editCoupon/${data.couponId}`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(data),
          });

          const result = await res.json();

          if (result.success) {
            bootstrap.Modal.getInstance(document.getElementById("editCouponModal")).hide();
            await Swal.fire({
              icon: "success",
              title: "Updated!",
              text: "Coupon updated successfully",
              timer: 1800,
              showConfirmButton: false,
            });
            location.reload();
          } else {
            Swal.fire("Error", result.message || "Failed to update coupon", "error");
          }
        } catch (err) {
          Swal.fire("Error", "Network error occurred.", "error");
        }
      });

      // Delete Coupon
      document.querySelectorAll(".delete-coupon").forEach((btn) => {
        btn.addEventListener("click", function () {
          const couponId = this.closest("tr").dataset.couponId;

          Swal.fire({
            title: "Are you sure?",
            text: "This coupon will be permanently deleted!",
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: "#d33",
            cancelButtonColor: "#3085d6",
            confirmButtonText: "Yes, delete it!",
          }).then(async (result) => {
            if (result.isConfirmed) {
              try {
                const res = await fetch(`/admin/removecoupon/${couponId}`, { method: "DELETE" });
                const data = await res.json();

                if (data.success || res.ok) {
                  Swal.fire("Deleted!", "Coupon has been deleted.", "success").then(() =>
                    location.reload()
                  );
                } else {
                  Swal.fire("Error!", data.error || "Failed to delete coupon.", "error");
                }
              } catch (err) {
                Swal.fire("Error!", "Network error occurred.", "error");
              }
            }
          });
        });
      });
    </script>
  </body>
</html>
