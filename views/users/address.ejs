<%- include('../includes/userHead.ejs') %>
<link rel="stylesheet" href="/css/address.css" />

<%- include('../includes/userHeader.ejs') %>

<main class="main">
  <% if (user) { %>
  <aside class="sidebar">
    <div class="profile-section">
      <div class="avatar">
        <img
          src="<%= user.photo && user.photo.length > 0 ? '/uploads/' + user.photo[0].filename : '/images/avatar.jpg' %>"
          alt="Profile Avatar"
        />
      </div>
      <ul class="profile-links">
        <li><a href="/profile">User Profile</a></li>
        <li><a href="/address">Address</a></li>
        <li><a href="/order-history">Order History</a></li>
        <li><a href="/change-password">Change Password</a></li>
        <li><a href="/wallet">Wallet</a></li>
      </ul>
    </div>
  </aside>
  <section class="content">
    <% if (addresses.address && addresses.address.length > 0) { %>
    <h2 class="page-title">Address List</h2>
    <div class="address-message">
      <a href="/addresses/add" class="btn product-btn">Add New Address</a>
    </div>
    <div class="address-list">
      <% addresses.address.forEach(address => { %>
      <div
        class="address-card"
        data-address-id="<%= address._id %>"
        data-is-default="<%= address.isDefault ? 'true' : 'false' %>"
      >
        <h3><%= address.name %></h3>
        <p>
          <%= address.houseName %>, <%= address.street %>, <%= address.district %>, <%=
          address.state %>, <%= address.country %>
        </p>
        <p>PIN: <%= address.pinCode %></p>
        <% if (address.isDefault) { %>
        <span class="default-address-tag">Default Address</span>
        <% } else { %>
        <button class="btn product-btn btn-sm set-default-btn" data-address-id="<%= address._id %>">
          Set as Default
        </button>
        <% } %>
        <a href="/address/edit/<%= address._id %>" class="btn product-btn btn-sm">Edit</a>
        <button class="btn product-btn btn-sm delete-btn" data-address-id="<%= address._id %>">
          Delete
        </button>
      </div>
      <% }) %>
    </div>
    <% } else { %>
    <div class="empty-state">
      <h2>No addresses saved</h2>
      <a href="/addresses/add" class="btn product-btn">Add Address</a>
    </div>
    <% } %>
  </section>
  <% } %>
</main>

<%- include('../includes/userFooter.ejs') %>
<%- include('../includes/userScripts.ejs') %>

<script>
  document.querySelectorAll(".set-default-btn").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const addressId = btn.dataset.addressId;

      try {
        const res = await fetch("/set-default", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ addressId }),
        });

        const data = await res.json();

        if (data.success) {
          Swal.fire({
            icon: "success",
            title: "Success",
            text: "Default address updated",
            timer: 1500,
            showConfirmButton: false,
          }).then(() => location.reload());
        } else {
          Swal.fire({
            icon: "error",
            title: "Error",
            text: data.message || "Failed to set default",
          });
        }
      } catch (err) {
        Swal.fire({
          icon: "error",
          title: "Network Error",
          text: "Something went wrong",
        });
      }
    });
  });

  document.querySelectorAll(".delete-btn").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const addressId = btn.dataset.addressId;

      Swal.fire({
        title: "Are you sure?",
        text: "You won't be able to revert this!",
        icon: "warning",
        showCancelButton: true,
        confirmButtonColor: "#d33",
        cancelButtonColor: "#3085d6",
        confirmButtonText: "Yes, delete it!",
      }).then(async (result) => {
        if (result.isConfirmed) {
          try {
            const res = await fetch(`/address/delete/${addressId}`, { method: "POST" });
            const data = await res.json();

            if (data.success) {
              Swal.fire("Deleted!", "Address has been deleted.", "success").then(() =>
                location.reload()
              );
            } else {
              Swal.fire("Error!", data.message || "Failed to delete.", "error");
            }
          } catch (err) {
            Swal.fire("Error!", "Network error occurred.", "error");
          }
        }
      });
    });
  });
</script>
<script>
  function setCategory(category) {
    const selectedCategory = document.getElementById("selectedCategory");
    if (selectedCategory) selectedCategory.value = category;
    const dropdownText = document.querySelector(".dropdown-toggle-text");
    if (dropdownText)
      dropdownText.textContent = category.charAt(0).toUpperCase() + category.slice(1);
  }
</script>
