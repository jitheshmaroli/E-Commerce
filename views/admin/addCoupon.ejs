<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Add Coupon - Admin</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    />
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/addCoupon.css" />
  </head>
  <body class="bg-light">
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
      <div class="container-fluid">
        <a class="navbar-brand fw-bold" href="/admin">
          <img src="/test.jpg" alt="Logo" width="35" class="d-inline-block align-text-top me-2" />
          SportZilon Admin
        </a>
        <button
          class="navbar-toggler"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#navbarNav"
        >
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav ms-auto">
            <li class="nav-item dropdown">
              <a
                class="nav-link dropdown-toggle text-white"
                href="#"
                id="adminDropdown"
                role="button"
                data-bs-toggle="dropdown"
              >
                ADMIN
              </a>
              <ul class="dropdown-menu dropdown-menu-end">
                <li><a class="dropdown-item" href="/admin/logout">Logout</a></li>
              </ul>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <div class="d-flex">
      <!-- Sidebar -->
      <aside class="sidebar bg-dark text-white p-3" style="width: 250px; min-height: 100vh">
        <div class="list-group list-group-flush">
          <a
            href="/admin"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3"
          >
            <i class="fas fa-home me-2"></i> HOME
          </a>
          <a
            href="/admin/allproducts"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3"
          >
            <i class="fas fa-box me-2"></i> ALL PRODUCTS
          </a>
          <a
            href="/admin/ordersList"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3"
          >
            <i class="fas fa-shopping-cart me-2"></i> ORDERS LIST
          </a>
          <a
            href="/admin/usersList"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3"
          >
            <i class="fas fa-users me-2"></i> USERS LIST
          </a>
          <a
            href="/admin/categoryList"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3"
          >
            <i class="fas fa-tags me-2"></i> CATEGORY LIST
          </a>
          <a
            href="/admin/couponList"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3 active"
          >
            <i class="fas fa-gift me-2"></i> COUPON LIST
          </a>
          <a
            href="/admin/offers"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3"
          >
            <i class="fas fa-percentage me-2"></i> OFFERS
          </a>
        </div>
      </aside>

      <!-- Main Content -->
      <main class="content flex-grow-1 p-4">
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb bg-transparent p-0 mb-4">
            <li class="breadcrumb-item">
              <a href="/admin/couponList" class="text-dark">Coupon List</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Add New Coupon</li>
          </ol>
        </nav>

        <div class="card shadow-lg border-0" style="max-width: 550px; margin: 0 auto">
          <div class="card-header bg-dark text-white text-center py-3">
            <h4 class="mb-0">Add New Coupon</h4>
          </div>
          <div class="card-body p-4">
            <form id="couponForm" method="POST" action="/admin/addcoupon">
              <div id="message" class="text-danger mb-3 fw-bold"><%= message || '' %></div>

              <!-- Coupon Code -->
              <div class="mb-4">
                <label for="code" class="form-label fw-bold"
                  >Coupon Code <span class="text-danger">*</span></label
                >
                <input
                  type="text"
                  class="form-control"
                  id="code"
                  name="code"
                  placeholder="e.g. NEW20"
                  maxlength="5"
                  required
                  autocomplete="off"
                />
                <small id="codeError" class="text-danger"></small>
              </div>

              <!-- Discount -->
              <div class="mb-4">
                <label for="discount" class="form-label fw-bold"
                  >Discount Percentage <span class="text-danger">*</span></label
                >
                <input
                  type="text"
                  class="form-control"
                  id="discount"
                  name="discount"
                  placeholder="e.g. 20"
                  inputmode="numeric"
                  min="1"
                  max="100"
                  required
                />
                <small id="discountError" class="text-danger"></small>
              </div>

              <!-- Valid From -->
              <div class="mb-4">
                <label for="startDate" class="form-label fw-bold"
                  >Valid From <span class="text-danger">*</span></label
                >
                <input type="date" class="form-control" id="startDate" name="startDate" required />
                <small id="startDateError" class="text-danger"></small>
              </div>

              <!-- Valid Until -->
              <div class="mb-4">
                <label for="expiryDate" class="form-label fw-bold"
                  >Valid Until <span class="text-danger">*</span></label
                >
                <input
                  type="date"
                  class="form-control"
                  id="expiryDate"
                  name="expiryDate"
                  required
                />
                <small id="expiryDateError" class="text-danger"></small>
              </div>

              <!-- Buttons -->
              <div class="d-flex gap-3">
                <button type="submit" class="btn btn-dark flex-grow-1 py-2 fw-bold">
                  ADD COUPON
                </button>
                <button
                  type="button"
                  class="btn btn-outline-dark flex-grow-1 py-2"
                  onclick="clearFields()"
                >
                  CLEAR
                </button>
                <a
                  href="/admin/couponList"
                  class="btn btn-outline-secondary flex-grow-1 py-2 text-center"
                >
                  BACK
                </a>
              </div>
            </form>
          </div>
        </div>
      </main>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
      const codeInput = document.getElementById("code");
      const discountInput = document.getElementById("discount");
      const startInput = document.getElementById("startDate");
      const expiryInput = document.getElementById("expiryDate");

      const codeError = document.getElementById("codeError");
      const discountError = document.getElementById("discountError");
      const startError = document.getElementById("startDateError");
      const expiryError = document.getElementById("expiryDateError");

      // Real-time validation + auto uppercase for code
      [codeInput, discountInput, startInput, expiryInput].forEach((input) => {
        input.addEventListener("input", validateField);
        input.addEventListener("blur", validateField);
      });

      codeInput.addEventListener("input", () => {
        codeInput.value = codeInput.value.toUpperCase();
      });

      function validateField(e) {
        const input = e.target;
        const value = input.value.trim();
        let errorEl = document.getElementById(`${input.id}Error`);
        let msg = "";

        if (input === codeInput) {
          if (!value) msg = "Coupon code is required";
          else if (value.length < 3 || value.length > 5) msg = "Code must be 3–5 characters";
          else if (!/[A-Z]/.test(value)) msg = "Code must contain at least one uppercase letter";
        } else if (input === discountInput) {
          const num = parseFloat(value);
          if (!value) msg = "Discount is required";
          else if (isNaN(num) || num < 1 || num > 100) msg = "Discount must be 1–100";
        } else if (input === startInput) {
          if (!value) msg = "Start date is required";
          else {
            const selected = new Date(value);
            const today = new Date();
            today.setHours(0, 0, 0, 0);
            if (selected < today) msg = "Start date cannot be in the past";
          }
        } else if (input === expiryInput) {
          if (!value) msg = "Expiry date is required";
          else {
            const selected = new Date(value);
            const tomorrow = new Date();
            tomorrow.setDate(tomorrow.getDate() + 1);
            tomorrow.setHours(0, 0, 0, 0);
            if (selected <= new Date()) msg = "Expiry must be in the future";
          }
        }

        errorEl.textContent = msg;
        input.classList.toggle("is-invalid", !!msg);

        // Cross-field validation: start < expiry
        if (startInput.value && expiryInput.value) {
          const s = new Date(startInput.value);
          const e = new Date(expiryInput.value);
          if (s >= e) {
            expiryError.textContent = "Expiry date must be after start date";
            expiryInput.classList.add("is-invalid");
          } else if (expiryError.textContent === "Expiry date must be after start date") {
            expiryError.textContent = "";
            expiryInput.classList.remove("is-invalid");
          }
        }
      }

      function isFormValid() {
        let valid = true;
        [codeInput, discountInput, startInput, expiryInput].forEach((input) => {
          validateField({ target: input });
          if (input.classList.contains("is-invalid")) valid = false;
        });
        return valid;
      }

      document.getElementById("couponForm").addEventListener("submit", async function (e) {
        e.preventDefault();

        if (!isFormValid()) {
          Swal.fire({
            icon: "warning",
            title: "Invalid Input",
            text: "Please correct the errors shown.",
            timer: 2500,
            showConfirmButton: false,
          });
          return;
        }

        const formData = new FormData(this);
        const data = Object.fromEntries(formData);

        try {
          const res = await fetch("/admin/addcoupon", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(data),
          });

          const result = await res.json();

          if (result.success) {
            await Swal.fire("Success", "Coupon added successfully!", "success");
            window.location.href = "/admin/couponList";
          } else {
            Swal.fire("Error", result.message || "Failed to add coupon.", "error");
          }
        } catch (err) {
          Swal.fire("Error", "Network error occurred.", "error");
        }
      });

      function clearFields() {
        codeInput.value = "";
        discountInput.value = "";
        startInput.value = "";
        expiryInput.value = "";
        document.querySelectorAll(".text-danger").forEach((el) => (el.textContent = ""));
        document
          .querySelectorAll(".form-control")
          .forEach((el) => el.classList.remove("is-invalid"));
      }
    </script>
  </body>
</html>
