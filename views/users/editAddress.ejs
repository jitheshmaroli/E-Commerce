<%- include('../includes/userHead.ejs') %>
<link rel="stylesheet" href="/css/addAddress.css" />

<%- include('../includes/userHeader.ejs') %>

<main class="main">
  <% if (user) { %>
  <aside class="sidebar">
    <div class="profile-section">
      <div class="avatar">
        <img
          src="<%= user.photo && user.photo.length > 0 ? '/uploads/' + user.photo[0].filename : '/images/avatar.jpg' %>"
          alt="Profile Avatar" />
      </div>
      <ul class="profile-links">
        <li><a href="/user-profile">User Profile</a></li>
        <li><a href="/address">Address</a></li>
        <li><a href="/order-history">Order History</a></li>
        <li><a href="/change-password">Change Password</a></li>
        <li><a href="/wallet">Wallet</a></li>
      </ul>
    </div>
  </aside>
  <section class="content">
    <h2 class="page-title">Edit Address</h2>
    <% if (address) { %>
    <form action="/address/edit?addressId=<%= address._id %>" method="POST">
      <div class="form-group">
        <label for="name">Name</label>
        <input
          type="text"
          id="name"
          name="name"
          value="<%= address.name %>"
          required />
      </div>
      <div class="form-group">
        <label for="houseName">House Name</label>
        <input
          type="text"
          id="houseName"
          name="houseName"
          value="<%= address.houseName %>"
          required />
      </div>
      <div class="form-group">
        <label for="street">Street</label>
        <input
          type="text"
          id="street"
          name="street"
          value="<%= address.street %>"
          required />
      </div>
      <div class="form-group">
        <label for="city">City</label>
        <input
          type="text"
          id="city"
          name="city"
          value="<%= address.city %>"
          required />
      </div>
      <div class="form-group">
        <label for="district">District</label>
        <input
          type="text"
          id="district"
          name="district"
          value="<%= address.district %>"
          required />
      </div>
      <div class="form-group">
        <label for="state">State</label>
        <input
          type="text"
          id="state"
          name="state"
          value="<%= address.state %>"
          required />
      </div>
      <div class="form-group">
        <label for="pinCode">Pin Code</label>
        <input
          type="number"
          id="pinCode"
          name="pinCode"
          value="<%= address.pinCode %>"
          minlength="6"
          maxlength="6"
          required
          onkeyup="limitPincode(this)" />
        <% if (message) { %><span class="alert alert-danger"
          ><%= message %></span
        ><% } %>
      </div>
      <div class="form-group">
        <label class="form-check-label">Set as Default</label>
        <input type="checkbox" class="form-check-input" id="isDefault"
        name="isDefault" <%= address.isDefault ? 'checked' : '' %>>
      </div>
      <div class="form-group">
        <button type="submit" class="btn product-btn">Update Address</button>
      </div>
    </form>
    <% } %>
  </section>
  <% } %>
</main>

<%- include('../includes/userFooter.ejs') %> <%-
include('../includes/userScripts.ejs') %>

<script>
  function limitPincode(input) {
    if (input.value.length > 6) input.value = input.value.slice(0, 6);
  }

  function setCategory(category) {
    const selectedCategory = document.getElementById("selectedCategory");
    if (selectedCategory) selectedCategory.value = category;
    const dropdownText = document.querySelector(".dropdown-toggle-text");
    if (dropdownText)
      dropdownText.textContent =
        category.charAt(0).toUpperCase() + category.slice(1);
  }
</script>
