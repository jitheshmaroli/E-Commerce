<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Add Product · ShoeZone Admin</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    />
    <link rel="stylesheet" href="/css/admin-shared.css" />
  </head>
  <body>
    <!-- ── Top bar ── -->
    <header class="admin-topbar">
      <a href="/admin" class="topbar-brand">
        <div class="topbar-brand-logo"><img src="/test.jpg" alt="Logo" /></div>
        <span class="topbar-brand-name">ShoeZone <em>Admin</em></span>
      </a>
      <div class="topbar-breadcrumb">
        <a href="/admin/allproducts" style="color: rgba(255, 255, 255, 0.35); text-decoration: none"
          >Products</a
        >
        <i class="fas fa-chevron-right"></i>
        <span>Add Product</span>
      </div>
      <div class="topbar-right">
        <div class="topbar-admin-pill" id="adminPill">
          <div class="topbar-admin-avatar">A</div>
          <span class="topbar-admin-label">Admin</span>
          <i class="fas fa-chevron-down topbar-admin-chevron"></i>
          <div class="topbar-admin-dropdown">
            <a href="/admin/logout" class="topbar-dropdown-item"
              ><i class="fas fa-sign-out-alt"></i> Logout</a
            >
          </div>
        </div>
      </div>
    </header>

    <div class="admin-shell">
      <%- include('../includes/adminSidebar.ejs', { activePage: 'products' }) %>

      <main class="admin-main">
        <div class="admin-page-header">
          <div class="admin-page-header-left">
            <div class="admin-page-title">Add New Product</div>
            <div class="admin-page-subtitle">
              Fill in the details below to add a product to the catalog
            </div>
          </div>
          <a href="/admin/allproducts" class="btn-admin btn-admin-ghost">
            <i class="fas fa-arrow-left"></i> Back to Products
          </a>
        </div>

        <div class="admin-card" style="max-width: 920px">
          <div class="admin-card-body">
            <form
              id="productForm"
              method="POST"
              action="/admin/addproduct"
              enctype="multipart/form-data"
            >
              <div class="row g-4">
                <!-- Left: Fields -->
                <div class="col-lg-7">
                  <div class="admin-field">
                    <label class="admin-label">Product Name <span class="req">*</span></label>
                    <input
                      type="text"
                      class="admin-input"
                      id="name"
                      name="name"
                      maxlength="50"
                      required
                    />
                    <small id="nameError" class="admin-error"></small>
                  </div>

                  <div class="admin-field">
                    <label class="admin-label">Description <span class="req">*</span></label>
                    <textarea
                      class="admin-textarea"
                      id="description"
                      name="description"
                      rows="4"
                      maxlength="500"
                      required
                    ></textarea>
                    <small id="descriptionError" class="admin-error"></small>
                  </div>

                  <div class="admin-field">
                    <label class="admin-label">Category <span class="req">*</span></label>
                    <select class="admin-select" id="category" name="category" required>
                      <option value="">Select Category</option>
                      <% categoryList.forEach(cat => { %>
                      <option value="<%= cat.categoryName %>"><%= cat.categoryName %></option>
                      <% }) %>
                    </select>
                    <small id="categoryError" class="admin-error"></small>
                  </div>

                  <div class="row g-3">
                    <div class="col-md-4">
                      <div class="admin-field">
                        <label class="admin-label">Brand</label>
                        <input type="text" class="admin-input" id="brandName" name="brandName" />
                        <small id="brandNameError" class="admin-error"></small>
                      </div>
                    </div>
                    <div class="col-md-4">
                      <div class="admin-field">
                        <label class="admin-label">Stock <span class="req">*</span></label>
                        <input
                          type="number"
                          inputmode="numeric"
                          pattern="[0-9]*"
                          class="admin-input"
                          id="stock"
                          name="stock"
                          min="0"
                          required
                        />
                        <small id="stockError" class="admin-error"></small>
                      </div>
                    </div>
                    <div class="col-md-4">
                      <div class="admin-field">
                        <label class="admin-label">Price (₹) <span class="req">*</span></label>
                        <input
                          type="number"
                          inputmode="decimal"
                          step="0.01"
                          class="admin-input"
                          id="price"
                          name="price"
                          min="0"
                          required
                        />
                        <small id="priceError" class="admin-error"></small>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Right: Images -->
                <div class="col-lg-5">
                  <div class="admin-field">
                    <label class="admin-label">Product Images <span class="req">*</span></label>
                    <div class="admin-upload-zone">
                      <div
                        style="
                          display: flex;
                          align-items: center;
                          gap: 0.65rem;
                          margin-bottom: 0.75rem;
                        "
                      >
                        <div
                          style="
                            width: 36px;
                            height: 36px;
                            background: var(--off-white);
                            border: 1.5px solid var(--grey-100);
                            border-radius: var(--radius-sm);
                            display: flex;
                            align-items: center;
                            justify-content: center;
                            flex-shrink: 0;
                          "
                        >
                          <i
                            class="fas fa-images"
                            style="color: var(--grey-400); font-size: 0.88rem"
                          ></i>
                        </div>
                        <div>
                          <div style="font-size: 0.82rem; font-weight: 700; color: var(--black)">
                            Upload 4 images
                          </div>
                          <div style="font-size: 0.72rem; color: var(--grey-400)">
                            JPEG, PNG or WebP · max 5MB each
                          </div>
                        </div>
                      </div>
                      <input
                        type="file"
                        class="admin-input"
                        id="photos"
                        name="photos"
                        accept="image/*"
                        multiple
                        required
                        style="padding: 0.5rem"
                      />
                      <small id="photosError" class="admin-error d-block mt-1"></small>
                      <div class="image-preview-grid" id="preview"></div>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Buttons -->
              <div
                style="
                  display: flex;
                  gap: 0.75rem;
                  margin-top: 2rem;
                  padding-top: 1.5rem;
                  border-top: 1px solid var(--grey-100);
                "
              >
                <button
                  type="submit"
                  class="btn-admin btn-admin-primary"
                  style="flex: 1; justify-content: center; padding: 0.85rem"
                >
                  <i class="fas fa-plus"></i> Add Product
                </button>
                <button
                  type="button"
                  class="btn-admin btn-admin-ghost"
                  onclick="clearFields()"
                  style="flex: 1; justify-content: center; padding: 0.85rem"
                >
                  <i class="fas fa-eraser"></i> Clear
                </button>
                <a
                  href="/admin/allproducts"
                  class="btn-admin btn-admin-ghost"
                  style="flex: 1; justify-content: center; padding: 0.85rem"
                >
                  <i class="fas fa-arrow-left"></i> Back
                </a>
              </div>
            </form>
          </div>
        </div>
      </main>
    </div>

    <footer class="admin-footer">© 2024 ShoeZone Admin Panel. All rights reserved.</footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
      document.getElementById("adminPill")?.addEventListener("click", function (e) {
        e.stopPropagation();
        this.classList.toggle("open");
      });
      document.addEventListener("click", () =>
        document.getElementById("adminPill")?.classList.remove("open")
      );

      // ── DOM refs ──────────────────────────────────────────────
      const form = document.getElementById("productForm");
      const photoInput = document.getElementById("photos");
      const preview = document.getElementById("preview");
      const nameError = document.getElementById("nameError");
      const descError = document.getElementById("descriptionError");
      const categoryError = document.getElementById("categoryError");
      const brandError = document.getElementById("brandNameError");
      const stockError = document.getElementById("stockError");
      const priceError = document.getElementById("priceError");
      const photosError = document.getElementById("photosError");

      function setFieldError(errorEl, message, inputEl = null) {
        if (!errorEl) return;
        const target = inputEl || errorEl.previousElementSibling;
        if (message) {
          errorEl.textContent = message;
          target?.classList?.add("is-invalid");
        } else {
          errorEl.textContent = "";
          target?.classList?.remove("is-invalid");
        }
      }
      function clearAllErrors() {
        document.querySelectorAll(".admin-error").forEach((el) => (el.textContent = ""));
        document.querySelectorAll(".is-invalid").forEach((el) => el.classList.remove("is-invalid"));
      }

      // ── Validators ────────────────────────────────────────────
      function validateName(v) {
        v = v.trim();
        if (!v) return "Product name is required.";
        if (v.length < 3) return "Name must be at least 3 characters.";
        if (v.length > 50) return "Name cannot exceed 50 characters.";
        return "";
      }
      function validateDescription(v) {
        v = v.trim();
        if (!v) return "Description is required.";
        if (v.length < 20) return "Description should be at least 20 characters.";
        if (v.length > 500) return "Description cannot exceed 500 characters.";
        return "";
      }
      function validateCategory(v) {
        return v ? "" : "Please select a category.";
      }
      function validateStock(v) {
        if (v === "" || isNaN(v)) return "Stock quantity is required.";
        const n = Number(v);
        if (!Number.isInteger(n)) return "Stock must be a whole number.";
        if (n < 0) return "Stock cannot be negative.";
        if (n > 99999) return "Stock seems too large (max 99999).";
        return "";
      }
      function validatePrice(v) {
        if (v === "" || isNaN(v)) return "Price is required.";
        const n = Number(v);
        if (n <= 0) return "Price must be greater than 0.";
        if (n < 10) return "Price should be at least ₹10.";
        if (n > 1000000) return "Price seems unusually high.";
        return "";
      }
      function validatePhotos(files) {
        if (files.length !== 4) return "Exactly 4 images are required.";
        for (const f of files) {
          if (!["image/jpeg", "image/png", "image/webp"].includes(f.type))
            return "Only JPEG, PNG, WebP allowed.";
          if (f.size > 5 * 1024 * 1024) return "Each image must be smaller than 5MB.";
        }
        return "";
      }

      // ── Real-time validation ──────────────────────────────────
      function attachValidation(field, validator, errorEl) {
        ["input", "blur"].forEach((ev) =>
          field.addEventListener(ev, () => setFieldError(errorEl, validator(field.value), field))
        );
      }
      attachValidation(document.getElementById("name"), validateName, nameError);
      attachValidation(document.getElementById("description"), validateDescription, descError);
      attachValidation(document.getElementById("category"), validateCategory, categoryError);
      attachValidation(document.getElementById("brandName"), () => "", brandError);
      attachValidation(document.getElementById("stock"), validateStock, stockError);
      attachValidation(document.getElementById("price"), validatePrice, priceError);

      // ── Photo preview ─────────────────────────────────────────
      photoInput.addEventListener("change", function () {
        const files = Array.from(this.files);
        const err = validatePhotos(files);
        if (err) {
          setFieldError(photosError, err, photoInput);
          this.value = "";
          preview.innerHTML = "";
          return;
        }
        setFieldError(photosError, "", photoInput);
        preview.innerHTML = "";
        files.forEach((file) => {
          const reader = new FileReader();
          reader.onload = (e) => {
            const wrapper = document.createElement("div");
            wrapper.className = "image-wrapper";
            wrapper.innerHTML = `<img src="${e.target.result}" alt="preview" />`;
            preview.appendChild(wrapper);
          };
          reader.readAsDataURL(file);
        });
      });

      // ── Submit ────────────────────────────────────────────────
      form.addEventListener("submit", async function (e) {
        e.preventDefault();
        const nameField = document.getElementById("name");
        const descField = document.getElementById("description");
        const catField = document.getElementById("category");
        const stockField = document.getElementById("stock");
        const priceField = document.getElementById("price");
        const brandField = document.getElementById("brandName");

        const nameErr = validateName(nameField.value);
        const descErr = validateDescription(descField.value);
        const catErr = validateCategory(catField.value);
        const stockErr = validateStock(stockField.value);
        const priceErr = validatePrice(priceField.value);
        const photoErr = validatePhotos(Array.from(photoInput.files));

        setFieldError(nameError, nameErr, nameField);
        setFieldError(descError, descErr, descField);
        setFieldError(categoryError, catErr, catField);
        setFieldError(stockError, stockErr, stockField);
        setFieldError(priceError, priceErr, priceField);
        setFieldError(brandError, "", brandField);
        setFieldError(photosError, photoErr, photoInput);

        if (nameErr || descErr || catErr || stockErr || priceErr || photoErr) {
          Swal.fire({
            icon: "error",
            title: "Validation Error",
            text: "Please fix the highlighted fields.",
            confirmButtonColor: "#0a0a0a",
          });
          return;
        }

        try {
          const res = await fetch(form.action, { method: "POST", body: new FormData(form) });
          const result = await res.json();
          if (res.ok || result.success) {
            await Swal.fire({
              icon: "success",
              title: "Product Added!",
              text: "Product added successfully.",
              confirmButtonColor: "#0a0a0a",
            });
            window.location.href = "/admin/allproducts";
          } else {
            Swal.fire("Error", result.message || "Failed to add product.", "error");
          }
        } catch {
          Swal.fire("Error", "Something went wrong. Please try again.", "error");
        }
      });

      function clearFields() {
        form.reset();
        preview.innerHTML = "";
        clearAllErrors();
      }
    </script>
  </body>
</html>
