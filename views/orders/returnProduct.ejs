<%- include('../includes/userHead.ejs') %>
<link rel="stylesheet" href="/css/returnProduct.css" />

<%- include('../includes/userHeader.ejs') %>

<div class="container">
  <div class="return-container">
    <h2 class="page-title">Return Product</h2>
    <div class="return-content">
      <div class="product-info">
        <img
          src="/uploads/<%= item.productId.photos[0].filename %>"
          alt="<%= item.productId.name %>"
          class="product-image"
        />
        <div class="product-details">
          <h3 class="product-name"><%= item.productId.name %></h3>
          <p class="product-quantity">Ordered Quantity: <%= item.quantity %></p>
        </div>
      </div>
      <form
        action="/return-product/<%= order._id %>/<%= item.productId._id %>"
        method="POST"
        class="return-form"
      >
        <div class="form-group">
          <label for="returnReason" class="form-label">Return Reason</label>
          <textarea
            id="returnReason"
            name="returnReason"
            class="form-control"
            rows="4"
            required
            placeholder="Describe the reason for return..."
          ></textarea>
        </div>
        <button type="submit" class="btn btn-primary submit-btn">Submit Return Request</button>
      </form>
    </div>
  </div>
</div>

<%- include('../includes/userFooter.ejs') %>
<%-
include('../includes/userScripts.ejs') %>
