<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Add New Product</title>
    <!-- Bootstrap 4 CSS -->
    <link
      rel="stylesheet"
      href="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/cropper/2.3.0/cropper.min.css"
    />
    <link rel="stylesheet" href="/css/addProduct.css" />
  </head>
  <body>
    <nav class="navbar navbar-expand-lg navbar-light bg-light">
      <div class="container-fluid">
        <a class="navbar-brand" href="#">
          <img
            src="/test.jpg"
            alt="Logo"
            width="30"
            height="24"
            class="d-inline-block align-text-top"
          />
          SportZilon
        </a>
        <div class="collapse navbar-collapse" id="navbarSupportedContent">
          <ul class="navbar-nav ml-auto mb-2 mb-lg-0">
            <li class="nav-item dropdown">
              <a
                class="nav-link dropdown-toggle"
                href="#"
                id="navbarDropdown"
                role="button"
                data-toggle="dropdown"
                aria-expanded="false"
              >
                ADMIN
              </a>
              <ul class="dropdown-menu dropdown-menu-right" aria-labelledby="navbarDropdown">
                <li><a class="dropdown-item" href="#">Action</a></li>
                <li><hr class="dropdown-divider" /></li>
                <li><a class="dropdown-item" href="/admin/logout">Logout</a></li>
              </ul>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <main class="main">
      <aside class="sidebar">
        <div class="">
          <div class="list-group sidebar-list" id="myListGroup">
            <a href="/admin"
              ><button type="button" class="list-group-item list-group-item-action">HOME</button></a
            >
            <a href="/admin/allproducts"
              ><button type="button" class="list-group-item list-group-item-action active">
                ALL PRODUCTS
              </button></a
            >
            <a href="/admin/ordersList"
              ><button type="button" class="list-group-item list-group-item-action">
                ORDERS LIST
              </button></a
            >
            <a href="/admin/usersList"
              ><button type="button" class="list-group-item list-group-item-action">
                USERS LIST
              </button></a
            >
            <a href="/admin/categoryList"
              ><button type="button" class="list-group-item list-group-item-action">
                CATEGORY LIST
              </button></a
            >
            <a href="/admin/couponList"
              ><button type="button" class="list-group-item list-group-item-action">
                COUPON LIST
              </button></a
            >
            <a href="/admin/offers"
              ><button type="button" class="list-group-item list-group-item-action">
                OFFERS
              </button></a
            >
          </div>
        </div>
      </aside>

      <section class="content">
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/admin/allproducts">ALL PRODUCTS</a></li>
            <li class="breadcrumb-item active" aria-current="page">ADD NEW PRODUCT</li>
          </ol>
        </nav>

        <div class="container">
          <% if (message) { %>
          <script>
            alert("<!= message !>");
          </script>
          <% } %>

          <div class="row justify-content-center">
            <div class="col-md-8">
              <form
                method="POST"
                action="/admin/addproduct"
                id="myForm"
                enctype="multipart/form-data"
              >
                <div class="form-group">
                  <label for="name">Product Name</label>
                  <input
                    type="text"
                    class="form-control"
                    id="name"
                    placeholder="Product name"
                    name="name"
                    maxlength="50"
                  />
                  <span id="name-error" class="text-danger"></span>
                </div>

                <div class="form-group">
                  <label for="description">Product Description</label>
                  <textarea
                    class="form-control"
                    id="description"
                    placeholder="Product description"
                    name="description"
                    rows="4"
                    maxlength="500"
                  ></textarea>
                  <span id="description-error" class="text-danger"></span>
                </div>

                <div class="form-group">
                  <% if (categoryList && categoryList.length > 0) { %>
                  <label for="category">Category</label>
                  <select class="form-control" id="category" name="category">
                    <option value="" disabled selected>Select Category</option>
                    <% categoryList.forEach(category => { %>
                    <option value="<%= category.categoryName %>">
                      <%= category.categoryName %>
                    </option>
                    <% }) %>
                  </select>
                  <span id="category-error" class="text-danger"></span>
                  <% } else { %>
                  <p class="text-warning">No categories available. Please add categories first.</p>
                  <% } %>
                </div>

                <div class="form-group">
                  <div class="row">
                    <div class="col-md-4">
                      <label for="brandName">Brand Name</label>
                      <input
                        type="text"
                        class="form-control"
                        id="brandName"
                        placeholder="Brand name"
                        name="brandName"
                      />
                      <span id="brandName-error" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                      <label for="stockQuantity">Stock Quantity</label>
                      <input
                        type="number"
                        class="form-control"
                        id="stockQuantity"
                        placeholder="Stock"
                        name="stock"
                        min="0"
                      />
                      <span id="stockQuantity-error" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                      <label for="price">Price (₹)</label>
                      <input
                        type="number"
                        step="0.01"
                        class="form-control"
                        id="price"
                        placeholder="Price"
                        name="price"
                        min="0"
                      />
                      <span id="price-error" class="text-danger"></span>
                    </div>
                  </div>
                </div>

                <div class="form-group">
                  <label for="tags">Tags (comma separated)</label>
                  <input
                    type="text"
                    class="form-control"
                    id="tags"
                    placeholder="e.g. running, sports, lightweight"
                    name="tags"
                  />
                  <small class="form-text text-muted">Separate multiple tags with commas.</small>
                  <span id="tags-error" class="text-danger"></span>
                </div>

                <div class="form-group">
                  <label for="photos">Upload Product Images (Exactly 4 required)</label>
                  <input
                    type="file"
                    class="form-control-file"
                    id="photos"
                    name="photos"
                    accept="image/*"
                    multiple
                  />
                  <small class="form-text text-muted"
                    >Select exactly 4 images (JPEG, PNG, GIF).</small
                  >
                  <span id="photo-error" class="text-danger"></span>
                </div>

                <div class="image-preview-container d-flex flex-wrap" id="preview"></div>

                <div class="row mt-4">
                  <div class="col">
                    <button type="submit" class="btn btn-success btn-lg mr-3">ADD PRODUCT</button>
                    <button type="reset" class="btn btn-secondary btn-lg mr-3">CLEAR FIELDS</button>
                    <a href="/admin/allproducts" class="btn btn-outline-primary btn-lg">BACK</a>
                  </div>
                </div>
              </form>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="footer mt-auto py-3 bg-light">
      <div class="container text-center">
        <p class="copyright mb-0">© 2024 ShoesZone.</p>
      </div>
    </footer>

    <!-- Bootstrap 4 JS + Popper -->
    <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/popper.js@1.16.1/dist/umd/popper.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>

    <script>
      const form = document.getElementById("myForm");
      const photoInput = document.getElementById("photos");
      const imagePreviewContainer = document.getElementById("preview");
      const photoError = document.getElementById("photo-error");
      const validImageTypes = ["image/jpeg", "image/png", "image/gif", "image/webp"];

      function validateProductName(name) {
        if (name.trim() === "") return "Product name is required.";
        if (!/^[a-zA-Z]/.test(name)) return "Product name must start with a letter.";
        if (name.trim().length < 3) return "Product name must be at least 3 characters.";
        return "";
      }

      function validateDescription(description) {
        if (description.trim() === "") return "Description is required.";
        if (description.trim().length < 10) return "Description must be at least 10 characters.";
        return "";
      }

      function validateCategory(category) {
        return category === "" ? "Please select a category." : "";
      }

      function validateBrandName(brandName) {
        return brandName.trim() === "" ? "Brand name is required." : "";
      }

      function validateStockQuantity(stock) {
        if (stock === "" || isNaN(stock) || parseInt(stock) < 0) {
          return "Stock quantity must be a valid non-negative number.";
        }
        return "";
      }

      function validatePrice(price) {
        if (price === "" || isNaN(price) || parseFloat(price) < 0) {
          return "Price must be a valid positive number.";
        }
        return "";
      }

      function validateTags(tags) {
        return tags.trim() === "" ? "At least one tag is required." : "";
      }

      function validatePhoto(input) {
        const files = input.files;
        if (files.length === 0) return "Please select images.";
        if (files.length < 4) return "Please select exactly 4 images.";
        if (files.length > 4) return "Maximum 4 images allowed.";
        for (let file of files) {
          if (!validImageTypes.includes(file.type)) {
            return "Only JPEG, PNG, GIF, and WebP images are allowed.";
          }
        }
        return "";
      }

      function displayImagePreviews(files) {
        imagePreviewContainer.innerHTML = "";
        Array.from(files).forEach((file) => {
          const reader = new FileReader();
          reader.onload = (e) => {
            const img = document.createElement("img");
            img.src = e.target.result;
            img.className = "img-thumbnail m-2";
            img.style.maxHeight = "150px";
            imagePreviewContainer.appendChild(img);
          };
          reader.readAsDataURL(file);
        });
      }

      // Real-time validation on input/change
      form.querySelectorAll("input, select, textarea").forEach((field) => {
        field.addEventListener("input", () => {
          const errorSpan = document.getElementById(`${field.id}-error`);
          if (errorSpan) {
            let error = "";
            switch (field.id) {
              case "name":
                error = validateProductName(field.value);
                break;
              case "description":
                error = validateDescription(field.value);
                break;
              case "category":
                error = validateCategory(field.value);
                break;
              case "brandName":
                error = validateBrandName(field.value);
                break;
              case "stockQuantity":
                error = validateStockQuantity(field.value);
                break;
              case "price":
                error = validatePrice(field.value);
                break;
              case "tags":
                error = validateTags(field.value);
                break;
            }
            errorSpan.textContent = error;
          }
        });
      });

      photoInput.addEventListener("change", () => {
        const error = validatePhoto(photoInput);
        photoError.textContent = error;
        if (!error) {
          displayImagePreviews(photoInput.files);
        } else {
          imagePreviewContainer.innerHTML = "";
        }
      });

      // Final validation on submit
      form.addEventListener("submit", (e) => {
        e.preventDefault();

        let hasError = false;

        document.querySelectorAll('[id$="-error"]').forEach((span) => {
          span.textContent = "";
        });

        const errors = {
          name: validateProductName(document.getElementById("name").value),
          description: validateDescription(document.getElementById("description").value),
          category: validateCategory(document.getElementById("category")?.value || ""),
          brandName: validateBrandName(document.getElementById("brandName").value),
          stockQuantity: validateStockQuantity(document.getElementById("stockQuantity").value),
          price: validatePrice(document.getElementById("price").value),
          tags: validateTags(document.getElementById("tags").value),
          photo: validatePhoto(photoInput),
        };

        Object.keys(errors).forEach((key) => {
          const span = document.getElementById(`${key}-error`);
          if (span && errors[key]) {
            span.textContent = errors[key];
            hasError = true;
          }
        });

        if (!hasError) {
          form.submit();
        }
      });
    </script>
  </body>
</html>
