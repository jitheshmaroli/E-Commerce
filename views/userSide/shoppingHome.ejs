<%- include('../includes/userScripts.ejs') %>
<script>
  // Rail scroll arrow buttons
  document.querySelectorAll(".rail-prev-btn, .rail-next-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const targetId = btn.dataset.target;
      const rail = document.getElementById(targetId);
      if (!rail) return;
      const scrollAmt = 220;
      rail.scrollBy({
        left: btn.classList.contains("rail-prev-btn") ? -scrollAmt : scrollAmt,
        behavior: "smooth",
      });
    });
  });

  // Add to Cart
  document.querySelectorAll(".btn-add-cart").forEach((btn) => {
    btn.addEventListener("click", async (e) => {
      e.preventDefault();
      const productId = btn.dataset.productId;
      const productName = btn
        .closest(".product-card")
        .querySelector(".product-name")
        .textContent.trim();
      const card = btn.closest(".product-card");
      const stock = Number(card.dataset.stock);
      if (stock <= 0) {
        Swal.fire("Out of Stock!", "This product is unavailable.", "warning");
        return;
      }
      try {
        const res = await fetch("/add-to-cart", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ productId, quantity: 1 }),
        });
        if (res.status === 401) {
          Swal.fire({
            title: "Please Log In",
            text: "Login to add items to cart",
            icon: "info",
            showCancelButton: true,
            confirmButtonText: "Go to Login",
          }).then((r) => {
            if (r.isConfirmed)
              window.location.href = `/login?redirect=${encodeURIComponent(
                window.location.pathname
              )}`;
          });
          return;
        }
        const data = await res.json();
        if (data.success) updateCounts(data.cartCount, data.wishlistCount);
        if (!res.ok) {
          Swal.fire("Error", data.message || "Something went wrong", "error");
          return;
        }
        Swal.fire({
          icon: "success",
          title: "Added!",
          text: `${productName} added to cart!`,
          timer: 1500,
          showConfirmButton: false,
        });
      } catch (err) {
        console.error(err);
      }
    });
  });

  // Wishlist
  async function toggleWishlist(btn) {
    const icon = btn.querySelector("i");
    const productCard = btn.closest(".product-card");
    const productId = productCard.dataset.product;
    try {
      const res = await fetch("/toggle-wishlist", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ productId }),
      });
      const data = await res.json();
      if (res.status === 401) {
        Swal.fire({
          title: "Please Log In",
          text: "Login to add to wishlist",
          icon: "info",
          showCancelButton: true,
          confirmButtonText: "Go to Login",
        }).then((r) => {
          if (r.isConfirmed)
            window.location.href = `/login?redirect=${encodeURIComponent(
              window.location.pathname
            )}`;
        });
        return;
      }
      if (data.success) {
        icon.className = data.isInWishlist
          ? "fa fa-heart text-danger fas fs-6"
          : "fa fa-heart text-muted far fs-6";
        updateCounts(data.cartCount, data.wishlistCount);
      }
    } catch (err) {
      console.error(err);
    }
  }

  // Buy Now
  document.querySelectorAll(".btn-buy-now").forEach((btn) => {
    btn.addEventListener("click", async (e) => {
      e.preventDefault();
      const productId = btn.dataset.productId;
      const card = btn.closest(".product-card");
      const stock = Number(card.dataset.stock);
      if (stock <= 0) {
        Swal.fire("Out of Stock!", "This product is currently unavailable.", "warning");
        return;
      }
      try {
        const res = await fetch(`/checkout/${productId}/1`, { method: "GET" });
        if (res.status === 401 || (res.redirected && res.url.includes("/login"))) {
          Swal.fire({
            title: "Please Log In",
            text: "Login to proceed with checkout",
            icon: "info",
            showCancelButton: true,
            confirmButtonText: "Login Now",
          }).then((r) => {
            if (r.isConfirmed)
              window.location.href = `/login?redirect=${encodeURIComponent(
                `/checkout/${productId}/1`
              )}`;
          });
          return;
        }
        window.location.href = `/checkout/${productId}/1`;
      } catch (err) {
        console.error(err);
      }
    });
  });

  // Drag-to-scroll rails
  document.querySelectorAll(".products-row.rail-scroll").forEach((row) => {
    let isDown = false,
      startX = 0,
      scrollLeft = 0;
    const onDown = (e) => {
      isDown = true;
      startX = (e.touches ? e.touches[0].pageX : e.pageX) - row.offsetLeft;
      scrollLeft = row.scrollLeft;
    };
    const onMove = (e) => {
      if (!isDown) return;
      e.preventDefault();
      const x = (e.touches ? e.touches[0].pageX : e.pageX) - row.offsetLeft;
      row.scrollLeft = scrollLeft - (x - startX);
    };
    const onUp = () => {
      isDown = false;
    };
    row.addEventListener("mousedown", onDown);
    row.addEventListener("mousemove", onMove);
    row.addEventListener("mouseleave", onUp);
    row.addEventListener("mouseup", onUp);
    row.addEventListener("touchstart", onDown, { passive: true });
    row.addEventListener("touchmove", onMove, { passive: false });
    row.addEventListener("touchend", onUp);
  });
</script>
