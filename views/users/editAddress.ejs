<%- include('../includes/userHead.ejs') %>
<link rel="stylesheet" href="/css/profile-shared.css" />

<%- include('../includes/userHeader.ejs') %>

<% if (user) { %>
<div class="account-shell">
  <%- include('../includes/accountNav.ejs', { activePage: 'address' }) %>

  <div class="account-content">
    <div class="account-card">
      <div class="account-card-header">
        <div class="account-card-icon"><i class="fas fa-pencil-alt"></i></div>
        <h2>Edit Address</h2>
      </div>
      <div class="account-card-body">
        <% if (address) { %>
        <form
          id="edit-address-form"
          action="/address/edit?addressId=<%= address._id %>"
          method="POST"
        >
          <div class="acc-form">
            <div class="acc-field">
              <label for="name">Full Name</label>
              <input type="text" id="name" name="name" value="<%= address.name %>" required />
            </div>

            <div class="acc-form-row">
              <div class="acc-field">
                <label for="houseName">House / Flat No.</label>
                <input
                  type="text"
                  id="houseName"
                  name="houseName"
                  value="<%= address.houseName %>"
                  required
                />
              </div>
              <div class="acc-field">
                <label for="street">Street / Area</label>
                <input
                  type="text"
                  id="street"
                  name="street"
                  value="<%= address.street %>"
                  required
                />
              </div>
            </div>

            <div class="acc-form-row">
              <div class="acc-field">
                <label for="city">City</label>
                <input type="text" id="city" name="city" value="<%= address.city %>" required />
              </div>
              <div class="acc-field">
                <label for="district">District</label>
                <input
                  type="text"
                  id="district"
                  name="district"
                  value="<%= address.district %>"
                  required
                />
              </div>
            </div>

            <div class="acc-form-row">
              <div class="acc-field">
                <label for="state">State</label>
                <input type="text" id="state" name="state" value="<%= address.state %>" required />
              </div>
              <div class="acc-field">
                <label for="pinCode">PIN Code</label>
                <input
                  type="text"
                  id="pinCode"
                  name="pinCode"
                  value="<%= address.pinCode %>"
                  inputmode="numeric"
                  pattern="\d{6}"
                  maxlength="6"
                  required
                  oninput="this.value = this.value.replace(/[^0-9]/g, '')"
                  onkeyup="limitPincode()"
                />
                <% if (message) { %>
                <span class="field-error"><%= message %></span>
                <% } %>
              </div>
            </div>

            <div class="acc-check">
              <input type="checkbox" id="isDefault" name="isDefault" <%= address.isDefault ?
              'checked' : '' %> />
              <label for="isDefault">Set as Default Address</label>
            </div>

            <div style="display: flex; gap: 0.75rem; align-items: center; flex-wrap: wrap">
              <button type="submit" id="edit-address-submit-btn" class="btn-acc-submit" disabled>
                <i class="fas fa-save"></i> Update Address
              </button>
              <a href="/address" class="btn-acc-ghost"> <i class="fas fa-arrow-left"></i> Back </a>
            </div>
          </div>
        </form>
        <% } else { %>
        <div class="addr-empty">
          <i class="fas fa-exclamation-circle"></i>
          <p>Address not found.</p>
          <a href="/address" class="btn-acc-ghost"
            ><i class="fas fa-arrow-left me-1"></i> Back to Addresses</a
          >
        </div>
        <% } %>
      </div>
    </div>
  </div>
</div>
<% } %>

<%- include('../includes/userFooter.ejs') %>
<%- include('../includes/userScripts.ejs') %>
<%- include('../includes/addressValidation.ejs') %>

<script>
  document.getElementById("edit-address-form")?.addEventListener("submit", async function (e) {
    e.preventDefault();
    const formData = new FormData(this);
    const data = Object.fromEntries(formData);
    data.isDefault = document.getElementById("isDefault").checked;
    try {
      const res = await fetch(this.action, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });
      const result = await res.json();
      if (result.success) {
        Swal.fire({
          icon: "success",
          title: "Address Updated!",
          timer: 2000,
          showConfirmButton: false,
        }).then(() => {
          window.location.href = "/address";
        });
      } else {
        Swal.fire({ icon: "error", title: "Error", text: result.message || "Failed to update." });
      }
    } catch (err) {
      Swal.fire({ icon: "error", title: "Network Error", text: "Something went wrong." });
    }
  });
</script>
