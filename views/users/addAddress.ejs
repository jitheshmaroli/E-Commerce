<%- include('../includes/userHead.ejs') %>
<link rel="stylesheet" href="/css/addAddress.css" />

<%- include('../includes/userHeader.ejs') %>

<main class="main">
  <% if (user) { %>
  <aside class="sidebar">
    <div class="profile-section">
      <div class="avatar">
        <img
          src="<%= user.photo && user.photo.length > 0 ? '/uploads/' + user.photo[0].filename : '/images/avatar.jpg' %>"
          alt="Profile Avatar" />
      </div>
      <ul class="profile-links">
        <li><a href="/user-profile">User Profile</a></li>
        <li><a href="/address">Address</a></li>
        <li><a href="/order-history">Order History</a></li>
        <li><a href="/change-password">Change Password</a></li>
        <li><a href="/wallet">Wallet</a></li>
      </ul>
    </div>
  </aside>
  <section class="content">
    <h2 class="page-title">Add New Address</h2>
    <form
      id="add-address-form"
      action="/addresses/add"
      method="post"
      onsubmit="return validateForm()">
      <input type="hidden" id="userId" name="userId" value="<%= user._id %>" />
      <div class="form-group">
        <label for="name">Full Name:</label>
        <input type="text" id="name" name="name" maxlength="50" required />
      </div>
      <div class="form-group">
        <label for="houseName">House Name/Number:</label>
        <input
          type="text"
          id="houseName"
          name="houseName"
          maxlength="50"
          required />
      </div>
      <div class="form-group">
        <label for="street">Street Address:</label>
        <input type="text" id="street" name="street" maxlength="50" required />
      </div>
      <div class="form-group">
        <label for="city">City:</label>
        <input type="text" id="city" name="city" maxlength="50" required />
      </div>
      <div class="form-group">
        <label for="district">District:</label>
        <input
          type="text"
          id="district"
          name="district"
          maxlength="50"
          required />
      </div>
      <div class="form-group">
        <label for="state">State:</label>
        <input type="text" id="state" name="state" maxlength="50" required />
      </div>
      <div class="form-group">
        <label for="pinCode">PIN Code:</label>
        <input
          type="number"
          id="pinCode"
          name="pinCode"
          minlength="6"
          maxlength="6"
          required
          onkeyup="limitPincode(this)" />
      </div>
      <div class="form-group">
        <button type="submit" class="btn product-btn">Add Address</button>
      </div>
    </form>
  </section>
  <% } %>
</main>

<%- include('../includes/userFooter.ejs') %> <%-
include('../includes/userScripts.ejs') %>

<script>
  function limitPincode(input) {
    if (input.value.length > 6) input.value = input.value.slice(0, 6);
  }

  function validateForm() {
    const name = document.getElementById("name").value.trim();
    const houseName = document.getElementById("houseName").value.trim();
    const street = document.getElementById("street").value.trim();
    const city = document.getElementById("city").value.trim();
    const district = document.getElementById("district").value.trim();
    const state = document.getElementById("state").value.trim();
    const pinCode = document.getElementById("pinCode").value.trim();

    const namePattern = /^[a-zA-Z\s]+$/;

    if (!name || !namePattern.test(name)) {
      alert(
        "Name must not be empty, contain only spaces, or have special characters."
      );
      return false;
    }

    if (!houseName || !street || !city || !district || !state || !pinCode) {
      alert("All fields are required.");
      return false;
    }

    if (pinCode.length !== 6 || isNaN(pinCode)) {
      alert("PIN Code must be a 6-digit number.");
      return false;
    }

    return true;
  }

  function setCategory(category) {
    const selectedCategory = document.getElementById("selectedCategory");
    if (selectedCategory) selectedCategory.value = category;
    const dropdownText = document.querySelector(".dropdown-toggle-text");
    if (dropdownText)
      dropdownText.textContent =
        category.charAt(0).toUpperCase() + category.slice(1);
  }
</script>
