<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Verify OTP – ShoeZone</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
    />
    <link rel="stylesheet" href="/css/auth-shared.css" />
  </head>
  <body>
    <div class="auth-page">
      <div class="auth-panel-brand">
        <div class="auth-brand-top">
          <a href="/" class="auth-logo-wrap">
            <img src="/test.jpg" alt="ShoeZone" class="auth-logo-img" />
            <span class="auth-logo-text">Shoe<em>Zone</em></span>
          </a>
        </div>
        <div class="auth-panel-mid">
          <div class="auth-panel-tagline">Almost<br />There,<br /><span>Hang On.</span></div>
          <p class="auth-panel-sub">
            Enter the OTP we sent to your email to continue resetting your password.
          </p>
        </div>
        <div class="auth-panel-bottom">
          <div class="auth-stat">
            <div class="auth-stat-num">6</div>
            <div class="auth-stat-label">Digit OTP</div>
          </div>
          <div class="auth-stat">
            <div class="auth-stat-num">60s</div>
            <div class="auth-stat-label">Valid For</div>
          </div>
        </div>
      </div>

      <div class="auth-panel-form">
        <div class="auth-form-scroll">
          <div class="auth-form-inner">
            <div class="auth-form-title">Enter OTP</div>
            <div class="auth-form-sub">Check your inbox for the 6-digit code</div>

            <div class="auth-alert auth-alert-info" id="otpInfoAlert" style="margin-bottom: 1.5rem">
              <i class="fas fa-envelope"></i>
              <span
                >OTP sent to <strong><%= maskedEmail %></strong></span
              >
            </div>

            <% if (message) { %>
            <div class="auth-alert auth-alert-error">
              <i class="fas fa-circle-exclamation"></i>
              <span><%= message %></span>
              <button class="auth-alert-close" onclick="this.closest('.auth-alert').remove()">
                &times;
              </button>
            </div>
            <% } %>

            <form
              action="/forgot-password-verify-otp"
              method="POST"
              id="otpForm"
              data-remaining-time="<%= remainingTime || 60 %>"
              data-user-email="<%= userData %>"
              data-user-masked-email="<%= maskedEmail %>"
              novalidate
            >
              <input type="hidden" name="email" value="<%= userData %>" />

              <div class="auth-field" style="margin-bottom: 1rem">
                <label style="text-align: center; display: block">6-Digit OTP</label>
                <div class="otp-row">
                  <input
                    type="password"
                    class="otp-box"
                    maxlength="1"
                    data-index="0"
                    inputmode="numeric"
                    pattern="[0-9]*"
                    required
                    autofocus
                  />
                  <input
                    type="password"
                    class="otp-box"
                    maxlength="1"
                    data-index="1"
                    inputmode="numeric"
                    pattern="[0-9]*"
                    required
                  />
                  <input
                    type="password"
                    class="otp-box"
                    maxlength="1"
                    data-index="2"
                    inputmode="numeric"
                    pattern="[0-9]*"
                    required
                  />
                  <input
                    type="password"
                    class="otp-box"
                    maxlength="1"
                    data-index="3"
                    inputmode="numeric"
                    pattern="[0-9]*"
                    required
                  />
                  <input
                    type="password"
                    class="otp-box"
                    maxlength="1"
                    data-index="4"
                    inputmode="numeric"
                    pattern="[0-9]*"
                    required
                  />
                  <input
                    type="password"
                    class="otp-box"
                    maxlength="1"
                    data-index="5"
                    inputmode="numeric"
                    pattern="[0-9]*"
                    required
                  />
                </div>
                <input type="hidden" name="otp" id="hiddenOtp" required />
                <div
                  id="otpError"
                  style="
                    font-size: 0.78rem;
                    color: var(--red-err);
                    text-align: center;
                    margin-top: 0.5rem;
                    min-height: 1.2rem;
                  "
                ></div>
              </div>

              <button type="submit" id="submitBtn" class="btn-auth-submit" disabled>
                <i class="fas fa-arrow-right" style="margin-right: 0.5rem"></i>Verify &amp; Continue
              </button>

              <div class="otp-timer-row">
                <span class="otp-timer-text" id="timer"></span>
                <button type="button" id="resendBtn" class="btn-resend" disabled>Resend OTP</button>
              </div>
            </form>

            <div class="auth-links" style="margin-top: 1.5rem">
              <a href="/login"
                ><i class="fas fa-arrow-left" style="margin-right: 0.3rem"></i>Back to Login</a
              >
            </div>
          </div>
        </div>
        <div class="auth-form-footer">© 2026 ShoeZone. All rights reserved.</div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      const form = document.getElementById("otpForm");
      const otpBoxes = document.querySelectorAll(".otp-box");
      const hiddenOtp = document.getElementById("hiddenOtp");
      const submitBtn = document.getElementById("submitBtn");
      const otpError = document.getElementById("otpError");
      const resendBtn = document.getElementById("resendBtn");
      const timerEl = document.getElementById("timer");
      const infoAlert = document.getElementById("otpInfoAlert");
      const userEmail = form.dataset.userEmail || "";
      const maskedEmail = form.dataset.userMaskedEmail || "";

      let timeLeft = parseInt(form.dataset.remainingTime) || 60;
      let timerId = null;

      function updateHidden() {
        hiddenOtp.value = Array.from(otpBoxes)
          .map((b) => b.value)
          .join("");
      }

      otpBoxes.forEach((box, i) => {
        box.addEventListener("input", (e) => {
          const val = e.target.value.replace(/\D/, "");
          box.value = val;
          box.classList.toggle("filled", !!val);
          if (val && i < 5) otpBoxes[i + 1].focus();
          updateHidden();
          validate();
        });
        box.addEventListener("keydown", (e) => {
          if (e.key === "Backspace" && !box.value && i > 0) {
            otpBoxes[i - 1].focus();
            otpBoxes[i - 1].classList.remove("filled");
          }
        });
        box.addEventListener("paste", (e) => {
          e.preventDefault();
          const text = (e.clipboardData || window.clipboardData).getData("text").replace(/\D/g, "");
          if (text) {
            text
              .split("")
              .slice(0, 6 - i)
              .forEach((d, idx) => {
                if (otpBoxes[i + idx]) {
                  otpBoxes[i + idx].value = d;
                  otpBoxes[i + idx].classList.add("filled");
                }
              });
            otpBoxes[Math.min(i + text.length, 5)]?.focus();
            updateHidden();
            validate();
          }
        });
      });

      function validate() {
        const ok = hiddenOtp.value.length === 6;
        otpError.textContent = !ok && hiddenOtp.value.length > 0 ? "Enter all 6 digits." : "";
        submitBtn.disabled = !ok;
      }

      function startTimer() {
        if (timeLeft <= 0) {
          resendBtn.disabled = false;
          timerEl.textContent = "";
          return;
        }
        resendBtn.disabled = true;
        timerEl.textContent = `Resend in ${timeLeft}s`;
        timerId = setInterval(() => {
          timeLeft--;
          timerEl.textContent = `Resend in ${timeLeft}s`;
          if (timeLeft <= 0) {
            clearInterval(timerId);
            timerEl.textContent = "";
            resendBtn.disabled = false;
          }
        }, 1000);
      }

      resendBtn.addEventListener("click", async () => {
        resendBtn.disabled = true;
        timeLeft = 60;
        startTimer();
        try {
          const res = await fetch("/resend-otp", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ email: userEmail }),
          });
          const data = await res.json();
          if (data.success) {
            infoAlert.innerHTML = `<i class="fas fa-envelope"></i><span>New OTP sent to <strong>${maskedEmail}</strong></span>`;
            infoAlert.className = "auth-alert auth-alert-info";
          } else {
            alert(data.message || "Failed to resend OTP");
            timeLeft = 0;
            clearInterval(timerId);
            startTimer();
          }
        } catch {
          alert("Network error. Please try again.");
          timeLeft = 0;
          clearInterval(timerId);
          startTimer();
        }
      });

      startTimer();
      validate();
      otpBoxes[0]?.focus();
    </script>
  </body>
</html>
