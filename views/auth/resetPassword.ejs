<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset Password - ShoeZone</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/auth-shared.css" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
    />
  </head>
  <body>
    <header class="header">
      <div class="brand">
        <a class="navbar-brand nav-link" style="color: aliceblue" href="/">
          <img src="/test.jpg" alt="Brand Logo" />
          <span class="brand-name">ShoeZone</span>
        </a>
      </div>
    </header>

    <div class="container">
      <div class="form-container card shadow">
        <div class="card-body p-4">
          <h3 class="text-center mb-4">Reset Your Password</h3>
          <p class="text-center text-muted mb-4">Choose a strong password</p>

          <% if (message) { %>
          <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <%= message %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
          <% } %>

          <form action="/reset-password" method="POST" id="resetForm" novalidate>
            <input type="hidden" name="email" value="<%= userData || '' %>" />

            <div class="mb-4">
              <label for="password" class="form-label">New Password</label>

              <div class="input-group">
                <input
                  type="password"
                  class="form-control"
                  id="password"
                  name="password"
                  required
                  minlength="8"
                />

                <span class="input-group-text toggle-password" id="togglePassword">
                  <i class="bi bi-eye-slash"></i>
                </span>

                <div class="invalid-feedback">Password must be at least 8 characters</div>
              </div>

              <small id="passwordHint" class="form-text text-muted d-block mt-1"></small>
            </div>

            <div class="mb-4">
              <label for="confirmPassword" class="form-label">Confirm Password</label>

              <div class="input-group">
                <input
                  type="password"
                  class="form-control"
                  id="confirmPassword"
                  name="confirmPassword"
                  required
                />

                <span class="input-group-text toggle-password" id="toggleConfirm">
                  <i class="bi bi-eye-slash"></i>
                </span>

                <div class="invalid-feedback" id="matchFeedback">Passwords do not match</div>
              </div>
            </div>

            <button type="submit" class="btn btn-dark w-100 py-2">Reset Password</button>
          </form>

          <div class="text-center mt-4">
            <a href="/login" class="text-muted">← Back to Login</a>
          </div>
        </div>
      </div>
    </div>

    <footer class="footer">
      <p class="copyright">© 2026 ShoeZone</p>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      const pw = document.getElementById("password");
      const cpw = document.getElementById("confirmPassword");
      const form = document.getElementById("resetForm");
      const hint = document.getElementById("passwordHint");
      const matchFb = document.getElementById("matchFeedback");

      const togglePw = document.getElementById("togglePassword");
      const toggleCpw = document.getElementById("toggleConfirm");

      function validatePassword(password) {
        if (password.length < 8) {
          return "Password must be at least 8 characters long.";
        }

        const hasUppercase = /[A-Z]/.test(password);
        const hasLowercase = /[a-z]/.test(password);
        const hasNumber = /\d/.test(password);
        const hasSymbol = /[!@#$%^&*()_+\-=[\]{};':".,<>/?\\|~`]/g.test(password);

        if (!hasUppercase || !hasLowercase || !hasNumber || !hasSymbol) {
          return "Password must contain at least one uppercase letter, lowercase letter, number, and symbol.";
        }

        return null;
      }
      // Password strength hint
      const updateHint = () => {
        const val = pw.value;
        const pwMessage = validatePassword(val);

        if (!pwMessage) {
          hint.textContent = "Strong password ✓";
          hint.className = "text-success";
        } else {
          hint.textContent = pwMessage;
          hint.className = "text-danger";
        }
      };

      // Match check
      const checkMatch = () => {
        if (!cpw.value) {
          matchFb.style.display = "none";
          cpw.classList.remove("is-invalid");
          return;
        }
        if (pw.value === cpw.value) {
          matchFb.style.display = "none";
          cpw.classList.remove("is-invalid");
          cpw.classList.add("is-valid");
        } else {
          matchFb.style.display = "block";
          cpw.classList.add("is-invalid");
          cpw.classList.remove("is-valid");
        }
      };

      pw.addEventListener("input", () => {
        pw.classList.remove("is-invalid");
        updateHint();
        checkMatch();
      });

      cpw.addEventListener("input", () => {
        cpw.classList.remove("is-invalid");
        checkMatch();
      });

      // Toggle visibility
      togglePw.addEventListener("click", () => {
        const isPassword = pw.type === "password";
        pw.type = isPassword ? "text" : "password";
        togglePw.innerHTML = `<i class="bi bi-eye${isPassword ? "" : "-slash"}"></i>`;
      });

      toggleCpw.addEventListener("click", () => {
        const isPassword = cpw.type === "password";
        cpw.type = isPassword ? "text" : "password";
        toggleCpw.innerHTML = `<i class="bi bi-eye${isPassword ? "" : "-slash"}"></i>`;
      });

      form.addEventListener("submit", (e) => {
        if (pw.value.length < 8) {
          e.preventDefault();
          pw.classList.add("is-invalid");
          pw.focus();
          return;
        }
        if (pw.value !== cpw.value) {
          e.preventDefault();
          cpw.classList.add("is-invalid");
          cpw.focus();
          alert("Passwords do not match!");
        }
      });
    </script>
  </body>
</html>
