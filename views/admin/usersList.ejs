<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Users List - Admin</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdn.datatables.net/2.0.8/css/dataTables.bootstrap5.min.css"
    />
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/adminUsersList.css" />
  </head>
  <body class="bg-light">
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
      <div class="container-fluid">
        <a class="navbar-brand fw-bold" href="/admin">
          <img src="/test.jpg" alt="Logo" width="35" class="d-inline-block align-text-top me-2" />
          SportZilon Admin
        </a>
        <button
          class="navbar-toggler"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#navbarNav"
        >
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav ms-auto">
            <li class="nav-item dropdown">
              <a
                class="nav-link dropdown-toggle text-white"
                href="#"
                id="adminDropdown"
                role="button"
                data-bs-toggle="dropdown"
              >
                ADMIN
              </a>
              <ul class="dropdown-menu dropdown-menu-end">
                <li><a class="dropdown-item" href="/admin/logout">Logout</a></li>
              </ul>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <div class="d-flex">
      <!-- Sidebar -->
      <aside class="sidebar bg-dark text-white p-3" style="width: 250px; min-height: 100vh">
        <div class="list-group list-group-flush">
          <a
            href="/admin"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3"
          >
            <i class="fas fa-home me-2"></i> HOME
          </a>
          <a
            href="/admin/allproducts"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3"
          >
            <i class="fas fa-box me-2"></i> ALL PRODUCTS
          </a>
          <a
            href="/admin/ordersList"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3"
          >
            <i class="fas fa-shopping-cart me-2"></i> ORDERS LIST
          </a>
          <a
            href="/admin/usersList"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3 active"
          >
            <i class="fas fa-users me-2"></i> USERS LIST
          </a>
          <a
            href="/admin/categoryList"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3"
          >
            <i class="fas fa-tags me-2"></i> CATEGORY LIST
          </a>
          <a
            href="/admin/couponList"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3"
          >
            <i class="fas fa-gift me-2"></i> COUPON LIST
          </a>
          <a
            href="/admin/offers"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3"
          >
            <i class="fas fa-percentage me-2"></i> OFFERS
          </a>
        </div>
      </aside>

      <!-- Main Content -->
      <main class="content flex-grow-1 p-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
          <h2 class="mb-0">Users List</h2>
        </div>

        <% if (users && users.length > 0) { %>
        <div class="card shadow-lg border-0">
          <div class="card-body p-0">
            <div class="table-responsive">
              <table id="usersTable" class="table table-hover table-striped align-middle">
                <thead class="table-dark">
                  <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Status</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% users.forEach(user => { %>
                  <tr data-user-email="<%= user.email %>">
                    <td class="fw-bold"><%= user.name || '—' %></td>
                    <td><%= user.email %></td>
                    <td>
                      <span
                        id="status-<%= user.email %>"
                        class="badge <%= user.isBlocked ? 'bg-danger' : 'bg-success' %>"
                      >
                        <%= user.isBlocked ? 'BLOCKED' : 'ACTIVE' %>
                      </span>
                    </td>
                    <td>
                      <button
                        class="btn btn-sm toggle-block-btn <%= user.isBlocked ? 'btn-success' : 'btn-danger' %>"
                        data-email="<%= user.email %>"
                        data-blocked="<%= user.isBlocked %>"
                        title="<%= user.isBlocked ? 'Unblock' : 'Block' %>"
                      >
                        <%= user.isBlocked ? 'UNBLOCK' : 'BLOCK' %>
                      </button>
                    </td>
                  </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
        <% } else { %>
        <div class="alert alert-info text-center py-5">
          <i class="fas fa-users fa-3x mb-3 text-muted"></i>
          <h4>No users found</h4>
          <p class="text-muted">No regular users registered yet.</p>
        </div>
        <% } %>
      </main>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
      $(document).ready(function () {
        $("#usersTable").DataTable({
          responsive: true,
          pageLength: 10,
          lengthMenu: [5, 10, 25, 50],
          order: [[0, "asc"]],
          language: {
            search: "Search users:",
            emptyTable: "No users found",
          },
        });
      });

      // Toggle Block/Unblock with SweetAlert
      document.querySelectorAll(".toggle-block-btn").forEach((btn) => {
        btn.addEventListener("click", async function () {
          const userEmail = this.dataset.email;
          const isBlocked = this.dataset.blocked === "true";
          const action = isBlocked ? "unblock" : "block";

          const result = await Swal.fire({
            title: `Are you sure?`,
            text: `This will ${action} the user!`,
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: isBlocked ? "#28a745" : "#d33",
            cancelButtonColor: "#6c757d",
            confirmButtonText: `Yes, ${action.toUpperCase()}!`,
          });

          if (result.isConfirmed) {
            try {
              const res = await fetch(`/admin/usersList/${userEmail}`, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
              });

              const data = await res.json();

              if (data.message && data.user) {
                const statusBadge = document.getElementById(`status-${userEmail}`);
                const toggleBtn = this;

                if (data.user.isBlocked) {
                  statusBadge.textContent = "BLOCKED";
                  statusBadge.classList.remove("bg-success");
                  statusBadge.classList.add("bg-danger");
                  toggleBtn.textContent = "UNBLOCK";
                  toggleBtn.classList.remove("btn-danger");
                  toggleBtn.classList.add("btn-success");
                  toggleBtn.dataset.blocked = "true";
                } else {
                  statusBadge.textContent = "ACTIVE";
                  statusBadge.classList.remove("bg-danger");
                  statusBadge.classList.add("bg-success");
                  toggleBtn.textContent = "BLOCK";
                  toggleBtn.classList.remove("btn-success");
                  toggleBtn.classList.add("btn-danger");
                  toggleBtn.dataset.blocked = "false";
                }

                Swal.fire({
                  icon: "success",
                  title: "Updated!",
                  text: `User ${data.user.isBlocked ? "blocked" : "unblocked"} successfully.`,
                  timer: 1800,
                  showConfirmButton: false,
                });
              } else {
                Swal.fire("Error!", data.error || "Failed to update user status.", "error");
              }
            } catch (err) {
              console.error("Toggle error:", err);
              Swal.fire("Error!", "Network error occurred.", "error");
            }
          }
        });
      });
    </script>
  </body>
</html>
