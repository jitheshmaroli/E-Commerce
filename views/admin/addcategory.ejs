<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Add New Category - Admin</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    />
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/addCategory.css" />
  </head>
  <body class="bg-light">
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
      <div class="container-fluid">
        <a class="navbar-brand fw-bold" href="/admin">
          <img src="/test.jpg" alt="Logo" width="35" class="d-inline-block align-text-top me-2" />
          SportZilon Admin
        </a>
        <button
          class="navbar-toggler"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#navbarNav"
        >
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav ms-auto">
            <li class="nav-item dropdown">
              <a
                class="nav-link dropdown-toggle text-white"
                href="#"
                id="adminDropdown"
                role="button"
                data-bs-toggle="dropdown"
              >
                ADMIN
              </a>
              <ul class="dropdown-menu dropdown-menu-end">
                <li><a class="dropdown-item" href="/admin/logout">Logout</a></li>
              </ul>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <div class="d-flex">
      <!-- Sidebar -->
      <aside class="sidebar bg-dark text-white p-3" style="width: 250px; min-height: 100vh">
        <div class="list-group list-group-flush">
          <a
            href="/admin"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3"
          >
            <i class="fas fa-home me-2"></i> HOME
          </a>
          <a
            href="/admin/allproducts"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3"
          >
            <i class="fas fa-box me-2"></i> ALL PRODUCTS
          </a>
          <a
            href="/admin/ordersList"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3"
          >
            <i class="fas fa-shopping-cart me-2"></i> ORDERS LIST
          </a>
          <a
            href="/admin/usersList"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3"
          >
            <i class="fas fa-users me-2"></i> USERS LIST
          </a>
          <a
            href="/admin/categoryList"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3 active"
          >
            <i class="fas fa-tags me-2"></i> CATEGORY LIST
          </a>
          <a
            href="/admin/couponList"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3"
          >
            <i class="fas fa-gift me-2"></i> COUPON LIST
          </a>
          <a
            href="/admin/offers"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3"
          >
            <i class="fas fa-percentage me-2"></i> OFFERS
          </a>
        </div>
      </aside>

      <!-- Main Content -->
      <main class="content flex-grow-1 p-4">
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb bg-transparent p-0 mb-4">
            <li class="breadcrumb-item">
              <a href="/admin/categoryList" class="text-dark">Category List</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Add New Category</li>
          </ol>
        </nav>

        <div class="card shadow-lg border-0" style="max-width: 550px; margin: 0 auto">
          <div class="card-header bg-dark text-white text-center py-3">
            <h4 class="mb-0">Add New Category</h4>
          </div>
          <div class="card-body p-4">
            <form id="categoryForm" method="POST" action="/admin/addcategory">
              <div id="globalError" class="text-danger mb-3 fw-bold"></div>

              <!-- Category Name -->
              <div class="mb-4">
                <label for="categoryName" class="form-label fw-bold"
                  >Category Name <span class="text-danger">*</span></label
                >
                <input
                  type="text"
                  class="form-control"
                  id="categoryName"
                  name="categoryName"
                  placeholder="Enter category name"
                  maxlength="20"
                  required
                />
                <small id="categoryNameError" class="text-danger"></small>
              </div>

              <!-- Description -->
              <div class="mb-4">
                <label for="description" class="form-label fw-bold"
                  >Description <span class="text-danger">*</span></label
                >
                <input
                  type="text"
                  class="form-control"
                  id="description"
                  name="description"
                  placeholder="Enter category description"
                  maxlength="100"
                  required
                />
                <small id="descriptionError" class="text-danger"></small>
              </div>

              <!-- Buttons -->
              <div class="d-flex gap-3">
                <button type="submit" class="btn btn-dark flex-grow-1 py-2 fw-bold">
                  ADD CATEGORY
                </button>
                <button
                  type="button"
                  class="btn btn-outline-dark flex-grow-1 py-2"
                  onclick="clearFields()"
                >
                  CLEAR
                </button>
                <a
                  href="/admin/categoryList"
                  class="btn btn-outline-secondary flex-grow-1 py-2 text-center"
                  >BACK</a
                >
              </div>
            </form>
          </div>
        </div>
      </main>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
      // Real-time validation
      const inputs = {
        categoryName: document.getElementById("categoryName"),
        description: document.getElementById("description"),
      };

      const errors = {
        categoryName: document.getElementById("categoryNameError"),
        description: document.getElementById("descriptionError"),
      };

      Object.values(inputs).forEach((input) => {
        if (input) {
          input.addEventListener("input", () => validateField(input));
          input.addEventListener("blur", () => validateField(input));
        }
      });

      function validateField(input) {
        const value = input.value.trim();
        const id = input.id;
        let errorMsg = "";

        if (id === "categoryName") {
          if (!value) errorMsg = "Category name is required";
          else if (!/^[A-Za-z\s]+$/.test(value)) errorMsg = "Only letters and spaces allowed";
          else if (value.length < 3) errorMsg = "Name must be at least 3 characters";
          else if (value.length > 20) errorMsg = "Name must be at most 20 characters";
        } else if (id === "description") {
          if (!value) errorMsg = "Description is required";
          else if (value.length < 3) errorMsg = "Description must be at least 3 characters";
          else if (value.length > 100) errorMsg = "Description must be at most 100 characters";
        }

        errors[id].textContent = errorMsg;
        input.classList.toggle("is-invalid", !!errorMsg);
      }

      function isFormValid() {
        let valid = true;
        Object.values(inputs).forEach((input) => {
          if (input) {
            validateField(input);
            if (input.classList.contains("is-invalid")) valid = false;
          }
        });
        return valid;
      }

      // Submit with SweetAlert
      document.getElementById("categoryForm").addEventListener("submit", async function (e) {
        e.preventDefault();

        if (!isFormValid()) {
          Swal.fire({
            icon: "warning",
            title: "Invalid Input",
            text: "Please fix the highlighted errors",
            timer: 2500,
            showConfirmButton: false,
          });
          return;
        }

        const formData = new FormData(this);
        const data = Object.fromEntries(formData);

        try {
          const res = await fetch("/admin/addcategory", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(data),
          });

          const result = await res.json();

          if (result.success) {
            await Swal.fire({
              icon: "success",
              title: "Success",
              text: "Category added successfully!",
              timer: 2000,
              showConfirmButton: false,
            });
            window.location.href = "/admin/categoryList";
          } else {
            Swal.fire({
              icon: "error",
              title: "Error",
              text: result.message || "Failed to add category",
            });
          }
        } catch (err) {
          Swal.fire({
            icon: "error",
            title: "Network Error",
            text: "Failed to connect. Please try again.",
          });
        }
      });

      function clearFields() {
        document.getElementById("categoryName").value = "";
        document.getElementById("description").value = "";
        document.querySelectorAll(".text-danger").forEach((el) => (el.textContent = ""));
        document
          .querySelectorAll(".form-control")
          .forEach((el) => el.classList.remove("is-invalid"));
      }
    </script>
  </body>
</html>
