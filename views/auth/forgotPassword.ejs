<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Forgot Password – ShoeZone</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <link rel="stylesheet" href="/css/auth-shared.css" />
</head>
<body>

<div class="auth-page">

  <div class="auth-panel-brand">
    <div class="auth-brand-top">
      <a href="/" class="auth-logo-wrap">
        <img src="/test.jpg" alt="ShoeZone" class="auth-logo-img" />
        <span class="auth-logo-text">Shoe<em>Zone</em></span>
      </a>
    </div>
    <div class="auth-panel-mid">
      <div class="auth-panel-tagline">
        Lock<span>ed</span><br>Out?<br>No Stress.
      </div>
      <p class="auth-panel-sub">We'll send a one-time password to your registered email so you can get back in.</p>
    </div>
    <div class="auth-panel-bottom">
      <div class="auth-stat"><div class="auth-stat-num">OTP</div><div class="auth-stat-label">Secure</div></div>
      <div class="auth-stat"><div class="auth-stat-num">60s</div><div class="auth-stat-label">Expiry</div></div>
    </div>
  </div>

  <div class="auth-panel-form">
    <div class="auth-form-scroll">
      <div class="auth-form-inner">

        <div class="auth-form-title">Forgot Password</div>
        <div class="auth-form-sub">Enter your registered email and we'll send you an OTP to reset your password.</div>

        <% if (message) { %>
        <div class="auth-alert auth-alert-error">
          <i class="fas fa-circle-exclamation"></i>
          <span><%= message %></span>
          <button class="auth-alert-close" onclick="this.closest('.auth-alert').remove()">&times;</button>
        </div>
        <% } %>

        <form action="/forgot-password" method="POST" id="forgotForm" novalidate>

          <div class="auth-field">
            <label for="email">Registered Email</label>
            <input type="email" id="email" name="email" placeholder="name@example.com" required autocomplete="email" autofocus />
            <span class="auth-field-error" id="emailError">Please enter a valid email address.</span>
          </div>

          <button type="submit" class="btn-auth-submit">
            <i class="fas fa-paper-plane" style="margin-right:.5rem"></i>Send OTP
          </button>

          <div class="auth-links">
            <a href="/login"><i class="fas fa-arrow-left" style="margin-right:.3rem"></i>Back to Login</a>
          </div>

        </form>
      </div>
    </div>
    <div class="auth-form-footer">© 2026 ShoeZone. All rights reserved.</div>
  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  const emailInput = document.getElementById('email');
  const emailError = document.getElementById('emailError');
  const emailRe = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  emailInput.addEventListener('input', () => {
    const ok = emailRe.test(emailInput.value.trim());
    emailInput.classList.toggle('is-invalid', !ok && emailInput.value.length > 0);
    emailInput.classList.toggle('is-valid', ok);
    emailError.classList.toggle('visible', !ok && emailInput.value.length > 0);
  });

  document.getElementById('forgotForm').addEventListener('submit', e => {
    if (!emailRe.test(emailInput.value.trim())) {
      e.preventDefault();
      emailInput.classList.add('is-invalid');
      emailError.classList.add('visible');
      emailInput.focus();
    }
  });
</script>
</body>
</html>
