<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dashboard · ShoeZone Admin</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/moment@2.30.1/moment.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-moment@1.0.1"></script>
    <link rel="stylesheet" href="/css/admin-shared.css" />
  </head>
  <body>
    <!-- ── Top bar ── -->
    <header class="admin-topbar">
      <a href="/admin" class="topbar-brand">
        <div class="topbar-brand-logo"><img src="/test.jpg" alt="Logo" /></div>
        <span class="topbar-brand-name">ShoeZone <em>Admin</em></span>
      </a>
      <div class="topbar-breadcrumb">
        <i class="fas fa-home"></i>
        <i class="fas fa-chevron-right"></i>
        <span>Dashboard</span>
      </div>
      <div class="topbar-right">
        <div class="topbar-admin-pill" id="adminPill">
          <div class="topbar-admin-avatar">A</div>
          <span class="topbar-admin-label">Admin</span>
          <i class="fas fa-chevron-down topbar-admin-chevron"></i>
          <div class="topbar-admin-dropdown">
            <a href="/admin/logout" class="topbar-dropdown-item">
              <i class="fas fa-sign-out-alt"></i> Logout
            </a>
          </div>
        </div>
      </div>
    </header>

    <div class="admin-shell">
      <%- include('../includes/adminSidebar.ejs', { activePage: 'dashboard' }) %>

      <main class="admin-main">
        <div class="admin-page-header">
          <div class="admin-page-header-left">
            <div class="admin-page-title">Dashboard</div>
            <div class="admin-page-subtitle">Welcome back — here's what's happening</div>
          </div>
        </div>

        <!-- Sales Chart -->
        <div class="admin-card mb-4">
          <div class="admin-card-header">
            <span class="admin-card-title">Sales Overview</span>
            <select id="chartFilter" class="chart-filter-select">
              <option value="yearly">Yearly</option>
              <option value="monthly">Monthly</option>
              <option value="weekly">Weekly</option>
            </select>
          </div>
          <div class="admin-card-body">
            <canvas id="salesChart" height="90"></canvas>
          </div>
        </div>

        <!-- Top lists -->
        <div class="row g-4 mb-4">
          <div class="col-lg-6">
            <div class="admin-card h-100">
              <div class="admin-card-header">
                <span class="admin-card-title">Top 10 Selling Products</span>
              </div>
              <div class="admin-card-body p-0">
                <ul id="bestProducts" class="admin-rank-list"></ul>
              </div>
            </div>
          </div>
          <div class="col-lg-6">
            <div class="admin-card h-100">
              <div class="admin-card-header">
                <span class="admin-card-title">Top 10 Selling Categories</span>
              </div>
              <div class="admin-card-body p-0">
                <ul id="bestCategories" class="admin-rank-list"></ul>
              </div>
            </div>
          </div>
        </div>

        <!-- Recent Orders -->
        <div class="admin-card mb-4">
          <div class="admin-card-header">
            <span class="admin-card-title">Recent Orders</span>
          </div>
          <div class="admin-card-body p-0">
            <div id="recentOrders"></div>
          </div>
        </div>

        <!-- Sales Report -->
        <div class="admin-card mb-4">
          <div class="admin-card-header">
            <span class="admin-card-title">Sales Report</span>
          </div>
          <div class="admin-card-body">
            <div class="row g-3 align-items-end mb-4">
              <div class="col-md-3">
                <div class="admin-field mb-0">
                  <label class="admin-label">Report Type</label>
                  <select id="reportType" class="admin-select">
                    <option value="daily">Daily</option>
                    <option value="weekly">Weekly</option>
                    <option value="yearly">Yearly</option>
                    <option value="custom">Custom Range</option>
                  </select>
                </div>
              </div>

              <div id="customDateRange" class="col-md-6 d-none">
                <div class="row g-2">
                  <div class="col">
                    <div class="admin-field mb-0">
                      <label class="admin-label">Start Date</label>
                      <input type="date" id="startDate" class="admin-input" />
                    </div>
                  </div>
                  <div class="col">
                    <div class="admin-field mb-0">
                      <label class="admin-label">End Date</label>
                      <input type="date" id="endDate" class="admin-input" />
                    </div>
                  </div>
                </div>
              </div>

              <div class="col-md-3">
                <button
                  type="button"
                  id="generateReportBtn"
                  class="btn-admin btn-admin-primary w-100"
                  style="height: 44px"
                >
                  <i class="fas fa-chart-bar"></i> Generate Report
                </button>
              </div>
            </div>

            <div id="reportContainer" class="table-responsive"></div>

            <div class="d-flex gap-2 mt-3">
              <button type="button" id="downloadPdfBtn" class="btn-admin btn-admin-ghost">
                <i class="fas fa-file-pdf"></i> Download PDF
              </button>
              <button type="button" id="downloadExcelBtn" class="btn-admin btn-admin-ghost">
                <i class="fas fa-file-excel"></i> Download Excel
              </button>
            </div>
          </div>
        </div>
      </main>
    </div>

    <footer class="admin-footer">© 2024 ShoeZone Admin Panel. All rights reserved.</footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      // Admin pill toggle
      document.getElementById("adminPill")?.addEventListener("click", function (e) {
        e.stopPropagation();
        this.classList.toggle("open");
      });
      document.addEventListener("click", () => {
        document.getElementById("adminPill")?.classList.remove("open");
      });

      // Show/hide custom date range
      document.getElementById("reportType").addEventListener("change", function () {
        document
          .getElementById("customDateRange")
          .classList.toggle("d-none", this.value !== "custom");
      });

      // Sales Chart
      let salesChart;
      const salesChartCanvas = document.getElementById("salesChart")?.getContext("2d");

      function updateChart(chartData) {
        if (salesChart) salesChart.destroy();
        salesChart = new Chart(salesChartCanvas, {
          type: "bar",
          data: {
            labels: chartData.labels,
            datasets: [
              {
                label: "Total Sales",
                data: chartData.datasets[0].data,
                backgroundColor: "rgba(10,10,10,0.85)",
                borderColor: "rgba(10,10,10,1)",
                borderWidth: 0,
                borderRadius: 6,
                borderSkipped: false,
              },
            ],
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            scales: {
              x: {
                grid: { display: false },
                ticks: { font: { family: "DM Sans", size: 11, weight: "600" }, color: "#9a9a96" },
              },
              y: {
                beginAtZero: true,
                grid: { color: "rgba(0,0,0,.05)", drawBorder: false },
                ticks: {
                  font: { family: "DM Sans", size: 11 },
                  color: "#9a9a96",
                  callback: (v) => "₹" + Number(v).toLocaleString("en-IN"),
                },
              },
            },
            plugins: {
              legend: { display: false },
              tooltip: {
                backgroundColor: "#0a0a0a",
                titleFont: { family: "Bebas Neue", size: 14 },
                bodyFont: { family: "DM Sans", size: 12 },
                callbacks: { label: (ctx) => "₹" + Number(ctx.raw).toLocaleString("en-IN") },
              },
            },
          },
        });
      }

      // Top lists
      function updateTopLists(topProducts, topCategories) {
        document.getElementById("bestProducts").innerHTML = topProducts
          .map(
            (p, i) =>
              `<li class="admin-rank-item">
        <span class="rank-num ${i < 3 ? "top" : ""}">${i + 1}</span>
        <span class="rank-name">${p.name}</span>
        <span class="rank-qty">QTY ${p.sales}</span>
      </li>`
          )
          .join("");

        document.getElementById("bestCategories").innerHTML = topCategories
          .map(
            (c, i) =>
              `<li class="admin-rank-item">
        <span class="rank-num ${i < 3 ? "top" : ""}">${i + 1}</span>
        <span class="rank-name">${c.name}</span>
        <span class="rank-qty">QTY ${c.sales}</span>
      </li>`
          )
          .join("");
      }

      // Recent orders
      function updateRecentOrders(orders) {
        document.getElementById("recentOrders").innerHTML = orders
          .map(
            (o) =>
              `<div class="recent-order-item">
        <span class="recent-order-id">#${o._id.slice(-6)}</span>
        <span class="recent-order-total">₹${o.totalCost.toFixed(2)}</span>
        <span class="recent-order-date">${new Date(o.createdAt).toLocaleDateString("en-IN")}</span>
        <span class="recent-order-items">${o.itemStatuses
          .map((i) => `${i.productName} (${i.status})`)
          .join(", ")}</span>
      </div>`
          )
          .join("");
      }

      // Fetch dashboard data
      async function updateDashboard(filter = "yearly") {
        try {
          const res = await fetch(`/admin/dashboard?filter=${filter}`);
          const data = await res.json();
          updateChart(data.chartData);
          updateTopLists(data.topProducts, data.topCategories);
          updateRecentOrders(data.recentOrders);
        } catch (err) {
          console.error("Dashboard fetch error:", err);
        }
      }

      document
        .getElementById("chartFilter")
        ?.addEventListener("change", (e) => updateDashboard(e.target.value));
      updateDashboard();

      // Generate Report
      document.getElementById("generateReportBtn")?.addEventListener("click", async () => {
        const type = document.getElementById("reportType").value;
        let url = `/admin/sales-report?type=${type}`;
        if (type === "custom") {
          const start = document.getElementById("startDate").value;
          const end = document.getElementById("endDate").value;
          if (start && end) url += `&startDate=${start}&endDate=${end}`;
        }
        try {
          const res = await fetch(url);
          const data = await res.json();
          const container = document.getElementById("reportContainer");
          container.innerHTML = "";
          if (!data.length) {
            container.innerHTML =
              '<p style="font-size:.84rem;color:#9a9a96;text-align:center;padding:1.5rem 0">No data found for this period.</p>';
            return;
          }
          const table = document.createElement("table");
          table.innerHTML = `
        <thead><tr>
          <th>Date</th><th>Total Sales</th><th>Orders</th>
          <th>Discounts</th><th>Coupon Deductions</th>
        </tr></thead>
        <tbody>${data
          .map(
            (r) => `<tr>
          <td>${r.date}</td>
          <td>₹${Number(r.totalSales).toLocaleString("en-IN")}</td>
          <td>${r.ordersCount}</td>
          <td>₹${Number(r.totalDiscounts).toLocaleString("en-IN")}</td>
          <td>₹${Number(r.couponDeductions).toLocaleString("en-IN")}</td>
        </tr>`
          )
          .join("")}</tbody>`;
          container.appendChild(table);
        } catch (err) {
          document.getElementById("reportContainer").innerHTML =
            '<p style="color:#dc2626;font-size:.84rem">Failed to load report.</p>';
        }
      });

      // Download buttons
      document.getElementById("downloadPdfBtn")?.addEventListener("click", () => {
        let url = `/admin/sales-report/download?format=pdf&type=${
          document.getElementById("reportType").value
        }`;
        if (document.getElementById("reportType").value === "custom") {
          const s = document.getElementById("startDate").value;
          const e = document.getElementById("endDate").value;
          if (s && e) url += `&startDate=${s}&endDate=${e}`;
        }
        window.location.href = url;
      });
      document.getElementById("downloadExcelBtn")?.addEventListener("click", () => {
        let url = `/admin/sales-report/download?format=excel&type=${
          document.getElementById("reportType").value
        }`;
        if (document.getElementById("reportType").value === "custom") {
          const s = document.getElementById("startDate").value;
          const e = document.getElementById("endDate").value;
          if (s && e) url += `&startDate=${s}&endDate=${e}`;
        }
        window.location.href = url;
      });
    </script>
  </body>
</html>
