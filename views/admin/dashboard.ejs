<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Dashboard</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/moment@2.30.1/moment.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-moment@1.0.1"></script>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/adminDashboard.css" />
  </head>
  <body class="bg-light">
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
      <div class="container-fluid">
        <a class="navbar-brand fw-bold" href="/admin">
          <img src="/test.jpg" alt="Logo" width="35" class="d-inline-block align-text-top me-2" />
          SportZilon Admin
        </a>
        <button
          class="navbar-toggler"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#navbarNav"
        >
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav ms-auto">
            <li class="nav-item dropdown">
              <a
                class="nav-link dropdown-toggle text-white"
                href="#"
                id="adminDropdown"
                role="button"
                data-bs-toggle="dropdown"
              >
                ADMIN
              </a>
              <ul class="dropdown-menu dropdown-menu-end">
                <li><a class="dropdown-item" href="/admin/logout">Logout</a></li>
              </ul>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <div class="d-flex">
      <!-- Sidebar -->
      <aside class="sidebar bg-dark text-white p-3" style="width: 250px; min-height: 100vh">
        <div class="list-group list-group-flush">
          <a
            href="/admin"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3 active"
          >
            <i class="fas fa-home me-2"></i> HOME
          </a>
          <a
            href="/admin/allproducts"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3"
          >
            <i class="fas fa-box me-2"></i> ALL PRODUCTS
          </a>
          <a
            href="/admin/ordersList"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3"
          >
            <i class="fas fa-shopping-cart me-2"></i> ORDERS LIST
          </a>
          <a
            href="/admin/usersList"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3"
          >
            <i class="fas fa-users me-2"></i> USERS LIST
          </a>
          <a
            href="/admin/categoryList"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3"
          >
            <i class="fas fa-tags me-2"></i> CATEGORY LIST
          </a>
          <a
            href="/admin/couponList"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3"
          >
            <i class="fas fa-gift me-2"></i> COUPON LIST
          </a>
          <a
            href="/admin/offers"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3"
          >
            <i class="fas fa-percentage me-2"></i> OFFERS
          </a>
        </div>
      </aside>

      <!-- Main Content -->
      <main class="content flex-grow-1 p-4">
        <h2 class="mb-4">Admin Dashboard</h2>

        <div class="row g-4">
          <!-- Sales Chart -->
          <div class="col-12">
            <div class="card shadow-lg border-0">
              <div
                class="card-header bg-dark text-white d-flex justify-content-between align-items-center"
              >
                <h5 class="mb-0">Sales Overview</h5>
                <select
                  id="chartFilter"
                  class="form-select form-select-sm w-auto bg-dark text-white border-0"
                >
                  <option value="yearly">Yearly</option>
                  <option value="monthly">Monthly</option>
                  <option value="weekly">Weekly</option>
                </select>
              </div>
              <div class="card-body p-4">
                <canvas id="salesChart" height="100"></canvas>
              </div>
            </div>
          </div>

          <!-- Top Selling Products & Categories -->
          <div class="col-lg-6">
            <div class="card shadow-lg border-0 h-100">
              <div class="card-header bg-dark text-white">
                <h5 class="mb-0">Top 10 Selling Products</h5>
              </div>
              <div class="card-body">
                <ul id="bestProducts" class="list-group list-group-flush"></ul>
              </div>
            </div>
          </div>

          <div class="col-lg-6">
            <div class="card shadow-lg border-0 h-100">
              <div class="card-header bg-dark text-white">
                <h5 class="mb-0">Top 10 Selling Categories</h5>
              </div>
              <div class="card-body">
                <ul id="bestCategories" class="list-group list-group-flush"></ul>
              </div>
            </div>
          </div>

          <!-- Recent Orders -->
          <div class="col-12">
            <div class="card shadow-lg border-0">
              <div class="card-header bg-dark text-white">
                <h5 class="mb-0">Recent Orders</h5>
              </div>
              <div class="card-body">
                <ul id="recentOrders" class="list-group list-group-flush"></ul>
              </div>
            </div>
          </div>

          <!-- Sales Report -->
          <div class="col-12">
            <div class="card shadow-lg border-0">
              <div class="card-header bg-dark text-white">
                <h5 class="mb-0">Sales Report</h5>
              </div>
              <div class="card-body">
                <form id="salesReportForm" class="row g-3 align-items-end">
                  <div class="col-md-3">
                    <label for="reportType" class="form-label fw-bold">Report Type</label>
                    <select id="reportType" class="form-select">
                      <option value="daily">Daily</option>
                      <option value="weekly">Weekly</option>
                      <option value="yearly">Yearly</option>
                      <option value="custom">Custom Range</option>
                    </select>
                  </div>

                  <div id="customDateRange" class="col-md-6 d-none">
                    <div class="row g-2">
                      <div class="col">
                        <label for="startDate" class="form-label fw-bold">Start Date</label>
                        <input type="date" id="startDate" class="form-control" />
                      </div>
                      <div class="col">
                        <label for="endDate" class="form-label fw-bold">End Date</label>
                        <input type="date" id="endDate" class="form-control" />
                      </div>
                    </div>
                  </div>

                  <div class="col-md-3">
                    <button type="button" id="generateReportBtn" class="btn btn-dark w-100">
                      <i class="fas fa-chart-bar me-2"></i> Generate Report
                    </button>
                  </div>
                </form>

                <div id="reportContainer" class="mt-4 table-responsive"></div>

                <div class="mt-3">
                  <button type="button" id="downloadPdfBtn" class="btn btn-outline-dark me-2">
                    <i class="fas fa-file-pdf me-2"></i> Download PDF
                  </button>
                  <button type="button" id="downloadExcelBtn" class="btn btn-outline-dark">
                    <i class="fas fa-file-excel me-2"></i> Download Excel
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </main>
    </div>

    <!-- Footer -->
    <footer class="footer bg-dark text-white text-center py-3 mt-auto">
      <div class="container">
        <p class="mb-0">© 2024 SportZilon Admin Panel. All rights reserved.</p>
      </div>
    </footer>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      // Sidebar toggle for mobile
      document.getElementById("navbarToggler")?.addEventListener("click", function () {
        document.querySelector(".sidebar")?.classList.toggle("active");
      });

      // Show/hide custom date range
      document.getElementById("reportType").addEventListener("change", function () {
        document
          .getElementById("customDateRange")
          .classList.toggle("d-none", this.value !== "custom");
      });

      // Sales Chart
      let salesChart;
      const salesChartCanvas = document.getElementById("salesChart")?.getContext("2d");

      function updateChart(chartData) {
        if (salesChart) salesChart.destroy();

        salesChart = new Chart(salesChartCanvas, {
          type: "bar",
          data: {
            labels: chartData.labels,
            datasets: [
              {
                label: "Total Sales",
                data: chartData.datasets[0].data,
                backgroundColor: "rgba(75, 192, 192, 0.6)",
                borderColor: "rgba(75, 192, 192, 1)",
                borderWidth: 1,
              },
            ],
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            scales: {
              x: { title: { display: true, text: "Date" } },
              y: { beginAtZero: true, title: { display: true, text: "Total Sales (₹)" } },
            },
            plugins: { legend: { display: false } },
          },
        });
      }

      // Top Lists
      function updateTopLists(topProducts, topCategories) {
        document.getElementById("bestProducts").innerHTML = topProducts
          .map(
            (p) =>
              `<li class="list-group-item d-flex justify-content-between"><span>${p.name}</span><span class="badge bg-success">QTY : ${p.sales}</span></li>`
          )
          .join("");

        document.getElementById("bestCategories").innerHTML = topCategories
          .map(
            (c) =>
              `<li class="list-group-item d-flex justify-content-between"><span>${c.name}</span><span class="badge bg-info">QTY : ${c.sales}</span></li>`
          )
          .join("");
      }

      // Recent Orders
      function updateRecentOrders(orders) {
        document.getElementById("recentOrders").innerHTML = orders
          .map(
            (o) => `
          <li class="list-group-item">
            <div class="d-flex justify-content-between">
              <strong>Order #${o._id.slice(-6)}</strong>
              <span>${new Date(o.createdAt).toLocaleDateString("en-IN")}</span>
            </div>
            <div>Total: ₹${o.totalCost.toFixed(2)}</div>
            <small class="text-muted">Items: ${o.itemStatuses
              .map((i) => `${i.productName} (${i.status})`)
              .join(", ")}</small>
          </li>
        `
          )
          .join("");
      }

      // Fetch Dashboard Data
      async function updateDashboard(filter = "yearly") {
        try {
          const res = await fetch(`/admin/dashboard?filter=${filter}`);
          const data = await res.json();

          updateChart(data.chartData);
          updateTopLists(data.topProducts, data.topCategories);
          updateRecentOrders(data.recentOrders);
        } catch (err) {
          console.error("Dashboard fetch error:", err);
        }
      }

      // Chart Filter Change
      document.getElementById("chartFilter")?.addEventListener("change", (e) => {
        updateDashboard(e.target.value);
      });

      // Initial Load
      updateDashboard();

      // Sales Report Generate
      document.getElementById("generateReportBtn")?.addEventListener("click", async () => {
        const type = document.getElementById("reportType").value;
        let url = `/admin/sales-report?type=${type}`;

        if (type === "custom") {
          const start = document.getElementById("startDate").value;
          const end = document.getElementById("endDate").value;
          if (start && end) url += `&startDate=${start}&endDate=${end}`;
        }

        try {
          const res = await fetch(url);
          const data = await res.json();

          const container = document.getElementById("reportContainer");
          container.innerHTML = "";

          if (data.length === 0) {
            container.innerHTML =
              '<p class="text-center text-muted">No data found for this period.</p>';
            return;
          }

          const table = document.createElement("table");
          table.className = "table table-striped table-bordered";

          const thead = document.createElement("thead");
          thead.innerHTML = `
          <tr>
            <th>Date</th>
            <th>Total Sales</th>
            <th>Orders</th>
            <th>Discounts</th>
            <th>Coupon Deductions</th>
          </tr>
        `;
          table.appendChild(thead);

          const tbody = document.createElement("tbody");
          data.forEach((r) => {
            const row = document.createElement("tr");
            row.innerHTML = `
            <td>${r.date}</td>
            <td>₹${Number(r.totalSales).toLocaleString("en-IN")}</td>
            <td>${r.ordersCount}</td>
            <td>₹${Number(r.totalDiscounts).toLocaleString("en-IN")}</td>
            <td>₹${Number(r.couponDeductions).toLocaleString("en-IN")}</td>
          `;
            tbody.appendChild(row);
          });
          table.appendChild(tbody);

          container.appendChild(table);
        } catch (err) {
          console.error(err);
          document.getElementById("reportContainer").innerHTML =
            '<p class="text-danger">Failed to load report.</p>';
        }
      });

      // Download Buttons
      document.getElementById("downloadPdfBtn")?.addEventListener("click", () => {
        let url = `/admin/sales-report/download?format=pdf&type=${
          document.getElementById("reportType").value
        }`;
        if (document.getElementById("reportType").value === "custom") {
          const s = document.getElementById("startDate").value;
          const e = document.getElementById("endDate").value;
          if (s && e) url += `&startDate=${s}&endDate=${e}`;
        }
        window.location.href = url;
      });

      document.getElementById("downloadExcelBtn")?.addEventListener("click", () => {
        let url = `/admin/sales-report/download?format=excel&type=${
          document.getElementById("reportType").value
        }`;
        if (document.getElementById("reportType").value === "custom") {
          const s = document.getElementById("startDate").value;
          const e = document.getElementById("endDate").value;
          if (s && e) url += `&startDate=${s}&endDate=${e}`;
        }
        window.location.href = url;
      });
    </script>
  </body>
</html>
