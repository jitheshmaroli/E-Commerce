<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset Password – ShoeZone</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
    />
    <link rel="stylesheet" href="/css/auth-shared.css" />
  </head>
  <body>
    <div class="auth-page">
      <div class="auth-panel-brand">
        <div class="auth-brand-top">
          <a href="/" class="auth-logo-wrap">
            <img src="/test.jpg" alt="ShoeZone" class="auth-logo-img" />
            <span class="auth-logo-text">Shoe<em>Zone</em></span>
          </a>
        </div>
        <div class="auth-panel-mid">
          <div class="auth-panel-tagline">New<br /><span>Pass</span>word,<br />Fresh Start.</div>
          <p class="auth-panel-sub">Choose a strong password to keep your account secure.</p>
        </div>
        <div class="auth-panel-bottom">
          <div class="auth-stat">
            <div class="auth-stat-num">AES</div>
            <div class="auth-stat-label">Encrypted</div>
          </div>
          <div class="auth-stat">
            <div class="auth-stat-num">100%</div>
            <div class="auth-stat-label">Secure</div>
          </div>
        </div>
      </div>

      <div class="auth-panel-form">
        <div class="auth-form-scroll">
          <div class="auth-form-inner">
            <div class="auth-form-title">Reset Password</div>
            <div class="auth-form-sub">Choose a strong new password for your account.</div>

            <% if (message) { %>
            <div class="auth-alert auth-alert-error">
              <i class="fas fa-circle-exclamation"></i>
              <span><%= message %></span>
              <button class="auth-alert-close" onclick="this.closest('.auth-alert').remove()">
                &times;
              </button>
            </div>
            <% } %>

            <form action="/reset-password" method="POST" id="resetForm" novalidate>
              <input type="hidden" name="email" value="<%= userData || '' %>" />

              <div class="auth-field">
                <label for="password">New Password</label>
                <div class="auth-pw-wrap">
                  <input type="password" id="password" name="password" required minlength="8" />
                  <button
                    type="button"
                    class="auth-pw-toggle"
                    id="togglePw"
                    aria-label="Toggle password"
                  >
                    <i class="fas fa-eye-slash"></i>
                  </button>
                </div>
                <div class="auth-strength-bar">
                  <div class="auth-strength-fill" id="strengthFill"></div>
                </div>
                <span class="auth-field-hint hint-mute" id="passwordHint"></span>
              </div>

              <div class="auth-field">
                <label for="confirmPassword">Confirm Password</label>
                <div class="auth-pw-wrap">
                  <input type="password" id="confirmPassword" name="confirmPassword" required />
                  <button
                    type="button"
                    class="auth-pw-toggle"
                    id="toggleCpw"
                    aria-label="Toggle confirm"
                  >
                    <i class="fas fa-eye-slash"></i>
                  </button>
                </div>
                <span class="auth-field-error" id="confirmError">Passwords do not match.</span>
              </div>

              <button type="submit" class="btn-auth-submit">
                <i class="fas fa-lock" style="margin-right: 0.5rem"></i>Reset Password
              </button>

              <div class="auth-links">
                <a href="/login"
                  ><i class="fas fa-arrow-left" style="margin-right: 0.3rem"></i>Back to Login</a
                >
              </div>
            </form>
          </div>
        </div>
        <div class="auth-form-footer">© 2026 ShoeZone. All rights reserved.</div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      const pw = document.getElementById("password");
      const cpw = document.getElementById("confirmPassword");
      const strengthFill = document.getElementById("strengthFill");
      const passwordHint = document.getElementById("passwordHint");
      const confirmError = document.getElementById("confirmError");
      const togglePw = document.getElementById("togglePw");
      const toggleCpw = document.getElementById("toggleCpw");

      const strengthCfg = [
        { label: "Too weak", color: "#ef4444", width: "20%" },
        { label: "Weak", color: "#f97316", width: "35%" },
        { label: "Fair", color: "#eab308", width: "55%" },
        { label: "Good", color: "#22c55e", width: "75%" },
        { label: "Strong ✓", color: "#15803d", width: "100%" },
      ];

      function calcStr(v) {
        let s = 0;
        if (v.length >= 8) s++;
        if (/[A-Z]/.test(v)) s++;
        if (/[a-z]/.test(v)) s++;
        if (/\d/.test(v)) s++;
        if (/[^a-zA-Z0-9\s]/.test(v)) s++;
        return s;
      }

      function validate(val) {
        if (val.length < 8) return "Password must be at least 8 characters.";
        if (!/[A-Z]/.test(val)) return "At least one uppercase letter required.";
        if (!/[a-z]/.test(val)) return "At least one lowercase letter required.";
        if (!/\d/.test(val)) return "At least one number required.";
        if (!/[!@#$%^&*()_+\-=\[\]{};':\"\\|,.<>\/?]/.test(val))
          return "At least one special character required.";
        return null;
      }

      pw.addEventListener("input", () => {
        const v = pw.value;
        if (!v) {
          strengthFill.style.width = "0";
          passwordHint.textContent = "";
          passwordHint.className = "auth-field-hint hint-mute";
          return;
        }
        const score = calcStr(v);
        const cfg = strengthCfg[Math.max(0, score - 1)];
        strengthFill.style.width = cfg.width;
        strengthFill.style.background = cfg.color;
        const err = validate(v);
        if (err) {
          passwordHint.textContent = err;
          passwordHint.className = "auth-field-hint hint-err";
        } else {
          passwordHint.textContent = "Strong password ✓";
          passwordHint.className = "auth-field-hint hint-ok";
        }
        checkMatch();
      });

      function checkMatch() {
        if (!cpw.value) {
          confirmError.classList.remove("visible");
          cpw.classList.remove("is-invalid", "is-valid");
          return;
        }
        const ok = pw.value === cpw.value;
        confirmError.classList.toggle("visible", !ok);
        cpw.classList.toggle("is-invalid", !ok);
        cpw.classList.toggle("is-valid", ok);
      }
      cpw.addEventListener("input", checkMatch);

      togglePw.addEventListener("click", () => {
        const show = pw.type === "password";
        pw.type = show ? "text" : "password";
        togglePw.innerHTML = `<i class="fas fa-eye${show ? "" : "-slash"}"></i>`;
      });
      toggleCpw.addEventListener("click", () => {
        const show = cpw.type === "password";
        cpw.type = show ? "text" : "password";
        toggleCpw.innerHTML = `<i class="fas fa-eye${show ? "" : "-slash"}"></i>`;
      });

      document.getElementById("resetForm").addEventListener("submit", (e) => {
        const err = validate(pw.value);
        if (err) {
          e.preventDefault();
          passwordHint.textContent = err;
          passwordHint.className = "auth-field-hint hint-err";
          pw.focus();
          return;
        }
        if (pw.value !== cpw.value) {
          e.preventDefault();
          confirmError.classList.add("visible");
          cpw.focus();
        }
      });
    </script>
  </body>
</html>
