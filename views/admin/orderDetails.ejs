<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Order Details - Admin</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    />
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/adminOrderDetails.css" />
  </head>
  <body class="bg-light">
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
      <div class="container-fluid">
        <a class="navbar-brand fw-bold" href="/admin">
          <img src="/test.jpg" alt="Logo" width="35" class="d-inline-block align-text-top me-2" />
          SportZilon Admin
        </a>
        <button
          class="navbar-toggler"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#navbarNav"
        >
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav ms-auto">
            <li class="nav-item dropdown">
              <a
                class="nav-link dropdown-toggle text-white"
                href="#"
                id="adminDropdown"
                role="button"
                data-bs-toggle="dropdown"
              >
                ADMIN
              </a>
              <ul class="dropdown-menu dropdown-menu-end">
                <li><a class="dropdown-item" href="/admin/logout">Logout</a></li>
              </ul>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <div class="d-flex">
      <!-- Sidebar -->
      <aside class="sidebar bg-dark text-white p-3" style="width: 250px; min-height: 100vh">
        <div class="list-group list-group-flush">
          <a
            href="/admin"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3"
          >
            <i class="fas fa-home me-2"></i> HOME
          </a>
          <a
            href="/admin/allproducts"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3"
          >
            <i class="fas fa-box me-2"></i> ALL PRODUCTS
          </a>
          <a
            href="/admin/ordersList"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3 active"
          >
            <i class="fas fa-shopping-cart me-2"></i> ORDERS LIST
          </a>
          <a
            href="/admin/usersList"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3"
          >
            <i class="fas fa-users me-2"></i> USERS LIST
          </a>
          <a
            href="/admin/categoryList"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3"
          >
            <i class="fas fa-tags me-2"></i> CATEGORY LIST
          </a>
          <a
            href="/admin/couponList"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3"
          >
            <i class="fas fa-gift me-2"></i> COUPON LIST
          </a>
          <a
            href="/admin/offers"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3"
          >
            <i class="fas fa-percentage me-2"></i> OFFERS
          </a>
        </div>
      </aside>

      <!-- Main Content -->
      <main class="content flex-grow-1 p-4">
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb bg-transparent p-0 mb-4">
            <li class="breadcrumb-item">
              <a href="/admin/ordersList" class="text-dark">Orders List</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Order Details</li>
          </ol>
        </nav>

        <% if (order) { %>
        <div class="card shadow-lg border-0 mb-4">
          <div
            class="card-header bg-dark text-white d-flex justify-content-between align-items-center"
          >
            <h5 class="mb-0">Order #<%= order.uniqueOrderId %></h5>
            <span class="badge bg-info"><%= order.paymentMethod.toUpperCase() %></span>
          </div>
          <div class="card-body">
            <div class="row">
              <!-- Order Items -->
              <div class="col-lg-12">
                <h6 class="mb-3">Order Items</h6>
                <div class="table-responsive">
                  <table class="table table-bordered table-hover">
                    <thead class="table-dark">
                      <tr>
                        <th>Item</th>
                        <th>Qty</th>
                        <th>Price</th>
                        <th>Ordered</th>
                        <th>Shipped</th>
                        <th>Delivered</th>
                        <th>Cancelled</th>
                        <th>Status</th>
                        <th>Actions</th>
                        <th>Return Actions</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% order.items.forEach(item => { %>
                      <tr id="item-row-<%= item.productId._id %>">
                        <td>
                          <div class="d-flex align-items-center">
                            <img
                              src="/uploads/<%= item.productId.photos?.[0]?.filename || 'placeholder.jpg' %>"
                              alt="<%= item.productId.name %>"
                              width="50"
                              class="me-3 rounded"
                            />
                            <div>
                              <strong><%= item.productId.name %></strong><br />
                              <small class="text-muted"
                                >₹<%= item.productId.price.toFixed(2) %></small
                              >
                            </div>
                          </div>
                        </td>
                        <td><%= item.quantity %></td>
                        <td>₹<%= (item.productId.price * item.quantity).toFixed(2) %></td>
                        <td>
                          <%= new Date(order.createdAt).toLocaleString('en-IN', {dateStyle: 'short', timeStyle: 'short'}) %>
                        </td>
                        <td>
                          <%= item.shippedAt ? new Date(item.shippedAt).toLocaleString('en-IN', {dateStyle: 'short', timeStyle: 'short'}) : '-' %>
                        </td>
                        <td>
                          <%= item.deliveredAt ? new Date(item.deliveredAt).toLocaleString('en-IN', {dateStyle: 'short', timeStyle: 'short'}) : '-' %>
                        </td>
                        <td>
                          <%= item.cancelledAt ? new Date(item.cancelledAt).toLocaleString('en-IN', {dateStyle: 'short', timeStyle: 'short'}) : '-' %>
                        </td>
                        <% 
                          function getStatusClass(status) {
                            switch (status) {
                              case 'Pending':   return 'bg-warning';
                              case 'Shipped':   return 'bg-info';
                              case 'Delivered': return 'bg-success';
                              case 'Cancelled': return 'bg-danger';
                              default:          return 'bg-secondary';
                            }
                          }
                        %>
                        <td>
                          <span
                            id="item-status-<%= item.productId._id %>"
                            class="badge <%= getStatusClass(item.status) %>"
                          >
                            <%= item.status %>
                          </span>
                        </td>
                        <td id="action-buttons-<%= item.productId._id %>">
                          <% if (item.status === 'Pending') { %>
                          <button
                            class="btn btn-sm btn-primary mb-2"
                            onclick="
                              updateOrderStatus(
                                '<%= order._id %>',
                                '<%= item.productId._id %>',
                                'Shipped'
                              )
                            "
                          >
                            Ship
                          </button>
                          <% } else if (item.status === 'Shipped') { %>

                          <button
                            class="btn btn-sm btn-success mb-2"
                            onclick="
                              updateOrderStatus(
                                '<%= order._id %>',
                                '<%= item.productId._id %>',
                                'Delivered'
                              )
                            "
                          >
                            Delivered
                          </button>
                          <% } else { %>
                          <span class="text-muted mb-2"><%= item.status %></span>
                          <% } %>
                        </td>
                        <td>
                          <% if (item.returnStatus === 'Requested') { %>
                          <span class="badge bg-warning mb-2">Return Requested</span>
                          <button
                            class="btn btn-sm btn-success mb-2"
                            onclick="approveReturn('<%= order._id %>', '<%= item.productId._id %>')"
                          >
                            Approve
                          </button>
                          <button
                            class="btn btn-sm btn-danger mb-2"
                            onclick="rejectReturn('<%= order._id %>', '<%= item.productId._id %>')"
                          >
                            Reject
                          </button>
                          <% } else { %>
                          <span
                            class="badge <%= item.returnStatus === 'Refunded' ? 'bg-success' : 'bg-secondary' %>"
                          >
                            <%= item.returnStatus %>
                          </span>
                          <% } %>
                        </td>
                      </tr>
                      <% }) %>
                    </tbody>
                    <tfoot>
                      <tr>
                        <td colspan="7" class="text-end fw-bold">Subtotal</td>
                        <td colspan="2">₹<%= order.priceDetails.subTotal.toFixed(2) %></td>
                      </tr>
                      <% if (order.couponCode) { %>
                      <tr>
                        <td colspan="7" class="text-end text-danger fw-bold">
                          Discount (<%= order.couponCode %>)
                        </td>
                        <td colspan="2" class="text-danger">
                          -₹<%= order.priceDetails.discountAmount.toFixed(2) %>
                        </td>
                      </tr>
                      <% } %>
                      <tr>
                        <td colspan="7" class="text-end fw-bold">Delivery Charge</td>
                        <td colspan="2">₹<%= order.priceDetails.deliveryCharge.toFixed(2) %></td>
                      </tr>
                      <tr>
                        <td colspan="7" class="text-end fw-bold">Sales Tax</td>
                        <td colspan="2"><%= order.priceDetails.salesTax %></td>
                      </tr>
                      <tr class="table-active">
                        <td colspan="7" class="text-end fw-bold fs-5">TOTAL</td>
                        <td colspan="2" class="fw-bold fs-5">₹<%= order.totalCost.toFixed(2) %></td>
                      </tr>
                    </tfoot>
                  </table>
                </div>
              </div>
            </div>

            <!-- Payment & Address -->
            <div class="row">
              <div class="col-lg-12">
                <div class="card mb-4">
                  <div class="card-header bg-dark text-white">
                    <h6 class="mb-0">Payment & Order Info</h6>
                  </div>
                  <div class="card-body">
                    <p>
                      <strong>Payment Method:</strong>
                      <%= order.paymentMethod.toUpperCase() %>
                    </p>
                    <p>
                      <strong>Payment Status:</strong>
                      <span
                        class="badge <%= order.paymentStatus === 'confirmed' || order.paymentStatus === 'paid' ? 'bg-success' : 'bg-warning' %>"
                      >
                        <%= order.paymentStatus.toUpperCase() %>
                      </span>
                    </p>
                    <p>
                      <strong>Order Date:</strong>
                      <%= new Date(order.createdAt).toLocaleString('en-IN') %>
                    </p>
                  </div>
                </div>

                <div class="card mb-4">
                  <div class="card-header bg-dark text-white">
                    <h6 class="mb-0">Delivery Address</h6>
                  </div>
                  <div class="card-body">
                    <address class="mb-0">
                      <strong><%= order.deliveryAddress.address.name %></strong><br />
                      <%= order.deliveryAddress.address.houseName %><br />
                      <%= order.deliveryAddress.address.street %>,
                      <%= order.deliveryAddress.address.city %><br />
                      <%= order.deliveryAddress.address.district %>,
                      <%= order.deliveryAddress.address.state %>
                      -
                      <%= order.deliveryAddress.address.pinCode %>
                    </address>
                  </div>
                </div>

                <!-- Invoice Button – only show if at least one item is delivered -->
                <% const hasDeliveredItem = order.items.some(item => item.status === 'Delivered');
                %>
                <% if (hasDeliveredItem) { %>
                <button
                  class="btn btn-dark w-100 mb-3"
                  data-bs-toggle="modal"
                  data-bs-target="#invoiceModal"
                >
                  <i class="fas fa-file-invoice me-2"></i> Invoice
                </button>
                <% } %>
              </div>
            </div>
          </div>
        </div>

        <!-- Invoice Modal -->
        <% if (invoiceData) { %>
        <div
          class="modal fade"
          id="invoiceModal"
          tabindex="-1"
          aria-labelledby="invoiceModalLabel"
          aria-hidden="true"
        >
          <div class="modal-dialog modal-xl">
            <div class="modal-content">
              <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="invoiceModalLabel">
                  Invoice – Order #<%= order.uniqueOrderId %> <% if (order.items.some(i => i.status
                  !== 'Delivered')) { %>
                  <small class="text-warning ms-2">(Partial – Delivered Items Only)</small>
                  <% } %>
                </h5>
                <button
                  type="button"
                  class="btn-close btn-close-white"
                  data-bs-dismiss="modal"
                  aria-label="Close"
                ></button>
              </div>
              <div class="modal-body p-4">
                <!-- Header -->
                <div class="row mb-4 align-items-center">
                  <div class="col-6">
                    <img src="/test.jpg" alt="Logo" height="50" />
                    <h4 class="mt-2">Tax Invoice</h4>
                  </div>
                  <div class="col-6 text-end">
                    <p class="mb-0">
                      <strong>Order ID:</strong>
                      <%= order.uniqueOrderId %>
                    </p>
                    <p>
                      <strong>Date:</strong>
                      <%= new Date(order.createdAt).toLocaleDateString('en-IN') %>
                    </p>
                  </div>
                </div>

                <!-- Addresses -->
                <div class="row mb-4">
                  <div class="col-md-6">
                    <strong>Billed To:</strong><br />
                    <%= order.deliveryAddress.address.name %><br />
                    <%= order.deliveryAddress.address.houseName %>,
                    <%= order.deliveryAddress.address.street %><br />
                    <%= order.deliveryAddress.address.city %>,
                    <%= order.deliveryAddress.address.district %><br />
                    <%= order.deliveryAddress.address.state %>
                    -
                    <%= order.deliveryAddress.address.pinCode %>
                  </div>
                  <div class="col-md-6 text-md-end">
                    <strong>Shipped To:</strong><br />
                    Same as billing address
                  </div>
                </div>

                <!-- Items Table – only delivered items with correct prices -->
                <div class="table-responsive">
                  <table class="table table-bordered">
                    <thead class="table-dark">
                      <tr>
                        <th>#</th>
                        <th>Item</th>
                        <th>Qty</th>
                        <th>Rate</th>
                        <th>Amount</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% invoiceData.deliveredItems.forEach((item, idx) => { %>
                      <tr>
                        <td><%= idx + 1 %></td>
                        <td><%= item.productId.name %></td>
                        <td><%= item.quantity %></td>
                        <td>₹<%= item.price.toFixed(2) %></td>
                        <td>₹<%= (item.price * item.quantity).toFixed(2) %></td>
                      </tr>
                      <% }) %>
                    </tbody>
                    <tfoot>
                      <tr>
                        <td colspan="4" class="text-end fw-bold">Subtotal (Delivered Items)</td>
                        <td class="fw-bold">₹<%= invoiceData.deliveredSubtotal.toFixed(2) %></td>
                      </tr>
                      <% if (invoiceData.discountAmount > 0) { %>
                      <tr>
                        <td colspan="4" class="text-end text-danger fw-bold">
                          Coupon Discount (<%= order.couponCode || 'Applied' %>)
                        </td>
                        <td class="text-danger">-₹<%= invoiceData.discountAmount.toFixed(2) %></td>
                      </tr>
                      <% } %>
                      <tr>
                        <td colspan="4" class="text-end fw-bold">Delivery Charge</td>
                        <td>₹<%= invoiceData.deliveryCharge.toFixed(2) %></td>
                      </tr>
                      <tr>
                        <td colspan="4" class="text-end fw-bold">Sales Tax</td>
                        <td>₹<%= invoiceData.taxAmount.toFixed(2) %></td>
                      </tr>
                      <tr class="table-active">
                        <td colspan="4" class="text-end fw-bold fs-5">Total</td>
                        <td class="fw-bold fs-5">₹<%= invoiceData.total.toFixed(2) %></td>
                      </tr>
                    </tfoot>
                  </table>
                </div>

                <!-- Footer Note -->
                <div class="mt-4 text-muted small">
                  <p>
                    <strong>Note:</strong> This invoice shows only delivered items. <% if
                    (order.items.some(i => i.status !== 'Delivered')) { %> Cancelled/returned items
                    are excluded.
                    <% } %>
                    Full order amount was charged at checkout.
                  </p>
                  <p>
                    Payment Method: <%= order.paymentMethod.toUpperCase() %> | Status: <%=
                    order.paymentStatus.toUpperCase() %>
                  </p>
                </div>
              </div>
              <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                  Close
                </button>
                <button type="button" class="btn btn-dark" onclick="window.print()">
                  <i class="fas fa-print me-2"></i> Print Invoice
                </button>
              </div>
            </div>
          </div>
        </div>
        <% } %>

        <% } else { %>
        <div class="alert alert-danger text-center py-5">
          <h4>Order not found</h4>
          <a href="/admin/ordersList" class="btn btn-dark mt-3">Back to Orders</a>
        </div>
        <% } %>
      </main>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
      function getStatusClass(status) {
        switch (status) {
          case "Pending":
            return "bg-warning";
          case "Shipped":
            return "bg-info";
          case "Delivered":
            return "bg-success";
          case "Cancelled":
            return "bg-danger";
          default:
            return "bg-secondary";
        }
      }

      async function updateOrderStatus(orderId, productId, newStatus) {
        const action = newStatus.toLowerCase();
        const result = await Swal.fire({
          title: `Confirm ${action}?`,
          text: `This will change the item status to "${newStatus}".`,
          icon: "question",
          showCancelButton: true,
          confirmButtonColor:
            action === "cancelled" ? "#d33" : action === "delivered" ? "#28a745" : "#007bff",
          confirmButtonText: `Yes, ${action.toUpperCase()}`,
        });

        if (!result.isConfirmed) return;

        try {
          const res = await fetch(
            `/admin/updateOrderStatus/${orderId}/${productId}?status=${newStatus}`,
            {
              method: "POST",
              headers: { "Content-Type": "application/json" },
            }
          );

          if (res.ok) {
            const statusEl = document.getElementById(`item-status-${productId}`);
            const actionsEl = document.getElementById(`action-buttons-${productId}`);

            statusEl.textContent = newStatus;
            statusEl.className = `badge ${getStatusClass(newStatus)}`;

            if (newStatus === "Pending") {
              actionsEl.innerHTML = `
              <button class="btn btn-sm btn-primary" onclick="updateOrderStatus('${orderId}', '${productId}', 'Shipped')">Ship</button>
            `;
            } else if (newStatus === "Shipped") {
              actionsEl.innerHTML = `
              <button class="btn btn-sm btn-success" onclick="updateOrderStatus('${orderId}', '${productId}', 'Delivered')">Delivered</button>
            `;
            } else {
              actionsEl.innerHTML = `<span class="text-muted">${newStatus}</span>`;
            }

            Swal.fire("Success!", `Item status updated to ${newStatus}.`, "success");
          } else {
            Swal.fire("Error!", "Failed to update status.", "error");
          }
        } catch (err) {
          console.error(err);
          Swal.fire("Error!", "Network error occurred.", "error");
        }
      }

      // Approve return
      async function approveReturn(orderId, productId) {
        const result = await Swal.fire({
          title: "Approve Return?",
          text: "This will refund the customer and mark the item as returned.",
          icon: "warning",
          showCancelButton: true,
          confirmButtonColor: "#28a745",
          confirmButtonText: "Yes, approve",
        });

        if (!result.isConfirmed) return;

        try {
          const res = await fetch(`/admin/approve-return/${orderId}/${productId}`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
          });

          if (res.ok) {
            Swal.fire("Success!", "Return approved and refund processed.", "success").then(() => {
              location.reload();
            });
          } else {
            const data = await res.json();
            Swal.fire("Error!", data.error || "Failed to approve return.", "error");
          }
        } catch (err) {
          console.error(err);
          Swal.fire("Error!", "Network error occurred.", "error");
        }
      }

      // Reject return
      async function rejectReturn(orderId, productId) {
        const result = await Swal.fire({
          title: "Reject Return?",
          text: "This will mark the return as rejected. No refund will be issued.",
          icon: "warning",
          showCancelButton: true,
          confirmButtonColor: "#d33",
          confirmButtonText: "Yes, reject",
        });

        if (!result.isConfirmed) return;

        try {
          const res = await fetch(`/admin/reject-return/${orderId}/${productId}`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
          });

          if (res.ok) {
            Swal.fire("Success!", "Return rejected.", "success").then(() => {
              location.reload();
            });
          } else {
            const data = await res.json();
            Swal.fire("Error!", data.error || "Failed to reject return.", "error");
          }
        } catch (err) {
          console.error(err);
          Swal.fire("Error!", "Network error occurred.", "error");
        }
      }
    </script>
  </body>
</html>
