<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Update Product</title>
    <link
      rel="stylesheet"
      href="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css"
    />
    <link rel="stylesheet" href="/css/updateProduct.css" />
  </head>
  <body>
    <nav class="navbar navbar-expand-lg navbar-light bg-light">
      <div class="container-fluid">
        <a class="navbar-brand" href="/admin">
          <img
            src="/test.jpg"
            alt="Logo"
            width="30"
            height="24"
            class="d-inline-block align-text-top"
          />
          SportZilon
        </a>
        <div class="collapse navbar-collapse">
          <ul class="navbar-nav ml-auto">
            <li class="nav-item dropdown">
              <a
                class="nav-link dropdown-toggle"
                href="#"
                id="navbarDropdown"
                role="button"
                data-toggle="dropdown"
                aria-expanded="false"
              >
                ADMIN
              </a>
              <ul class="dropdown-menu dropdown-menu-right">
                <li><a class="dropdown-item" href="#">Action</a></li>
                <li><hr class="dropdown-divider" /></li>
                <li><a class="dropdown-item" href="/admin/logout">Logout</a></li>
              </ul>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <div class="container-fluid mt-4">
      <div class="row">
        <!-- Sidebar -->
        <div class="col-2">
          <div class="list-group sidebar-list">
            <a href="/admin"
              ><button type="button" class="list-group-item list-group-item-action">HOME</button></a
            >
            <a href="/admin/allproducts"
              ><button type="button" class="list-group-item list-group-item-action active">
                ALL PRODUCTS
              </button></a
            >
            <a href="/admin/ordersList"
              ><button type="button" class="list-group-item list-group-item-action">
                ORDERS LIST
              </button></a
            >
            <a href="/admin/usersList"
              ><button type="button" class="list-group-item list-group-item-action">
                USERS LIST
              </button></a
            >
            <a href="/admin/categoryList"
              ><button type="button" class="list-group-item list-group-item-action">
                CATEGORY LIST
              </button></a
            >
            <a href="/admin/couponList"
              ><button type="button" class="list-group-item list-group-item-action">
                COUPON LIST
              </button></a
            >
            <a href="/admin/offers"
              ><button type="button" class="list-group-item list-group-item-action">
                OFFERS
              </button></a
            >
          </div>
        </div>

        <!-- Main Content -->
        <div class="col-10">
          <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
              <li class="breadcrumb-item"><a href="/admin">Admin</a></li>
              <li class="breadcrumb-item"><a href="/admin/allproducts">All Products</a></li>
              <li class="breadcrumb-item active" aria-current="page">Update Product</li>
            </ol>
          </nav>

          <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
              <h4 class="mb-0">Update Product: <%= productData.name %></h4>
            </div>
            <div class="card-body">
              <form
                method="POST"
                id="myForm"
                action="/admin/allProducts/edit/<%= productData._id %>"
                enctype="multipart/form-data"
              >
                <div class="row">
                  <!-- Left Column: Form Fields -->
                  <div class="col-md-7">
                    <div class="form-group">
                      <label for="name">Product Name</label>
                      <input
                        type="text"
                        class="form-control"
                        id="name"
                        name="name"
                        value="<%= productData.name %>"
                        placeholder="Product name"
                        required
                      />
                      <span id="name-error" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                      <label for="description">Product Description</label>
                      <textarea
                        class="form-control"
                        id="description"
                        name="description"
                        rows="3"
                        required
                      >
<%= productData.description %></textarea
                      >
                      <span id="description-error" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                      <label for="category">Category</label>
                      <select class="form-control" id="category" name="category" required>
                        <% if (categoryList && categoryList.length > 0) { %> <%
                        categoryList.forEach(category => { %>
                        <option
  value="<%= category.categoryName %>"
  <%= productData.category &&
      productData.category.categoryName === category.categoryName
        ? "selected"
        : "" %>
>
  <%= category.categoryName %>
</option>

                        <% }) %>
                        <% } %>
                      </select>
                      <span id="category-error" class="text-danger"></span>
                    </div>

                    <div class="form-row">
                      <div class="form-group col-md-4">
                        <label for="brandName">Brand Name</label>
                        <input
                          type="text"
                          class="form-control"
                          id="brandName"
                          name="brandName"
                          value="<%= productData.brandName %>"
                          placeholder="Brand name"
                        />
                        <span id="brandName-error" class="text-danger"></span>
                      </div>
                      <div class="form-group col-md-4">
                        <label for="stockQuantity">Stock Quantity</label>
                        <input
                          type="number"
                          class="form-control"
                          id="stockQuantity"
                          name="stock"
                          value="<%= productData.stock %>"
                          min="0"
                          required
                        />
                        <span id="stockQuantity-error" class="text-danger"></span>
                      </div>
                      <div class="form-group col-md-4">
                        <label for="price">Price (₹)</label>
                        <input
                          type="number"
                          step="0.01"
                          class="form-control"
                          id="price"
                          name="price"
                          value="<%= productData.price %>"
                          min="0"
                          required
                        />
                        <span id="price-error" class="text-danger"></span>
                      </div>
                    </div>

                    <div class="form-group">
                      <label for="tags">Tags (comma separated)</label>
                      <input
                        type="text"
                        class="form-control"
                        id="tags"
                        name="tags"
                        value="<%= Array.isArray(productData.tags)
  ? productData.tags.join(', ')
  : productData.tags %>"
                        placeholder="e.g. running, sports"
                      />
                      <span id="tags-error" class="text-danger"></span>
                    </div>

                    <div class="mt-4">
                      <button type="submit" class="btn btn-success btn-lg mr-3">
                        UPDATE PRODUCT
                      </button>
                      <button type="reset" class="btn btn-secondary btn-lg mr-3">
                        CLEAR FIELDS
                      </button>
                      <a href="/admin/allproducts" class="btn btn-outline-primary btn-lg">BACK</a>
                    </div>
                  </div>

                  <!-- Right Column: Image Gallery -->
                  <div class="col-md-5">
                    <div class="border p-4 rounded bg-light">
                      <h5 class="text-center mb-4">
                        Product Images (Current: <%= productData.photos.length %>)
                      </h5>

                      <div class="form-group">
                        <label for="photos">Add New Images</label>
                        <input
                          type="file"
                          class="form-control-file"
                          name="photos"
                          id="photos"
                          accept="image/*"
                          multiple
                        />
                        <small class="form-text text-muted"
                          >Select new images to add (existing ones can be removed below).</small
                        >
                      </div>

                      <div
                        class="image-preview-container d-flex flex-wrap justify-content-center mt-3"
                      >
                        <% productData.photos.forEach((photo, i) => { %>
                        <div
                          class="image-wrapper m-2 text-center"
                          data-index="<%= i %>"
                          data-filename="<%= photo.filename %>"
                        >
                          <img
                            src="/uploads/<%= photo.filename %>"
                            class="img-thumbnail"
                            width="120"
                            height="120"
                            alt="Product Image"
                          />
                          <br />
                          <button type="button" class="btn btn-sm btn-danger mt-2 remove-image-btn">
                            Remove
                          </button>
                          <input
                            type="hidden"
                            name="existingPhotos[]"
                            value="<%= photo.filename %>"
                          />
                        </div>
                        <% }) %>

                        <% if (productData.photos.length === 0) { %>
                        <p class="text-center text-muted w-100">No images uploaded yet.</p>
                        <% } %>
                      </div>
                    </div>
                  </div>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>

    <footer class="footer mt-5 py-3 bg-light border-top">
      <div class="container text-center">
        <p class="mb-0 text-muted">© 2024 ShoesZone.</p>
      </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/popper.js@1.16.1/dist/umd/popper.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>

    <script>
      const form = document.getElementById("myForm");
      const photoInput = document.getElementById("photos");
      const previewContainer = document.querySelector(".image-preview-container");

      // Remove existing image (client-side only — server will handle deletion)
      previewContainer.addEventListener("click", (e) => {
        if (e.target.classList.contains("remove-image-btn")) {
          const wrapper = e.target.closest(".image-wrapper");
          const hiddenInput = wrapper.querySelector('input[name="existingPhotos[]"]');
          if (hiddenInput) hiddenInput.remove(); // Prevent sending to server
          wrapper.remove();
        }
      });

      // Preview newly selected images
      photoInput.addEventListener("change", (e) => {
        const files = e.target.files;
        for (let file of files) {
          const reader = new FileReader();
          reader.onload = (ev) => {
            const wrapper = document.createElement("div");
            wrapper.className = "image-wrapper m-2 text-center";
            const img = document.createElement("img");
            img.src = ev.target.result;
            img.className = "img-thumbnail";
            img.width = 120;
            img.height = 120;
            wrapper.appendChild(img);
            wrapper.innerHTML += '<br><small class="text-success">New Image</small>';
            previewContainer.appendChild(wrapper);
          };
          reader.readAsDataURL(file);
        }
      });

      // Basic validation
      form.addEventListener("submit", (e) => {
        let valid = true;
        document.querySelectorAll(".text-danger").forEach((el) => (el.textContent = ""));

        const name = document.getElementById("name").value.trim();
        if (name.length < 3) {
          document.getElementById("name-error").textContent = "Name must be at least 3 characters";
          valid = false;
        }

        const desc = document.getElementById("description").value.trim();
        if (desc.length < 10) {
          document.getElementById("description-error").textContent =
            "Description must be at least 10 characters";
          valid = false;
        }

        if (!valid) e.preventDefault();
      });
    </script>
  </body>
</html>
