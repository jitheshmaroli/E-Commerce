<%- include('../includes/userHead.ejs') %>
<link rel="stylesheet" href="/css/profile-shared.css" />
<%- include('../includes/userHeader.ejs') %>

<% const getOverallStatus = (items) => { if (items.every(i => i.status === 'Delivered')) return
'Delivered'; if (items.every(i => i.status === 'Cancelled')) return 'Cancelled'; if (items.some(i =>
i.status === 'Shipped')) return 'Shipped'; if (items.some(i => i.status === 'Pending')) return
'Pending'; return 'Mixed'; }; const statusPillClass = s => ({ Delivered: 'pill-delivered', Shipped:
'pill-shipped', Pending: 'pill-pending', Cancelled: 'pill-cancelled', }[s] || 'pill-mixed'); const
statusIcon = s => ({ Delivered: 'fa-check-circle', Shipped: 'fa-truck', Pending: 'fa-clock',
Cancelled: 'fa-times-circle', }[s] || 'fa-box'); %>

<% if (user) { %>
<div class="account-shell">
  <%- include('../includes/accountNav.ejs', { activePage: 'orders' }) %>

  <div class="account-content">
    <div class="account-card">
      <div class="account-card-header">
        <div class="account-card-icon"><i class="fas fa-box"></i></div>
        <h2>Order History</h2>
      </div>
      <div class="account-card-body">
        <% if (orders && orders.length > 0) { %>

        <div class="orders-grid">
          <% orders.forEach(order => { %>
          <%
            const overallStatus = getOverallStatus(order.items);
            const pillClass     = statusPillClass(overallStatus);
            const icon          = statusIcon(overallStatus);
          %>
          <div class="order-row-card">
            <!-- Meta -->
            <div class="order-meta">
              <div class="order-id">#<%= order.uniqueOrderId %></div>
              <div class="order-date">
                <i class="far fa-calendar-alt me-1"></i
                ><%= new Date(order.createdAt).toDateString() %>
              </div>
              <div class="order-total">
                ₹<%= order.totalCost.toFixed ? order.totalCost.toFixed(2) : order.totalCost %>
              </div>
            </div>

            <!-- Thumbnails -->
            <div class="order-thumbs">
              <% order.items.slice(0, 3).forEach(item => { %>
              <img
                src="/uploads/<%= item.productId.photos[0].filename %>"
                alt="<%= item.productId.name %>"
                class="order-thumb"
                title="<%= item.productId.name %>"
              />
              <% }) %>
              <% if (order.items.length > 3) { %>
              <div class="order-thumb-more">+<%= order.items.length - 3 %></div>
              <% } %>
            </div>

            <!-- Status -->
            <div class="order-status-cell">
              <span class="order-status-pill <%= pillClass %>">
                <i class="fas <%= icon %>"></i>
                <%= overallStatus %>
              </span>
              <span style="font-size: 0.72rem; color: var(--grey-400)"
                ><%= order.items.length %> item<%= order.items.length !== 1 ? 's' : '' %></span
              >
            </div>

            <!-- Action -->
            <div class="order-actions">
              <a href="/order-details/<%= order._id %>" class="btn-order-detail">
                <i class="fas fa-arrow-right"></i> Details
              </a>
            </div>
          </div>
          <% }) %>
        </div>

        <!-- Pagination -->
        <% if (totalPages > 1) { %>
        <div class="pagination mt-4">
          <% for (let i = 1; i <= totalPages; i++) { %>
          <a
            href="/order-history?page=<%= i %>"
            class="page-link <%= i === currentPage ? 'current-page' : '' %>"
          >
            <%= i %>
          </a>
          <% } %>
        </div>
        <% } %>

        <% } else { %>
        <div class="orders-empty">
          <i class="fas fa-shopping-bag"></i>
          <h3>No Orders Yet</h3>
          <p>You haven't placed any orders. Start shopping!</p>
          <a href="/products" class="btn-shop-now"><i class="fas fa-arrow-right"></i> Shop Now</a>
        </div>
        <% } %>
      </div>
    </div>
  </div>
</div>
<% } %>

<%- include('../includes/userFooter.ejs') %>
<%- include('../includes/userScripts.ejs') %>
