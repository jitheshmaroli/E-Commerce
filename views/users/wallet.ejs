<%- include('../includes/userHead.ejs') %>
<link rel="stylesheet" href="/css/wallet.css" />

<%- include('../includes/userHeader.ejs') %>

<main class="main">
  <% if (user) { %>
  <aside class="sidebar">
    <div class="profile-section">
      <div class="avatar">
        <img
          src="<%= user.photo && user.photo.length > 0 ? '/uploads/' + user.photo[0].filename : '/images/avatar.jpg' %>"
          alt="Profile Avatar" />
      </div>
      <ul class="profile-links">
        <li><a href="/profile">User Profile</a></li>
        <li><a href="/address">Address</a></li>
        <li><a href="/order-history">Order History</a></li>
        <li><a href="/change-password">Change Password</a></li>
        <li><a href="/wallet">Wallet</a></li>
      </ul>
    </div>
  </aside>
  <section class="content">
    <div class="container">
      <h2 class="page-title">My Wallet</h2>
      <div class="card mb-4">
        <div class="card-body">
          <h3 class="card-title">Current Balance</h3>
          <h4 class="card-text text-primary">₹<%= user.wallet.toFixed(2) %></h4>
        </div>
      </div>
      <h3>Transaction History</h3>
      <div class="transaction-list">
        <table class="table table-striped">
          <thead>
            <tr>
              <th>Date</th>
              <th>Description</th>
              <th>Amount</th>
              <th>Type</th>
            </tr>
          </thead>
          <tbody>
            <% user.walletTransactions.forEach(transaction => { %>
            <tr>
              <td><%= transaction.createdAt.toLocaleDateString() %></td>
              <td><%= transaction.description %></td>
              <td
                class="<%= transaction.type === 'credit' ? 'text-success' : 'text-danger' %>">
                <%= transaction.type === 'credit' ? '+' : '-' %>₹<%=
                transaction.amount.toFixed(2) %>
              </td>
              <td>
                <%= transaction.type.charAt(0).toUpperCase() +
                transaction.type.slice(1) %>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </section>
  <% } %>
</main>

<%- include('../includes/userFooter.ejs') %> <%-
include('../includes/userScripts.ejs') %>

<script>
  function setCategory(category) {
    const selectedCategory = document.getElementById("selectedCategory");
    if (selectedCategory) selectedCategory.value = category;
    const dropdownText = document.querySelector(".dropdown-toggle-text");
    if (dropdownText)
      dropdownText.textContent =
        category.charAt(0).toUpperCase() + category.slice(1);
  }
</script>
