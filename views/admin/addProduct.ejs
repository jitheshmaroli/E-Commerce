<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Add New Product - Admin</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    />
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/addProduct.css" />
  </head>
  <body class="bg-light">
    <!-- Navbar & Sidebar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
      <div class="container-fluid">
        <a class="navbar-brand fw-bold" href="/admin">
          <img src="/test.jpg" alt="Logo" width="35" class="d-inline-block align-text-top me-2" />
          SportZilon Admin
        </a>
        <button
          class="navbar-toggler"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#navbarNav"
        >
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav ms-auto">
            <li class="nav-item dropdown">
              <a
                class="nav-link dropdown-toggle text-white"
                href="#"
                id="adminDropdown"
                role="button"
                data-bs-toggle="dropdown"
              >
                ADMIN
              </a>
              <ul class="dropdown-menu dropdown-menu-end">
                <li><a class="dropdown-item" href="/admin/logout">Logout</a></li>
              </ul>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <div class="d-flex">
      <aside class="sidebar bg-dark text-white p-3" style="width: 250px; min-height: 100vh">
        <div class="list-group list-group-flush">
          <a
            href="/admin"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3"
          >
            <i class="fas fa-home me-2"></i> HOME
          </a>
          <a
            href="/admin/allproducts"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3 active"
          >
            <i class="fas fa-box me-2"></i> ALL PRODUCTS
          </a>
          <a
            href="/admin/ordersList"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3"
          >
            <i class="fas fa-shopping-cart me-2"></i> ORDERS LIST
          </a>
          <a
            href="/admin/usersList"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3"
          >
            <i class="fas fa-users me-2"></i> USERS LIST
          </a>
          <a
            href="/admin/categoryList"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3"
          >
            <i class="fas fa-tags me-2"></i> CATEGORY LIST
          </a>
          <a
            href="/admin/couponList"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3"
          >
            <i class="fas fa-gift me-2"></i> COUPON LIST
          </a>
          <a
            href="/admin/offers"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3"
          >
            <i class="fas fa-percentage me-2"></i> OFFERS
          </a>
        </div>
      </aside>

      <main class="content flex-grow-1 p-4">
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb bg-transparent p-0 mb-4">
            <li class="breadcrumb-item">
              <a href="/admin/allproducts" class="text-dark">All Products</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Add New Product</li>
          </ol>
        </nav>

        <div class="card shadow-lg border-0" style="max-width: 900px; margin: 0 auto">
          <div class="card-header bg-dark text-white text-center py-3">
            <h4 class="mb-0">Add New Product</h4>
          </div>
          <div class="card-body p-4">
            <form
              id="productForm"
              method="POST"
              action="/admin/addproduct"
              enctype="multipart/form-data"
            >
              <div class="row">
                <!-- Left Column: Form Fields -->
                <div class="col-lg-7">
                  <div class="mb-4">
                    <label for="name" class="form-label fw-bold"
                      >Product Name <span class="text-danger">*</span></label
                    >
                    <input
                      type="text"
                      class="form-control"
                      id="name"
                      name="name"
                      maxlength="50"
                      required
                    />
                    <small id="nameError" class="text-danger"></small>
                  </div>

                  <div class="mb-4">
                    <label for="description" class="form-label fw-bold"
                      >Description <span class="text-danger">*</span></label
                    >
                    <textarea
                      class="form-control"
                      id="description"
                      name="description"
                      rows="4"
                      maxlength="500"
                      required
                    ></textarea>
                    <small id="descriptionError" class="text-danger"></small>
                  </div>

                  <div class="mb-4">
                    <label for="category" class="form-label fw-bold"
                      >Category <span class="text-danger">*</span></label
                    >
                    <select class="form-control" id="category" name="category" required>
                      <option value="">Select Category</option>
                      <% categoryList.forEach(cat => { %>
                      <option value="<%= cat.categoryName %>"><%= cat.categoryName %></option>
                      <% }) %>
                    </select>
                    <small id="categoryError" class="text-danger"></small>
                  </div>

                  <div class="row mb-4">
                    <div class="col-md-4">
                      <label for="brandName" class="form-label fw-bold">Brand Name</label>
                      <input type="text" class="form-control" id="brandName" name="brandName" />
                      <small id="brandNameError" class="text-danger"></small>
                    </div>
                    <div class="col-md-4">
                      <label for="stock" class="form-label fw-bold"
                        >Stock Quantity <span class="text-danger">*</span></label
                      >
                      <input
                        type="number"
                        inputmode="numeric"
                        pattern="[0-9]*"
                        class="form-control"
                        id="stock"
                        name="stock"
                        min="0"
                        required
                      />
                      <small id="stockError" class="text-danger"></small>
                    </div>
                    <div class="col-md-4">
                      <label for="price" class="form-label fw-bold"
                        >Price (₹) <span class="text-danger">*</span></label
                      >
                      <input
                        type="number"
                        inputmode="decimal"
                        step="0.01"
                        pattern="[0-9]+([.,][0-9]{1,2})?"
                        class="form-control"
                        id="price"
                        name="price"
                        min="0"
                        required
                      />
                      <small id="priceError" class="text-danger"></small>
                    </div>
                  </div>

                  <!-- <div class="mb-4">
                    <label for="tags" class="form-label fw-bold">Tags (comma separated)</label>
                    <input
                      type="text"
                      class="form-control"
                      id="tags"
                      name="tags"
                      placeholder="e.g. running, sports, lightweight"
                    />
                    <small id="tagsError" class="text-danger"></small>
                  </div> -->
                </div>

                <!-- Right Column: Image Upload -->
                <div class="col-lg-5">
                  <div class="border p-4 rounded bg-light">
                    <h5 class="text-center mb-4">Product Images (Exactly 4 required)</h5>
                    <input
                      type="file"
                      class="form-control"
                      id="photos"
                      name="photos"
                      accept="image/*"
                      multiple
                      required
                    />
                    <small class="form-text text-muted mt-2"
                      >Select exactly 4 images (JPEG, PNG, WebP).</small
                    >
                    <small id="photosError" class="text-danger d-block mt-2"></small>

                    <div
                      class="image-preview-container d-flex flex-wrap justify-content-center mt-4"
                      id="preview"
                    ></div>
                  </div>
                </div>
              </div>

              <!-- Buttons -->
              <div class="d-flex gap-3 mt-5">
                <button type="submit" class="btn product-btn flex-grow-1 py-3 fw-bold">
                  ADD PRODUCT
                </button>
                <button
                  type="button"
                  class="btn btn-outline-dark flex-grow-1 py-3"
                  onclick="clearFields()"
                >
                  CLEAR
                </button>
                <a
                  href="/admin/allproducts"
                  class="btn btn-outline-secondary flex-grow-1 py-3 text-center"
                  >BACK</a
                >
              </div>
            </form>
          </div>
        </div>
      </main>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
      // DOM Elements
      const form = document.getElementById("productForm");
      const photoInput = document.getElementById("photos");
      const preview = document.getElementById("preview");

      // Error elements
      const nameError = document.getElementById("nameError");
      const descError = document.getElementById("descriptionError");
      const categoryError = document.getElementById("categoryError");
      const brandError = document.getElementById("brandNameError");
      const stockError = document.getElementById("stockError");
      const priceError = document.getElementById("priceError");
      const photosError = document.getElementById("photosError");

      function setFieldError(errorEl, message, inputEl = null) {
        if (!errorEl) return;
        const targetInput = inputEl || errorEl.previousElementSibling;
        if (message) {
          errorEl.textContent = message;
          if (targetInput && targetInput.classList) {
            targetInput.classList.add("is-invalid");
          }
        } else {
          errorEl.textContent = "";
          if (targetInput && targetInput.classList) {
            targetInput.classList.remove("is-invalid");
          }
        }
      }

      function clearAllErrors() {
        document.querySelectorAll(".text-danger").forEach((el) => (el.textContent = ""));
        document.querySelectorAll(".is-invalid").forEach((el) => el.classList.remove("is-invalid"));
      }

      // Validation Functions
      function validateName(value) {
        value = value.trim();
        if (!value) return "Product name is required.";
        if (value.length < 3) return "Name must be at least 3 characters.";
        if (value.length > 50) return "Name cannot exceed 50 characters.";
        if (/^\s+$/.test(value)) return "Name cannot be only spaces.";
        return "";
      }

      function validateDescription(value) {
        value = value.trim();
        if (!value) return "Description is required.";
        if (value.length < 20) return "Description should be at least 20 characters.";
        if (value.length > 500) return "Description cannot exceed 500 characters.";
        return "";
      }

      function validateCategory(value) {
        return value ? "" : "Please select a category.";
      }

      function validateStock(value) {
        if (value === "" || isNaN(value)) return "Stock quantity is required.";
        const num = Number(value);
        if (!Number.isInteger(num)) return "Stock must be a whole number.";
        if (num < 0) return "Stock cannot be negative.";
        if (num > 99999) return "Stock seems too large (max 99999).";
        return "";
      }

      function validatePrice(value) {
        if (value === "" || isNaN(value)) return "Price is required.";
        const num = Number(value);
        if (num <= 0) return "Price must be greater than 0.";
        if (num < 10) return "Price should be at least ₹10.";
        if (num > 1000000) return "Price seems unusually high.";
        return "";
      }

      function validatePhotos(files) {
        if (files.length !== 4) {
          return "Exactly 4 images are required.";
        }
        for (const file of files) {
          if (!["image/jpeg", "image/png", "image/webp"].includes(file.type)) {
            return "Only JPEG, PNG, and WebP images are allowed.";
          }
          if (file.size > 5 * 1024 * 1024) {
            return "Each image must be smaller than 5MB.";
          }
        }
        return "";
      }

      // Attach real-time validation
      function attachValidation(field, validator, errorEl) {
        ["input", "blur"].forEach((event) => {
          field.addEventListener(event, () => {
            const errMsg = validator(field.value);
            setFieldError(errorEl, errMsg, field);
          });
        });
      }

      attachValidation(document.getElementById("name"), validateName, nameError);
      attachValidation(document.getElementById("description"), validateDescription, descError);
      attachValidation(document.getElementById("category"), validateCategory, categoryError);
      // Brand is optional – always clear
      document.getElementById("brandName").addEventListener("input", () => {
        setFieldError(brandError, "", document.getElementById("brandName"));
      });
      attachValidation(document.getElementById("stock"), validateStock, stockError);
      attachValidation(document.getElementById("price"), validatePrice, priceError);

      // Photo preview & validation
      photoInput.addEventListener("change", function () {
        const files = Array.from(this.files);
        const errMsg = validatePhotos(files);

        if (errMsg) {
          setFieldError(photosError, errMsg, photoInput);
          this.value = "";
          preview.innerHTML = "";
        } else {
          setFieldError(photosError, "", photoInput);
          preview.innerHTML = "";
          files.forEach((file) => {
            const reader = new FileReader();
            reader.onload = (e) => {
              const img = document.createElement("img");
              img.src = e.target.result;
              img.className = "img-thumbnail m-2";
              img.style.width = "120px";
              img.style.height = "120px";
              img.style.objectFit = "cover";
              preview.appendChild(img);
            };
            reader.readAsDataURL(file);
          });
        }
      });

      // Form submit validation
      form.addEventListener("submit", async function (e) {
        e.preventDefault();

        // Get field values
        const nameField = document.getElementById("name");
        const descField = document.getElementById("description");
        const categoryField = document.getElementById("category");
        const stockField = document.getElementById("stock");
        const priceField = document.getElementById("price");
        const brandField = document.getElementById("brandName");

        const nameErr = validateName(nameField.value);
        const descErr = validateDescription(descField.value);
        const catErr = validateCategory(categoryField.value);
        const stockErr = validateStock(stockField.value);
        const priceErr = validatePrice(priceField.value);
        const photosErr = validatePhotos(Array.from(photoInput.files));

        // Show/hide errors with proper field association
        setFieldError(nameError, nameErr, nameField);
        setFieldError(descError, descErr, descField);
        setFieldError(categoryError, catErr, categoryField);
        setFieldError(stockError, stockErr, stockField);
        setFieldError(priceError, priceErr, priceField);
        setFieldError(brandError, "", brandField);
        setFieldError(photosError, photosErr, photoInput);

        // If any error exists, stop submission
        if (nameErr || descErr || catErr || stockErr || priceErr || photosErr) {
          Swal.fire({
            icon: "error",
            title: "Validation Error",
            text: "Please correct the errors highlighted in the form.",
            confirmButtonColor: "#dc3545",
          });
          return;
        }

        // Submit via fetch
        try {
          const formData = new FormData(form);
          const res = await fetch(form.action, {
            method: "POST",
            body: formData,
          });

          const result = await res.json();

          if (res.ok || result.success) {
            await Swal.fire("Success", "Product added successfully!", "success");
            window.location.href = "/admin/allproducts";
          } else {
            Swal.fire("Error", result.message || "Failed to add product.", "error");
          }
        } catch (err) {
          Swal.fire("Error", "Something went wrong. Please try again.", "error");
        }
      });

      // Clear form function
      function clearFields() {
        form.reset();
        preview.innerHTML = "";
        clearAllErrors();
      }
    </script>
  </body>
</html>
