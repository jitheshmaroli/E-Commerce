<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Add Coupon · ShoeZone Admin</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    />
    <link rel="stylesheet" href="/css/admin-shared.css" />
  </head>
  <body>
    <!-- ── Top bar ── -->
    <header class="admin-topbar">
      <a href="/admin" class="topbar-brand">
        <div class="topbar-brand-logo"><img src="/test.jpg" alt="Logo" /></div>
        <span class="topbar-brand-name">ShoeZone <em>Admin</em></span>
      </a>
      <div class="topbar-breadcrumb">
        <a href="/admin/couponList" style="color: rgba(255, 255, 255, 0.35); text-decoration: none"
          >Coupon List</a
        >
        <i class="fas fa-chevron-right"></i>
        <span>Add New Coupon</span>
      </div>
      <div class="topbar-right">
        <div class="topbar-admin-pill" id="adminPill">
          <div class="topbar-admin-avatar">A</div>
          <span class="topbar-admin-label">Admin</span>
          <i class="fas fa-chevron-down topbar-admin-chevron"></i>
          <div class="topbar-admin-dropdown">
            <a href="/admin/logout" class="topbar-dropdown-item"
              ><i class="fas fa-sign-out-alt"></i> Logout</a
            >
          </div>
        </div>
      </div>
    </header>

    <div class="admin-shell">
      <%- include('../includes/adminSidebar.ejs', { activePage: 'coupons' }) %>

      <main class="admin-main">
        <div class="admin-page-header">
          <div class="admin-page-header-left">
            <div class="admin-page-title">Add New Coupon</div>
            <div class="admin-page-subtitle">Create a discount coupon for customers</div>
          </div>
          <a href="/admin/couponList" class="btn-admin btn-admin-ghost">
            <i class="fas fa-arrow-left"></i> Back to Coupons
          </a>
        </div>

        <div class="admin-card" style="max-width: 560px">
          <div class="admin-card-body">
            <form id="couponForm" method="POST" action="/admin/addcoupon">
              <div
                id="message"
                class="admin-error"
                style="font-weight: 700; margin-bottom: 0.75rem"
              >
                <%= message || '' %>
              </div>

              <!-- Coupon Code -->
              <div class="admin-field">
                <label class="admin-label">Coupon Code <span class="req">*</span></label>
                <input
                  type="text"
                  class="admin-input"
                  id="code"
                  name="code"
                  placeholder="e.g. NEW20"
                  maxlength="5"
                  required
                  autocomplete="off"
                  style="
                    text-transform: uppercase;
                    font-family: 'Bebas Neue', sans-serif;
                    font-size: 1.1rem;
                    letter-spacing: 0.08em;
                  "
                />
                <small id="codeError" class="admin-error"></small>
              </div>

              <!-- Discount -->
              <div class="admin-field">
                <label class="admin-label">Discount Percentage <span class="req">*</span></label>
                <input
                  type="text"
                  class="admin-input"
                  id="discount"
                  name="discount"
                  placeholder="e.g. 20"
                  inputmode="numeric"
                  min="1"
                  max="100"
                  required
                />
                <small id="discountError" class="admin-error"></small>
              </div>

              <!-- Valid From -->
              <div class="admin-field">
                <label class="admin-label">Valid From <span class="req">*</span></label>
                <input type="date" class="admin-input" id="startDate" name="startDate" required />
                <small id="startDateError" class="admin-error"></small>
              </div>

              <!-- Valid Until -->
              <div class="admin-field">
                <label class="admin-label">Valid Until <span class="req">*</span></label>
                <input type="date" class="admin-input" id="expiryDate" name="expiryDate" required />
                <small id="expiryDateError" class="admin-error"></small>
              </div>

              <!-- Buttons -->
              <div
                style="
                  display: flex;
                  gap: 0.75rem;
                  margin-top: 2rem;
                  padding-top: 1.5rem;
                  border-top: 1px solid var(--grey-100);
                "
              >
                <button
                  type="submit"
                  class="btn-admin btn-admin-primary"
                  style="flex: 1; justify-content: center; padding: 0.85rem"
                >
                  ADD COUPON
                </button>
                <button
                  type="button"
                  class="btn-admin btn-admin-ghost"
                  onclick="clearFields()"
                  style="flex: 1; justify-content: center; padding: 0.85rem"
                >
                  CLEAR
                </button>
                <a
                  href="/admin/couponList"
                  class="btn-admin btn-admin-ghost"
                  style="flex: 1; justify-content: center; padding: 0.85rem"
                >
                  BACK
                </a>
              </div>
            </form>
          </div>
        </div>
      </main>
    </div>

    <footer class="admin-footer">© 2024 ShoeZone Admin Panel. All rights reserved.</footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
      document.getElementById("adminPill")?.addEventListener("click", function (e) {
        e.stopPropagation();
        this.classList.toggle("open");
      });
      document.addEventListener("click", () =>
        document.getElementById("adminPill")?.classList.remove("open")
      );

      const codeInput = document.getElementById("code");
      const discountInput = document.getElementById("discount");
      const startInput = document.getElementById("startDate");
      const expiryInput = document.getElementById("expiryDate");

      const codeError = document.getElementById("codeError");
      const discountError = document.getElementById("discountError");
      const startError = document.getElementById("startDateError");
      const expiryError = document.getElementById("expiryDateError");

      // Real-time validation + auto uppercase for code
      [codeInput, discountInput, startInput, expiryInput].forEach((input) => {
        input.addEventListener("input", validateField);
        input.addEventListener("blur", validateField);
      });

      codeInput.addEventListener("input", () => {
        codeInput.value = codeInput.value.toUpperCase();
      });

      function validateField(e) {
        const input = e.target;
        const value = input.value.trim();
        let errorEl = document.getElementById(`${input.id}Error`);
        let msg = "";

        if (input === codeInput) {
          if (!value) msg = "Coupon code is required";
          else if (value.length < 3 || value.length > 5) msg = "Code must be 3–5 characters";
          else if (!/[A-Z]/.test(value)) msg = "Code must contain at least one uppercase letter";
        } else if (input === discountInput) {
          const num = parseFloat(value);
          if (!value) msg = "Discount is required";
          else if (isNaN(num) || num < 1 || num > 100) msg = "Discount must be 1–100";
        } else if (input === startInput) {
          if (!value) msg = "Start date is required";
          else {
            const selected = new Date(value);
            const today = new Date();
            today.setHours(0, 0, 0, 0);
            if (selected < today) msg = "Start date cannot be in the past";
          }
        } else if (input === expiryInput) {
          if (!value) msg = "Expiry date is required";
          else {
            const selected = new Date(value);
            const tomorrow = new Date();
            tomorrow.setDate(tomorrow.getDate() + 1);
            tomorrow.setHours(0, 0, 0, 0);
            if (selected <= new Date()) msg = "Expiry must be in the future";
          }
        }

        errorEl.textContent = msg;
        input.classList.toggle("is-invalid", !!msg);

        // Cross-field validation: start < expiry
        if (startInput.value && expiryInput.value) {
          const s = new Date(startInput.value);
          const e = new Date(expiryInput.value);
          if (s >= e) {
            expiryError.textContent = "Expiry date must be after start date";
            expiryInput.classList.add("is-invalid");
          } else if (expiryError.textContent === "Expiry date must be after start date") {
            expiryError.textContent = "";
            expiryInput.classList.remove("is-invalid");
          }
        }
      }

      function isFormValid() {
        let valid = true;
        [codeInput, discountInput, startInput, expiryInput].forEach((input) => {
          validateField({ target: input });
          if (input.classList.contains("is-invalid")) valid = false;
        });
        return valid;
      }

      document.getElementById("couponForm").addEventListener("submit", async function (e) {
        e.preventDefault();

        if (!isFormValid()) {
          Swal.fire({
            icon: "warning",
            title: "Invalid Input",
            text: "Please correct the errors shown.",
            timer: 2500,
            showConfirmButton: false,
          });
          return;
        }

        const formData = new FormData(this);
        const data = Object.fromEntries(formData);

        try {
          const res = await fetch("/admin/addcoupon", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(data),
          });

          const result = await res.json();

          if (result.success) {
            await Swal.fire("Success", "Coupon added successfully!", "success");
            window.location.href = "/admin/couponList";
          } else {
            Swal.fire("Error", result.message || "Failed to add coupon.", "error");
          }
        } catch (err) {
          Swal.fire("Error", "Network error occurred.", "error");
        }
      });

      function clearFields() {
        codeInput.value = "";
        discountInput.value = "";
        startInput.value = "";
        expiryInput.value = "";
        document.querySelectorAll(".admin-error").forEach((el) => (el.textContent = ""));
        document
          .querySelectorAll(".admin-input")
          .forEach((el) => el.classList.remove("is-invalid"));
      }
    </script>
  </body>
</html>
