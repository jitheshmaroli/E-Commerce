<%- include('../includes/userHead.ejs') %>
<link rel="stylesheet" href="/css/profile-shared.css" />

<%- include('../includes/userHeader.ejs') %>

<% if (user) { %>
<div class="account-shell">
  <%- include('../includes/accountNav.ejs', { activePage: 'password' }) %>

  <div class="account-content">
    <div class="account-card">
      <div class="account-card-header">
        <div class="account-card-icon"><i class="fas fa-lock"></i></div>
        <h2>Change Password</h2>
      </div>
      <div class="account-card-body">
        <% if (message) { %>
        <div class="alert alert-danger mb-3"><%= message %></div>
        <% } %>

        <form action="/change-password" method="post">
          <div class="acc-form">
            <div class="acc-field">
              <label for="current-password">Current Password</label>
              <input type="password" id="current-password" name="currentPassword" required />
            </div>

            <div class="acc-field">
              <label for="new-password">New Password</label>
              <input type="password" id="new-password" name="newPassword" required />
              <div class="password-strength-bar mt-2">
                <div class="password-strength-fill" id="strength-fill"></div>
              </div>
              <span class="strength-label" id="password-strength-meter"></span>
              <span id="password-error" class="field-error"></span>
            </div>

            <div class="acc-field">
              <label for="confirm-password">Confirm New Password</label>
              <input type="password" id="confirm-password" name="confirmPassword" required />
              <span id="confirm-error" class="field-error"></span>
            </div>

            <button type="submit" id="submit-button" class="btn-acc-submit" disabled>
              <i class="fas fa-key"></i> Update Password
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
<% } %>

<%- include('../includes/userFooter.ejs') %>
<%- include('../includes/userScripts.ejs') %>

<script>
  const passwordInput = document.getElementById("new-password");
  const confirmInput = document.getElementById("confirm-password");
  const submitButton = document.getElementById("submit-button");
  const strengthFill = document.getElementById("strength-fill");
  const strengthMeter = document.getElementById("password-strength-meter");
  const passwordError = document.getElementById("password-error");
  const confirmError = document.getElementById("confirm-error");

  const strengthConfig = [
    { label: "Too Weak", color: "#ef4444", width: "20%" },
    { label: "Weak", color: "#f97316", width: "35%" },
    { label: "Fair", color: "#eab308", width: "55%" },
    { label: "Good", color: "#22c55e", width: "75%" },
    { label: "Strong", color: "#15803d", width: "100%" },
  ];

  function calcStrength(pw) {
    let s = 0;
    if (pw.length >= 8) s++;
    if (/[A-Z]/.test(pw)) s++;
    if (/[a-z]/.test(pw)) s++;
    if (/\d/.test(pw)) s++;
    if (/[^a-zA-Z0-9\s]/.test(pw)) s++;
    return s;
  }

  function updateStrength(pw) {
    const score = calcStrength(pw);
    const cfg = strengthConfig[Math.max(0, score - 1)] || strengthConfig[0];

    if (pw.length === 0) {
      strengthFill.style.width = "0";
      strengthMeter.textContent = "";
      return;
    }

    strengthFill.style.width = cfg.width;
    strengthFill.style.background = cfg.color;
    strengthMeter.textContent = cfg.label;
    strengthMeter.style.color = cfg.color;

    if (score <= 2 || pw.length < 8) {
      submitButton.disabled = true;
      passwordError.textContent = "Password too weak — use 8+ chars, uppercase, number & symbol.";
    } else {
      passwordError.textContent = "";
      validateAll();
    }
  }

  function validateAll() {
    const pwOk = passwordError.textContent === "";
    const cfOk = confirmError.textContent === "";
    submitButton.disabled = !(pwOk && cfOk);
  }

  passwordInput.addEventListener("keyup", () => updateStrength(passwordInput.value));
  confirmInput.addEventListener("keyup", () => {
    if (confirmInput.value !== passwordInput.value) {
      confirmError.textContent = "Passwords do not match.";
      submitButton.disabled = true;
    } else {
      confirmError.textContent = "";
      validateAll();
    }
  });

  function setCategory(c) {
    const el = document.getElementById("selectedCategory");
    if (el) el.value = c;
    const dt = document.querySelector(".dropdown-toggle-text");
    if (dt) dt.textContent = c.charAt(0).toUpperCase() + c.slice(1);
  }
</script>
