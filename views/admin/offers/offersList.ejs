<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Offers List - Admin</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdn.datatables.net/2.0.8/css/dataTables.bootstrap5.min.css"
    />
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/adminCouponList.css" />
  </head>
  <body class="bg-light">
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
      <div class="container-fluid">
        <a class="navbar-brand fw-bold" href="/admin">
          <img src="/test.jpg" alt="Logo" width="35" class="d-inline-block align-text-top me-2" />
          SportZilon Admin
        </a>
        <button
          class="navbar-toggler"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#navbarNav"
        >
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav ms-auto">
            <li class="nav-item dropdown">
              <a
                class="nav-link dropdown-toggle text-white"
                href="#"
                id="adminDropdown"
                role="button"
                data-bs-toggle="dropdown"
              >
                ADMIN
              </a>
              <ul class="dropdown-menu dropdown-menu-end">
                <li><a class="dropdown-item" href="/admin/logout">Logout</a></li>
              </ul>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <div class="d-flex">
      <!-- Sidebar -->
      <aside class="sidebar bg-dark text-white p-3" style="width: 250px; min-height: 100vh">
        <div class="list-group list-group-flush">
          <a
            href="/admin"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3"
          >
            <i class="fas fa-home me-2"></i> HOME
          </a>
          <a
            href="/admin/allproducts"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3"
          >
            <i class="fas fa-box me-2"></i> ALL PRODUCTS
          </a>
          <a
            href="/admin/ordersList"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3"
          >
            <i class="fas fa-shopping-cart me-2"></i> ORDERS LIST
          </a>
          <a
            href="/admin/usersList"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3"
          >
            <i class="fas fa-users me-2"></i> USERS LIST
          </a>
          <a
            href="/admin/categoryList"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3"
          >
            <i class="fas fa-tags me-2"></i> CATEGORY LIST
          </a>
          <a
            href="/admin/couponList"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3"
          >
            <i class="fas fa-gift me-2"></i> COUPON LIST
          </a>
          <a
            href="/admin/offers"
            class="list-group-item list-group-item-action bg-dark text-white border-0 py-3 active"
          >
            <i class="fas fa-percentage me-2"></i> OFFERS
          </a>
        </div>
      </aside>

      <!-- Main Content -->
      <main class="content flex-grow-1 p-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
          <h2 class="mb-0">Offers List</h2>
          <a href="/admin/offers/add-offer" class="btn btn-dark px-4 py-2">
            <i class="fas fa-plus me-2"></i> Add New Offer
          </a>
        </div>

        <% if (offers && offers.length > 0) { %>
        <div class="card shadow-lg border-0">
          <div class="card-body p-0">
            <div class="table-responsive">
              <table id="offersTable" class="table table-hover table-striped align-middle">
                <thead class="table-dark">
                  <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Discount</th>
                    <th>Offer Type</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th>Status</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% offers.forEach(offer => { %>
                  <tr data-offer-id="<%= offer._id %>">
                    <td class="fw-bold"><%= offer.name %></td>
                    <td><%= offer.description %></td>
                    <td>
                      <%= offer.discountType === 'percentage' ? offer.discountValue + '%' : '₹' + offer.discountValue %>
                    </td>
                    <td>
                      <%= offer.offerType.charAt(0).toUpperCase() + offer.offerType.slice(1) %>
                    </td>
                    <td>
                      <%= new Date(offer.startDate).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                    </td>
                    <td>
                      <%= new Date(offer.endDate).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                    </td>
                    <td>
                      <span class="badge <%= offer.isActive ? 'bg-success' : 'bg-danger' %>">
                        <%= offer.isActive ? 'Active' : 'Inactive' %>
                      </span>
                    </td>
                    <td>
                      <a
                        href="/admin/offers/edit/<%= offer._id %>"
                        class="btn btn-warning btn-sm me-2"
                        title="Edit"
                      >
                        <i class="fas fa-edit"></i>
                      </a>
                      <button class="btn btn-danger btn-sm delete-offer" title="Delete">
                        <i class="fas fa-trash"></i>
                      </button>
                    </td>
                  </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
        <% } else { %>
        <div class="alert alert-info text-center py-5">
          <i class="fas fa-percentage fa-3x mb-3 text-muted"></i>
          <h4>No offers found</h4>
          <p class="text-muted">Click "Add New Offer" to create your first offer</p>
        </div>
        <% } %>
      </main>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
      $(document).ready(function () {
        $("#offersTable").DataTable({
          responsive: true,
          pageLength: 10,
          lengthMenu: [5, 10, 25, 50],
          order: [[4, "desc"]],
          language: {
            search: "Search offers:",
            emptyTable: "No offers found",
          },
        });
      });

      // Delete Offer with SweetAlert
      document.querySelectorAll(".delete-offer").forEach((btn) => {
        btn.addEventListener("click", function () {
          const offerId = this.closest("tr").dataset.offerId;

          Swal.fire({
            title: "Are you sure?",
            text: "This offer will be permanently deleted!",
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: "#d33",
            cancelButtonColor: "#3085d6",
            confirmButtonText: "Yes, delete it!",
          }).then(async (result) => {
            if (result.isConfirmed) {
              try {
                const res = await fetch(`/admin/offers/delete/${offerId}`, { method: "POST" });
                const data = await res.json();

                if (data.success || res.ok) {
                  Swal.fire("Deleted!", "Offer has been deleted.", "success").then(() =>
                    location.reload()
                  );
                } else {
                  Swal.fire("Error!", data.message || "Failed to delete offer.", "error");
                }
              } catch (err) {
                Swal.fire("Error!", "Network error occurred.", "error");
              }
            }
          });
        });
      });
    </script>
  </body>
</html>
