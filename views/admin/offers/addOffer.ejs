<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Add New Offer</title>

    <!-- Bootstrap 4 CSS -->
    <link
      rel="stylesheet"
      href="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css"
    />
    <link rel="stylesheet" href="/css/addProduct.css" />
  </head>
  <body>
    <nav class="navbar navbar-expand-lg navbar-light bg-light">
      <div class="container-fluid">
        <a class="navbar-brand" href="/admin">
          <img
            src="/test.jpg"
            alt="Logo"
            width="30"
            height="24"
            class="d-inline-block align-text-top"
          />
          SportZilon
        </a>
        <div class="collapse navbar-collapse">
          <ul class="navbar-nav ml-auto">
            <li class="nav-item dropdown">
              <a
                class="nav-link dropdown-toggle"
                href="#"
                id="navbarDropdown"
                role="button"
                data-toggle="dropdown"
                aria-expanded="false"
              >
                ADMIN
              </a>
              <ul class="dropdown-menu dropdown-menu-right">
                <li><a class="dropdown-item" href="#">Action</a></li>
                <li><hr class="dropdown-divider" /></li>
                <li><a class="dropdown-item" href="/admin/logout">Logout</a></li>
              </ul>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <main class="main">
      <aside class="sidebar">
        <div class="p-3">
          <div class="list-group sidebar-list">
            <a href="/admin"
              ><button type="button" class="list-group-item list-group-item-action">HOME</button></a
            >
            <a href="/admin/allproducts"
              ><button type="button" class="list-group-item list-group-item-action">
                ALL PRODUCTS
              </button></a
            >
            <a href="/admin/ordersList"
              ><button type="button" class="list-group-item list-group-item-action">
                ORDERS LIST
              </button></a
            >
            <a href="/admin/usersList"
              ><button type="button" class="list-group-item list-group-item-action">
                USERS LIST
              </button></a
            >
            <a href="/admin/categoryList"
              ><button type="button" class="list-group-item list-group-item-action">
                CATEGORY LIST
              </button></a
            >
            <a href="/admin/couponList"
              ><button type="button" class="list-group-item list-group-item-action">
                COUPON LIST
              </button></a
            >
            <a href="/admin/offers"
              ><button type="button" class="list-group-item list-group-item-action active">
                OFFERS
              </button></a
            >
          </div>
        </div>
      </aside>

      <section class="content">
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/admin/offers">OFFERS</a></li>
            <li class="breadcrumb-item active" aria-current="page">ADD NEW OFFER</li>
          </ol>
        </nav>

        <div class="container">
          <% if (message) { %>
          <div class="alert alert-info alert-dismissible fade show" role="alert">
            <%= message %>
            <button type="button" class="close" data-dismiss="alert">
              <span>&times;</span>
            </button>
          </div>
          <% } %>

          <div class="row justify-content-center">
            <div class="col-lg-8 col-md-10">
              <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                  <h4 class="mb-0">Create New Offer</h4>
                </div>
                <div class="card-body">
                  <form action="/admin/offers/add-offer" method="POST" id="offerForm">
                    <div class="form-row">
                      <div class="form-group col-md-6">
                        <label for="name">Offer Name <span class="text-danger">*</span></label>
                        <input
                          type="text"
                          class="form-control"
                          id="name"
                          name="name"
                          required
                          maxlength="50"
                        />
                        <small class="text-danger" id="nameError"></small>
                      </div>

                      <div class="form-group col-md-6">
                        <label for="discountType"
                          >Discount Type <span class="text-danger">*</span></label
                        >
                        <select class="form-control" id="discountType" name="discountType" required>
                          <option value="">Select Type</option>
                          <option value="percentage">Percentage (%)</option>
                          <option value="amount">Fixed Amount (₹)</option>
                        </select>
                        <small class="text-danger" id="discountTypeError"></small>
                      </div>
                    </div>

                    <div class="form-group">
                      <label for="discountValue"
                        >Discount Value <span class="text-danger">*</span></label
                      >
                      <input
                        type="number"
                        class="form-control"
                        id="discountValue"
                        name="discountValue"
                        required
                        min="1"
                        step="1"
                      />
                      <small class="form-text text-muted" id="discountHint"
                        >For percentage: 1–100. For amount: any positive value.</small
                      >
                      <small class="text-danger" id="discountValueError"></small>
                    </div>

                    <div class="form-group">
                      <label for="description"
                        >Description <span class="text-danger">*</span></label
                      >
                      <textarea
                        class="form-control"
                        id="description"
                        name="description"
                        rows="4"
                        required
                        maxlength="200"
                      ></textarea>
                      <small class="text-danger" id="descriptionError"></small>
                    </div>

                    <div class="form-row">
                      <div class="form-group col-md-6">
                        <label for="startDate">Start Date <span class="text-danger">*</span></label>
                        <input
                          type="date"
                          class="form-control"
                          id="startDate"
                          name="startDate"
                          required
                        />
                        <small class="text-danger" id="startDateError"></small>
                      </div>
                      <div class="form-group col-md-6">
                        <label for="endDate">End Date <span class="text-danger">*</span></label>
                        <input
                          type="date"
                          class="form-control"
                          id="endDate"
                          name="endDate"
                          required
                        />
                        <small class="text-danger" id="endDateError"></small>
                      </div>
                    </div>

                    <div class="form-group">
                      <label for="offerType">Apply To <span class="text-danger">*</span></label>
                      <select class="form-control" id="offerType" name="offerType" required>
                        <option value="">Select Target</option>
                        <option value="product">Specific Product</option>
                        <option value="category">Specific Category</option>
                        <option value="all">All Products</option>
                        <option value="referral">Referral Bonus</option>
                      </select>
                      <small class="text-danger" id="offerTypeError"></small>
                    </div>

                    <div class="form-group" id="productGroup">
                      <label for="product">Product</label>
                      <select class="form-control" id="product" name="product">
                        <option value="">None (not applicable)</option>
                        <option value="all">All Products</option>
                        <% if (products && products.length > 0) { %> <% products.forEach(product =>
                        { %>
                        <option value="<%= product._id %>"><%= product.name %></option>
                        <% }) %>
                        <% } %>
                      </select>
                      <small class="text-danger" id="productError"></small>
                    </div>

                    <div class="form-group" id="categoryGroup">
                      <label for="category">Category</label>
                      <select class="form-control" id="category" name="category">
                        <option value="">None (not applicable)</option>
                        <option value="all">All Categories</option>
                        <% if (categories && categories.length > 0) { %> <%
                        categories.forEach(category => { %>
                        <option value="<%= category._id %>"><%= category.categoryName %></option>
                        <% }) %>
                        <% } %>
                      </select>
                      <small class="text-danger" id="categoryError"></small>
                    </div>

                    <div class="form-group mt-4">
                      <button type="submit" class="btn btn-success btn-lg mr-3">Add Offer</button>
                      <a href="/admin/offers" class="btn btn-outline-secondary btn-lg">Cancel</a>
                    </div>
                  </form>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="footer mt-auto py-3 bg-light border-top">
      <div class="container text-center">
        <p class="mb-0 text-muted">© 2024 ShoesZone. All rights reserved.</p>
      </div>
    </footer>

    <!-- Bootstrap 4 JS + Dependencies -->
    <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/popper.js@1.16.1/dist/umd/popper.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>

    <script>
      const offerTypeSelect = document.getElementById("offerType");
      const productGroup = document.getElementById("productGroup");
      const categoryGroup = document.getElementById("categoryGroup");
      const productSelect = document.getElementById("product");
      const categorySelect = document.getElementById("category");
      const discountTypeSelect = document.getElementById("discountType");
      const discountValueInput = document.getElementById("discountValue");

      // Handle Offer Type change
      offerTypeSelect.addEventListener("change", function () {
        const value = this.value;
        productGroup.style.display = value === "product" || value === "all" ? "block" : "none";
        categoryGroup.style.display = value === "category" || value === "all" ? "block" : "none";

        // Reset selections
        if (value !== "product") productSelect.value = "";
        if (value !== "category") categorySelect.value = "";
      });

      // Handle Discount Type change
      discountTypeSelect.addEventListener("change", function () {
        if (this.value === "percentage") {
          discountValueInput.max = 100;
          discountValueInput.min = 1;
          discountValueInput.step = 1;
          discountValueInput.placeholder = "Enter percentage (1-100)";
        } else if (this.value === "amount") {
          discountValueInput.removeAttribute("max");
          discountValueInput.min = 0.01;
          discountValueInput.step = 0.01;
          discountValueInput.placeholder = "Enter amount";
        }
      });

      // Client-side validation on submit
      document.getElementById("offerForm").addEventListener("submit", function (e) {
        e.preventDefault();

        // Clear previous errors
        document.querySelectorAll(".text-danger").forEach((el) => (el.textContent = ""));

        let isValid = true;

        // Name
        const name = document.getElementById("name").value.trim();
        if (name.length < 3 || name.length > 50) {
          document.getElementById("nameError").textContent = "Name must be 3–50 characters";
          isValid = false;
        }

        // Description
        const desc = document.getElementById("description").value.trim();
        if (desc.length < 10 || desc.length > 200) {
          document.getElementById("descriptionError").textContent =
            "Description must be 10–200 characters";
          isValid = false;
        }

        // Discount Type & Value
        const discountType = discountTypeSelect.value;
        const discountValue = parseFloat(discountValueInput.value);

        if (!discountType) {
          document.getElementById("discountTypeError").textContent = "Please select discount type";
          isValid = false;
        }

        if (isNaN(discountValue) || discountValue <= 0) {
          document.getElementById("discountValueError").textContent =
            "Enter a valid positive value";
          isValid = false;
        } else if (discountType === "percentage" && (discountValue < 1 || discountValue > 100)) {
          document.getElementById("discountValueError").textContent =
            "Percentage must be between 1 and 100";
          isValid = false;
        }

        // Dates
        const startDate = document.getElementById("startDate").value;
        const endDate = document.getElementById("endDate").value;
        if (startDate && endDate && new Date(endDate) <= new Date(startDate)) {
          document.getElementById("endDateError").textContent = "End date must be after start date";
          isValid = false;
        }

        // Offer Type and Target
        const offerType = offerTypeSelect.value;
        if (!offerType) {
          document.getElementById("offerTypeError").textContent =
            "Please select where to apply the offer";
          isValid = false;
        } else if (offerType === "product" && !productSelect.value) {
          document.getElementById("productError").textContent = "Please select a product";
          isValid = false;
        } else if (offerType === "category" && !categorySelect.value) {
          document.getElementById("categoryError").textContent = "Please select a category";
          isValid = false;
        }

        if (isValid) {
          this.submit();
        }
      });

      // Initialize on load
      offerTypeSelect.dispatchEvent(new Event("change"));
      discountTypeSelect.dispatchEvent(new Event("change"));
    </script>
  </body>
</html>
