<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create Account – ShoeZone</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
    />
    <link rel="stylesheet" href="/css/auth-shared.css" />
  </head>
  <body>
    <div class="auth-page">
      <!-- ── Brand Panel ── -->
      <div class="auth-panel-brand">
        <div class="auth-brand-top">
          <a href="/" class="auth-logo-wrap">
            <img src="/test.jpg" alt="ShoeZone" class="auth-logo-img" />
            <span class="auth-logo-text">Shoe<em>Zone</em></span>
          </a>
        </div>
        <div class="auth-panel-mid">
          <div class="auth-panel-tagline">Join the<br /><span>Sole</span><br />Club.</div>
          <p class="auth-panel-sub">
            Create your account and get access to exclusive drops, early sales, and personalised
            picks.
          </p>
        </div>
        <div class="auth-panel-bottom">
          <div class="auth-stat">
            <div class="auth-stat-num">50K+</div>
            <div class="auth-stat-label">Members</div>
          </div>
          <div class="auth-stat">
            <div class="auth-stat-num">Free</div>
            <div class="auth-stat-label">Returns</div>
          </div>
          <div class="auth-stat">
            <div class="auth-stat-num">24/7</div>
            <div class="auth-stat-label">Support</div>
          </div>
        </div>
      </div>

      <!-- ── Form Panel ── -->
      <div class="auth-panel-form">
        <div class="auth-form-scroll">
          <div class="auth-form-inner">
            <div class="auth-form-title">Create Account</div>
            <div class="auth-form-sub">It's free and takes less than a minute</div>

            <% if (message) { %>
            <div class="auth-alert auth-alert-error">
              <i class="fas fa-circle-exclamation"></i>
              <span><%= message %></span>
              <button class="auth-alert-close" onclick="this.closest('.auth-alert').remove()">
                &times;
              </button>
            </div>
            <% } %>

            <form action="/signup" method="POST" id="signupForm" novalidate>
              <div class="auth-field">
                <label for="name">Full Name</label>
                <input type="text" id="name" name="name" required />
                <span class="auth-field-error" id="nameError"
                  >Name is required (min 3 characters).</span
                >
              </div>

              <div class="auth-field">
                <label for="email">Email Address</label>
                <input type="email" id="email" name="email" required autocomplete="email" />
                <span class="auth-field-error" id="emailError"
                  >Please enter a valid email address.</span
                >
              </div>

              <div class="auth-field">
                <label for="password">Password</label>
                <div class="auth-pw-wrap">
                  <input type="password" id="password" name="password" required minlength="8" />
                  <button
                    type="button"
                    class="auth-pw-toggle"
                    id="togglePw"
                    aria-label="Toggle password"
                  >
                    <i class="fas fa-eye-slash"></i>
                  </button>
                </div>
                <div class="auth-strength-bar">
                  <div class="auth-strength-fill" id="strengthFill"></div>
                </div>
                <span class="auth-field-hint hint-mute" id="passwordHint"></span>
              </div>

              <div class="auth-field">
                <label for="confirmPassword">Confirm Password</label>
                <div class="auth-pw-wrap">
                  <input type="password" id="confirmPassword" name="confirmPassword" required />
                  <button
                    type="button"
                    class="auth-pw-toggle"
                    id="toggleCpw"
                    aria-label="Toggle confirm"
                  >
                    <i class="fas fa-eye-slash"></i>
                  </button>
                </div>
                <span class="auth-field-error" id="confirmError">Passwords do not match.</span>
              </div>

              <button type="submit" id="submitBtn" class="btn-auth-submit" disabled>
                Create Account
              </button>

              <div class="auth-divider">or</div>

              <a href="/auth/google" class="btn-auth-google">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path
                    d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
                    fill="#4285F4"
                  />
                  <path
                    d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
                    fill="#34A853"
                  />
                  <path
                    d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"
                    fill="#FBBC05"
                  />
                  <path
                    d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
                    fill="#EA4335"
                  />
                </svg>
                Continue with Google
              </a>

              <div class="auth-links">
                <a href="/login">Already have an account? <strong>Log in</strong></a>
              </div>
            </form>
          </div>
        </div>
        <div class="auth-form-footer">© 2026 ShoeZone. All rights reserved.</div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      const nameInput = document.getElementById("name");
      const emailInput = document.getElementById("email");
      const pw = document.getElementById("password");
      const cpw = document.getElementById("confirmPassword");
      const submitBtn = document.getElementById("submitBtn");
      const passwordHint = document.getElementById("passwordHint");
      const strengthFill = document.getElementById("strengthFill");
      const nameError = document.getElementById("nameError");
      const emailError = document.getElementById("emailError");
      const confirmError = document.getElementById("confirmError");
      const togglePw = document.getElementById("togglePw");
      const toggleCpw = document.getElementById("toggleCpw");

      const strengthCfg = [
        { label: "Too weak", color: "#ef4444", width: "20%" },
        { label: "Weak", color: "#f97316", width: "35%" },
        { label: "Fair", color: "#eab308", width: "55%" },
        { label: "Good", color: "#22c55e", width: "75%" },
        { label: "Strong ✓", color: "#15803d", width: "100%" },
      ];

      function calcStrength(v) {
        let s = 0;
        if (v.length >= 8) s++;
        if (/[A-Z]/.test(v)) s++;
        if (/[a-z]/.test(v)) s++;
        if (/\d/.test(v)) s++;
        if (/[^a-zA-Z0-9\s]/.test(v)) s++;
        return s;
      }

      function validateName() {
        let v = nameInput.value.trim().replace(/\s+/g, " ");
        if (nameInput.value !== v) nameInput.value = v;
        if (!v) {
          nameError.textContent = "Name is required.";
          nameError.classList.add("visible");
          nameInput.classList.remove("is-valid", "is-invalid");
          return false;
        }
        if (!/^[a-zA-Z]/.test(v)) {
          nameError.textContent = "Name must start with a letter.";
          nameError.classList.add("visible");
          nameInput.classList.add("is-invalid");
          nameInput.classList.remove("is-valid");
          return false;
        }
        if (v.length < 3) {
          nameError.textContent = "Name must be at least 3 characters.";
          nameError.classList.add("visible");
          nameInput.classList.add("is-invalid");
          nameInput.classList.remove("is-valid");
          return false;
        }
        if (!/^[a-zA-Z][a-zA-Z\s]*[a-zA-Z]$/.test(v) && v.length >= 2) {
          nameError.textContent = "Only letters and spaces allowed.";
          nameError.classList.add("visible");
          nameInput.classList.add("is-invalid");
          nameInput.classList.remove("is-valid");
          return false;
        }
        nameError.classList.remove("visible");
        nameInput.classList.remove("is-invalid");
        nameInput.classList.add("is-valid");
        return true;
      }

      function validateEmail() {
        const v = emailInput.value.trim();
        const ok = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v);
        emailInput.classList.toggle("is-invalid", v.length > 0 && !ok);
        emailInput.classList.toggle("is-valid", ok);
        emailError.classList.toggle("visible", v.length > 0 && !ok);
        return ok;
      }

      function validatePassword() {
        const v = pw.value;
        if (!v) {
          strengthFill.style.width = "0";
          passwordHint.textContent = "";
          passwordHint.className = "auth-field-hint hint-mute";
          pw.classList.remove("is-valid", "is-invalid");
          return false;
        }
        const score = calcStrength(v);
        const cfg = strengthCfg[Math.max(0, score - 1)];
        strengthFill.style.width = cfg.width;
        strengthFill.style.background = cfg.color;
        const rules = [
          { ok: v.length >= 8, msg: "At least 8 characters" },
          { ok: /[A-Z]/.test(v), msg: "One uppercase letter" },
          { ok: /[a-z]/.test(v), msg: "One lowercase letter" },
          { ok: /\d/.test(v), msg: "One number" },
          { ok: /[^a-zA-Z0-9\s]/.test(v), msg: "One special character" },
        ];
        const first = rules.find((r) => !r.ok);
        if (first) {
          passwordHint.textContent = first.msg + " required";
          passwordHint.className = "auth-field-hint hint-err";
          pw.classList.add("is-invalid");
          pw.classList.remove("is-valid");
          return false;
        }
        passwordHint.textContent = cfg.label;
        passwordHint.className = "auth-field-hint hint-ok";
        pw.classList.remove("is-invalid");
        pw.classList.add("is-valid");
        return true;
      }

      function validateConfirm() {
        const v = cpw.value;
        if (!v) {
          confirmError.classList.remove("visible");
          cpw.classList.remove("is-valid", "is-invalid");
          return false;
        }
        const ok = v === pw.value;
        confirmError.classList.toggle("visible", !ok);
        cpw.classList.toggle("is-invalid", !ok);
        cpw.classList.toggle("is-valid", ok);
        return ok;
      }

      function refreshSubmit() {
        const ok = validateName() && validateEmail() && validatePassword() && validateConfirm();
        submitBtn.disabled = !ok;
      }

      nameInput.addEventListener("input", refreshSubmit);
      emailInput.addEventListener("input", refreshSubmit);
      pw.addEventListener("input", () => {
        validatePassword();
        validateConfirm();
        refreshSubmit();
      });
      cpw.addEventListener("input", () => {
        validateConfirm();
        refreshSubmit();
      });

      // Password toggles
      togglePw.addEventListener("click", () => {
        const show = pw.type === "password";
        pw.type = show ? "text" : "password";
        togglePw.innerHTML = `<i class="fas fa-eye${show ? "" : "-slash"}"></i>`;
      });
      toggleCpw.addEventListener("click", () => {
        const show = cpw.type === "password";
        cpw.type = show ? "text" : "password";
        toggleCpw.innerHTML = `<i class="fas fa-eye${show ? "" : "-slash"}"></i>`;
      });

      refreshSubmit();
    </script>
  </body>
</html>
